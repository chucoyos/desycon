<% content_for :title, "Servicios de facturación" %>

<div class="w-full px-4 sm:px-6 lg:px-4 py-4 sm:py-6 lg:py-8" data-controller="modal">
  <div class="mb-8">
    <div class="flex items-start gap-4">
      <div class="flex items-start gap-4">
        <div class="flex items-center justify-center w-14 h-14 rounded-xl bg-gradient-to-br from-emerald-500 to-emerald-600 shadow-lg">
          <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6M7 4h10a2 2 0 012 2v12a2 2 0 01-2 2H7a2 2 0 01-2-2V6a2 2 0 012-2z"/>
          </svg>
        </div>
        <div>
          <h1 class="font-bold text-3xl text-gray-900">Servicios de facturación</h1>
          <p class="text-sm text-gray-500 mt-1">Listado para emitir CFDI individual o en lote</p>
        </div>
      </div>
    </div>
  </div>

  <div class="bg-white rounded-xl shadow-md border border-gray-200 p-5 mb-6">
    <div class="flex items-center gap-2 mb-4">
      <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"/>
      </svg>
      <h2 class="text-sm font-semibold text-gray-700 uppercase tracking-wider">Filtros</h2>
    </div>

    <%= form_with url: services_path, method: :get, class: "w-full", data: { turbo: false } do |f| %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4">
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">Contenedor</label>
          <%= f.text_field :container_number,
              value: @selected_container_number,
              placeholder: "Buscar número de contenedor",
              maxlength: 11,
              class: "w-full px-3 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 text-sm transition-all" %>
        </div>

        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">BL House</label>
          <%= f.text_field :blhouse,
              value: @selected_blhouse,
              placeholder: "Buscar BL House",
              class: "w-full px-3 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 text-sm transition-all" %>
        </div>

        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">Fecha inicio</label>
          <%= f.date_field :start_date,
              value: @selected_start_date,
              class: "w-full px-3 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 text-sm transition-all" %>
        </div>

        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">Fecha fin</label>
          <%= f.date_field :end_date,
              value: @selected_end_date,
              class: "w-full px-3 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 text-sm transition-all" %>
        </div>

        <div class="flex gap-2 items-end">
          <%= f.submit "Filtrar", class: "cursor-pointer px-4 py-2.5 bg-emerald-600 hover:bg-emerald-700 text-white rounded-lg text-sm font-semibold transition-all shadow-sm hover:shadow-md" %>
          <%= link_to "Limpiar", services_path, class: "px-4 py-2.5 bg-gray-100 hover:bg-gray-200 text-gray-700 rounded-lg text-sm font-medium transition-colors" %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="mb-6">
    <%= render "shared/tailwind_pagination", paginated: @services %>
  </div>

  <div class="mb-4 flex justify-end">
    <button
      type="button"
      data-action="click->modal#open"
      data-modal-id="services-quick-guide-modal"
      class="cursor-pointer inline-flex items-center gap-2 px-3 py-2 rounded-md border border-emerald-200 bg-emerald-50 text-emerald-700 hover:bg-emerald-100 text-sm font-semibold"
    >
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
        <path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.852l.041-.02M21 12a9 9 0 11-18 0 9 9 0 0118 0zM12 8.25h.008v.008H12V8.25z" />
      </svg>
      Guía rápida
    </button>
  </div>

  <div class="mb-4 flex justify-start">
    <%= form_with url: issue_batch_services_path, method: :post, local: true, id: "services-batch-invoice-form", class: "flex items-center gap-3" do %>
      <%= submit_tag "Facturar seleccionados",
          id: "services-batch-submit",
          disabled: true,
          data: { turbo_confirm: "Se emitirá CFDI para los servicios seleccionados. ¿Deseas continuar?" },
          class: "cursor-pointer inline-flex items-center justify-center h-10 px-4 rounded-full text-sm font-semibold bg-emerald-600 text-white hover:bg-emerald-700 disabled:opacity-50 disabled:cursor-not-allowed" %>
      <span id="services-selected-count" class="text-xs font-semibold text-emerald-800">0 seleccionados</span>
    <% end %>
  </div>

  <div class="hidden lg:block bg-white shadow-sm rounded-xl border border-gray-100 overflow-visible">
    <table class="w-full divide-y divide-gray-200 table-fixed">
      <thead class="bg-gradient-to-r from-gray-50 to-white">
        <tr>
          <th class="px-2 py-3 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider w-10">
            <input type="checkbox" id="services-select-all" class="h-4 w-4 rounded border-gray-300 text-emerald-600 focus:ring-emerald-500" />
          </th>
          <th class="px-2 py-3 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider w-28">Estado</th>
          <th class="px-2 py-3 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider w-[10rem]">Servicio</th>
          <th class="px-2 py-3 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider w-[10rem]">Contenedor</th>
          <th class="px-2 py-3 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider w-[10rem]">BL House</th>
          <th class="px-2 py-3 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider w-[9rem]">Agencia</th>
          <th class="px-2 py-3 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider w-[9rem]">Cliente</th>
          <th class="px-2 py-3 text-right text-xs font-semibold text-gray-700 uppercase tracking-wider w-[8rem]">Monto</th>
          <th class="px-2 py-3 text-right text-xs font-semibold text-gray-700 uppercase tracking-wider w-[6rem]">Opciones</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-100">
        <% if @services.any? %>
          <% @services.each do |service| %>
            <tr class="hover:bg-gray-50 transition-colors duration-150">
              <td class="px-2 py-3 align-top">
                <% unless service[:facturado] %>
                  <input
                    type="checkbox"
                    name="service_tokens[]"
                    value="<%= service[:token] %>"
                    form="services-batch-invoice-form"
                    class="services-selector h-4 w-4 rounded border-gray-300 text-emerald-600 focus:ring-emerald-500"
                  />
                <% end %>
              </td>
              <td class="px-2 py-3 whitespace-nowrap text-xs text-gray-700">
                <% status_badge_class = service[:facturado] ? "bg-emerald-100 text-emerald-800 border-emerald-200" : "bg-amber-100 text-amber-800 border-amber-200" %>
                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[11px] font-semibold border <%= status_badge_class %>">
                  <%= service[:status_label] %>
                </span>
              </td>
              <td class="px-2 py-3 text-sm text-gray-700" title="<%= service[:service_name] %>">
                <span class="font-medium block truncate"><%= truncate(service[:service_name], length: 18) %></span>
              </td>
              <td class="px-2 py-3 whitespace-nowrap text-sm text-gray-700" title="<%= service[:container_number] %>">
                <span class="block truncate"><%= truncate(service[:container_number], length: 12) %></span>
              </td>
              <td class="px-2 py-3 whitespace-nowrap text-sm text-gray-700" title="<%= service[:blhouse] %>">
                <span class="block truncate"><%= truncate(service[:blhouse], length: 12) %></span>
              </td>
              <td class="px-2 py-3 text-sm text-gray-700" title="<%= service[:agency_name] %>">
                <span class="block truncate"><%= truncate(service[:agency_name], length: 16) %></span>
              </td>
              <td class="px-2 py-3 text-sm text-gray-700" title="<%= service[:client_name] %>">
                <span class="block truncate"><%= truncate(service[:client_name], length: 16) %></span>
              </td>
              <td class="px-2 py-3 whitespace-nowrap text-sm text-right font-semibold text-gray-900"><%= number_to_currency(service[:amount], unit: "$", precision: 2) %></td>
              <td class="px-2 py-3 whitespace-nowrap text-right text-sm font-medium">
                <div class="relative inline-block text-left" data-controller="dropdown">
                  <button type="button" class="h-10 w-10 inline-flex items-center justify-center rounded-full text-slate-500 hover:text-slate-700 hover:bg-slate-100 transition-colors focus:outline-none focus:ring-2 focus:ring-emerald-500" data-action="click->dropdown#toggle" title="Opciones">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2z"></path>
                    </svg>
                  </button>

                  <div data-dropdown-target="menu" class="hidden absolute right-0 mt-2 w-64 rounded-2xl border border-slate-200 bg-white shadow-[0_14px_40px_rgba(15,23,42,0.16)] z-50 origin-top-right">
                    <div class="py-2" role="menu">
                      <% if service[:type] == "ContainerService" %>
                        <%= link_to container_path(service[:container_id], anchor: "servicios"), class: "flex items-center gap-3 px-4 py-2.5 text-sm text-slate-700 hover:bg-slate-50 hover:text-slate-900 transition-colors", role: "menuitem" do %>
                          Ver
                        <% end %>
                      <% else %>
                        <%= link_to bl_house_line_path(service[:bl_house_line_id], anchor: "servicios"), class: "flex items-center gap-3 px-4 py-2.5 text-sm text-slate-700 hover:bg-slate-50 hover:text-slate-900 transition-colors", role: "menuitem" do %>
                          Ver
                        <% end %>
                      <% end %>

                      <% unless service[:facturado] %>
                        <div class="my-1 border-t border-slate-200"></div>
                        <%= button_to "Facturar individual",
                            issue_manual_invoices_path(invoiceable_type: service[:type], invoiceable_id: service[:service_id]),
                            method: :post,
                            form: { data: { turbo_confirm: "Se emitirá CFDI para este servicio. ¿Deseas continuar?" } },
                            class: "w-full text-left flex items-center gap-3 px-4 py-2.5 text-sm text-indigo-700 hover:bg-indigo-50 hover:text-indigo-900 transition-colors" %>
                      <% else %>
                        <% if service[:invoice_id].present? %>
                          <%= link_to invoice_path(service[:invoice_id]), class: "flex items-center gap-3 px-4 py-2.5 text-sm text-indigo-700 hover:bg-indigo-50 hover:text-indigo-900 transition-colors", role: "menuitem" do %>
                            Ver factura
                          <% end %>
                        <% else %>
                          <div class="px-4 py-2.5 text-sm text-gray-400">Factura no disponible</div>
                        <% end %>
                      <% end %>
                    </div>
                  </div>
                </div>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="9" class="px-6 py-12 text-center">
              <p class="text-gray-500 text-lg font-medium">No hay servicios para los filtros seleccionados</p>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div class="lg:hidden space-y-4">
    <% if @services.any? %>
      <% @services.each do |service| %>
        <div class="bg-white shadow-sm rounded-xl p-4 border border-gray-100">
          <div class="flex items-start justify-between gap-3">
            <div>
              <p class="text-xs text-gray-500">Estado</p>
              <% status_badge_class = service[:facturado] ? "bg-emerald-100 text-emerald-800" : "bg-amber-100 text-amber-800" %>
              <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold <%= status_badge_class %>"><%= service[:status_label] %></span>
            </div>
            <% unless service[:facturado] %>
              <input
                type="checkbox"
                name="service_tokens[]"
                value="<%= service[:token] %>"
                form="services-batch-invoice-form"
                class="services-selector h-4 w-4 rounded border-gray-300 text-emerald-600 focus:ring-emerald-500"
              />
            <% end %>
          </div>

          <div class="mt-3 grid grid-cols-2 gap-3 text-sm text-gray-700">
            <div>
              <p class="text-xs text-gray-500">Servicio</p>
              <p class="font-medium" title="<%= service[:service_name] %>"><%= truncate(service[:service_name], length: 18) %></p>
            </div>
            <div>
              <p class="text-xs text-gray-500">Contenedor</p>
              <p class="font-medium"><%= service[:container_number] %></p>
            </div>
            <div>
              <p class="text-xs text-gray-500">BL House</p>
              <p class="font-medium"><%= service[:blhouse] %></p>
            </div>
            <div>
              <p class="text-xs text-gray-500">Cliente</p>
              <p class="font-medium" title="<%= service[:client_name] %>"><%= truncate(service[:client_name], length: 16) %></p>
            </div>
            <div>
              <p class="text-xs text-gray-500">Agencia aduanal</p>
              <p class="font-medium" title="<%= service[:agency_name] %>"><%= truncate(service[:agency_name], length: 16) %></p>
            </div>
            <div class="col-span-2">
              <p class="text-xs text-gray-500">Monto</p>
              <p class="font-semibold text-gray-900"><%= number_to_currency(service[:amount], unit: "$", precision: 2) %></p>
            </div>
          </div>

          <% unless service[:facturado] %>
            <div class="mt-3 pt-3 border-t border-gray-100 space-y-2">
              <% if service[:type] == "ContainerService" %>
                <%= link_to "Ver", container_path(service[:container_id], anchor: "servicios"), class: "w-full inline-flex items-center justify-center px-3 py-2 rounded-lg text-sm font-semibold bg-slate-50 text-slate-700 border border-slate-200 hover:bg-slate-100" %>
              <% else %>
                <%= link_to "Ver", bl_house_line_path(service[:bl_house_line_id], anchor: "servicios"), class: "w-full inline-flex items-center justify-center px-3 py-2 rounded-lg text-sm font-semibold bg-slate-50 text-slate-700 border border-slate-200 hover:bg-slate-100" %>
              <% end %>

              <%= button_to "Facturar individual",
                  issue_manual_invoices_path(invoiceable_type: service[:type], invoiceable_id: service[:service_id]),
                  method: :post,
                  form: { data: { turbo_confirm: "Se emitirá CFDI para este servicio. ¿Deseas continuar?" } },
                  class: "w-full cursor-pointer inline-flex items-center justify-center px-3 py-2 rounded-lg text-sm font-semibold bg-indigo-50 text-indigo-700 border border-indigo-200 hover:bg-indigo-100" %>
            </div>
          <% end %>
        </div>
      <% end %>
    <% else %>
      <div class="bg-white shadow-sm rounded-xl p-8 text-center border border-gray-100">
        <p class="text-gray-500 text-base font-medium">No hay servicios para los filtros seleccionados</p>
      </div>
    <% end %>
  </div>

  <div class="mt-6">
    <%= render "shared/tailwind_pagination", paginated: @services %>
  </div>
</div>

<div id="services-quick-guide-modal" data-modal-target="modal" data-action="click->modal#closeOnBackdrop" class="hidden fixed inset-0 z-50 overflow-y-auto bg-slate-900/50 backdrop-blur-sm px-4 py-6" role="dialog" aria-modal="true" aria-labelledby="services-quick-guide-title">
  <div class="mx-auto max-w-3xl">
    <div class="rounded-2xl bg-white shadow-2xl border border-slate-200 overflow-hidden">
      <div class="flex items-start justify-between gap-4 px-5 py-4 border-b border-slate-200 bg-gradient-to-r from-emerald-50 to-white">
        <div>
          <h3 id="services-quick-guide-title" class="text-lg font-bold text-slate-900 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-emerald-600">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 3.75h9A2.25 2.25 0 0118.75 6v12A2.25 2.25 0 0116.5 20.25h-9A2.25 2.25 0 015.25 18V6A2.25 2.25 0 017.5 3.75z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 8.25h7.5m-7.5 3h7.5m-7.5 3h4.5" />
            </svg>
            Guía rápida: Servicios de facturación
          </h3>
          <p class="text-sm text-slate-600 mt-1">Cómo emitir CFDI individual o en lote de forma correcta y sin rechazos.</p>
        </div>
        <button type="button" data-action="click->modal#close" class="cursor-pointer inline-flex items-center justify-center h-9 w-9 rounded-full text-slate-500 hover:text-slate-700 hover:bg-slate-100" aria-label="Cerrar guía">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <div class="px-5 py-5 space-y-4 text-sm text-slate-700">
        <div class="rounded-lg border border-sky-200 bg-sky-50 px-4 py-3">
          <p class="font-semibold text-sky-900 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-sky-700">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.042-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.852l.042-.02M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Propósito de esta pantalla
          </p>
          <p class="mt-1">Te permite emitir CFDI para servicios de dos maneras:</p>
          <p class="mt-1">1) <span class="font-semibold">Individual:</span> un servicio a la vez desde el menú de opciones.</p>
          <p class="mt-1">2) <span class="font-semibold">Lote:</span> varios servicios al mismo tiempo usando checkboxes.</p>
        </div>

        <div class="rounded-lg border border-indigo-200 bg-indigo-50 px-4 py-3">
          <p class="font-semibold text-indigo-900 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-indigo-700">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
            Cómo facturar individual
          </p>
          <p class="mt-1">1) Ubica el servicio en el listado.</p>
          <p class="mt-1">2) Abre <span class="font-semibold">Opciones</span> (botón de tres puntos).</p>
          <p class="mt-1">3) Selecciona <span class="font-semibold">Facturar individual</span> y confirma.</p>
        </div>

        <div class="rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-3">
          <p class="font-semibold text-emerald-900 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-emerald-700">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 6.75h18M3 12h18m-18 5.25h18" />
            </svg>
            Cómo facturar en lote
          </p>
          <p class="mt-1">1) Marca los servicios con checkbox.</p>
          <p class="mt-1">2) Verifica el contador de seleccionados.</p>
          <p class="mt-1">3) Presiona <span class="font-semibold">Facturar seleccionados</span>.</p>
        </div>

        <div class="rounded-lg border border-amber-200 bg-amber-50 px-4 py-3">
          <p class="font-semibold text-amber-900 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-amber-700">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9.303 3.376l-7.5-12.99a1.5 1.5 0 00-2.598 0l-7.5 12.99A1.5 1.5 0 004.5 18.75h15a1.5 1.5 0 001.303-2.624z" />
            </svg>
            Reglas para emisión exitosa
          </p>
          <p class="mt-1">1) En lote, selecciona servicios del <span class="font-semibold">mismo cliente receptor</span>.</p>
          <p class="mt-1">2) No incluyas servicios ya facturados; solo se facturan los pendientes.</p>
          <p class="mt-1">3) Revisa contenedor, BL House y monto antes de confirmar.</p>
          <p class="mt-1">4) Si un servicio ya tiene CFDI, usa <span class="font-semibold">Ver factura</span> en opciones.</p>
        </div>
      </div>

      <div class="px-5 py-4 border-t border-slate-200 bg-slate-50 flex justify-end">
        <button type="button" data-action="click->modal#close" class="cursor-pointer inline-flex items-center px-4 py-2 rounded-md bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-semibold">
          Entendido
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener("turbo:load", initServicesBatchSelection);
  document.addEventListener("turbo:render", initServicesBatchSelection);

  function initServicesBatchSelection() {
    const form = document.getElementById("services-batch-invoice-form");
    if (!form) return;

    const checkboxes = Array.from(document.querySelectorAll(".services-selector"));
    const selectAll = document.getElementById("services-select-all");
    const submitButton = document.getElementById("services-batch-submit");
    const countElement = document.getElementById("services-selected-count");

    const updateState = () => {
      const selected = checkboxes.filter((checkbox) => checkbox.checked).length;
      if (submitButton) submitButton.disabled = selected === 0;
      if (countElement) countElement.textContent = `${selected} seleccionados`;
      if (selectAll) {
        const selectable = checkboxes.length;
        selectAll.checked = selectable > 0 && selected === selectable;
      }
    };

    if (selectAll) {
      selectAll.addEventListener("change", () => {
        checkboxes.forEach((checkbox) => {
          checkbox.checked = selectAll.checked;
        });
        updateState();
      });
    }

    checkboxes.forEach((checkbox) => checkbox.addEventListener("change", updateState));
    updateState();
  }
</script>
