              <%= sf.label :fecha_programada, "Fecha programada", class: "block text-sm font-semibold text-gray-700 mb-2" %>
              <%= sf.date_field :fecha_programada, class: "w-full px-3 py-2 rounded-lg border border-gray-300 focus:ring-2 focus:ring-purple-500 focus:border-purple-500" %>
            </div>

            <div>
              <%= sf.label :factura, "Factura", class: "block text-sm font-semibold text-gray-700 mb-2" %>
              <%= sf.text_field :factura, placeholder: "FAC-001", class: "w-full px-3 py-2 rounded-lg border border-gray-300 focus:ring-2 focus:ring-purple-500 focus:border-purple-500" %>
            </div>

            <div>
              <%= sf.label :observaciones, "Observaciones", class: "block text-sm font-semibold text-gray-700 mb-2" %>
              <%= sf.text_area :observaciones, rows: 3, class: "w-full px-3 py-2 rounded-lg border border-gray-300 focus:ring-2 focus:ring-purple-500 focus:border-purple-500" %>
            </div>
          </div>
        <% end %>

        <div class="mt-6 flex justify-end gap-2">
          <button type="button" data-action="click->modal#close" class="cursor-pointer px-4 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 transition-colors">Cancelar</button>
          <%= f.submit "Guardar servicio", class: "cursor-pointer px-4 py-2 bg-purple-600 text-white rounded-lg hover:bg-purple-700 transition-colors" %>
        </div>
      <% end %>
    </div>
  </div>

  <% @container.container_services.each do |service| %>
    <% next if service.facturado? %>

    <div id="container-service-edit-modal-<%= service.id %>" data-modal-target="modal" class="hidden fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full z-50" data-action="click->modal#closeOnBackdrop">
      <div class="relative top-16 mx-auto p-5 border w-full max-w-2xl shadow-lg rounded-xl bg-white">
        <div class="flex items-center justify-between border-b border-gray-100 pb-3 mb-4">
          <h3 class="text-lg font-bold text-gray-900">Editar servicio de contenedor</h3>
          <button type="button" data-action="click->modal#close" class="cursor-pointer text-gray-400 hover:text-gray-600" aria-label="Cerrar modal">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>

        <%= form_with model: @container, url: container_path(@container), method: :patch, local: true do |f| %>
          <%= hidden_field_tag :source, "show_services" %>
          <%= hidden_field_tag :service_action, "update" %>
          <%= f.fields_for :container_services, service, child_index: service.id do |sf| %>
            <div class="space-y-4">
              <%= sf.hidden_field :id %>

              <div>
                <%= sf.label :service_catalog_id, "Servicio *", class: "block text-sm font-semibold text-gray-700 mb-2" %>
                  <% service_catalog_options = @service_catalogs.map { |catalog| [catalog.display_name, catalog.id, { data: { amount: catalog.amount } }] } %>
                  <%= sf.select :service_catalog_id,
                    options_for_select(service_catalog_options, sf.object&.service_catalog_id),
                    { prompt: "Selecciona un servicio" },
                        { required: true, data: { catalog_amounts: @service_catalogs.index_by { |catalog| catalog.id.to_s }.transform_values(&:amount).to_json }, onchange: "window.desyconSyncServiceAmountFromCatalog && window.desyconSyncServiceAmountFromCatalog(this)", class: "js-service-catalog-select w-full px-3 py-2 rounded-lg border border-gray-300 focus:ring-2 focus:ring-purple-500 focus:border-purple-500" } %>
              </div>

              <div>
                <%= sf.label :amount, "Monto *", class: "block text-sm font-semibold text-gray-700 mb-2" %>
                <%= sf.number_field :amount, step: "0.01", min: 0.01, required: true, class: "js-service-amount-input w-full px-3 py-2 rounded-lg border border-gray-300 focus:ring-2 focus:ring-purple-500 focus:border-purple-500" %>
              </div>

              <div>
                <%= sf.label :billed_to_entity_id, "Facturar a", class: "block text-sm font-semibold text-gray-700 mb-2" %>
                <%= sf.collection_select :billed_to_entity_id,
                    @clients,
                    :id,
                    :name,
                    { include_blank: "Selecciona cliente" },
                    { class: "w-full px-3 py-2 rounded-lg border border-gray-300 focus:ring-2 focus:ring-purple-500 focus:border-purple-500" } %>
              </div>

              <div>
                <%= sf.label :fecha_programada, "Fecha programada", class: "block text-sm font-semibold text-gray-700 mb-2" %>
                <%= sf.date_field :fecha_programada, class: "w-full px-3 py-2 rounded-lg border border-gray-300 focus:ring-2 focus:ring-purple-500 focus:border-purple-500" %>
