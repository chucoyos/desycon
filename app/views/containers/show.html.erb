<% content_for :title, "Contenedor #{@container.number}" %>
<% is_consolidator = current_user&.consolidator? %>

<div class="w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 sm:py-6 lg:py-8">
  
  <!-- Navegación -->
  <div class="mb-4 sm:mb-6">
    <%= link_to containers_path, class: "inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium text-blue-700 hover:bg-blue-50 transition-all duration-200 group" do %>
      <svg class="w-5 h-5 transition-transform group-hover:-translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/>
      </svg>
      <span>Volver a contenedores</span>
    <% end %>
  </div>

  <!-- Header -->
  <div class="bg-white shadow-md rounded-2xl overflow-hidden mb-6">
    <div class="px-4 sm:px-6 lg:px-8 py-5 sm:py-6 border-b border-gray-100 bg-gradient-to-r from-gray-50 to-white">
      <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
        <div class="flex-1">
          <div class="flex items-center gap-3 mb-2">
            <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-gradient-to-br from-blue-600 to-blue-700 shadow-lg">
              <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
              </svg>
            </div>
            <div>
              <h1 class="text-2xl sm:text-3xl font-mono font-bold text-gray-900"><%= @container.number %></h1>
              <p class="text-sm text-gray-500">Contenedor de <%= tipo_maniobra_nombre(@container.tipo_maniobra) %></p>
            </div>
          </div>
          <div class="flex flex-wrap gap-2 mt-3">
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-sm font-medium border <%= status_badge_class(@container.status) %> shadow-sm">
              <%= status_icon(@container.status) %>
              <%= status_nombre(@container.status) %>
            </span>
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-sm font-medium border <%= tipo_maniobra_badge_class(@container.tipo_maniobra) %> shadow-sm">
              <%= tipo_maniobra_icon(@container.tipo_maniobra) %>
              <%= tipo_maniobra_nombre(@container.tipo_maniobra) %>
            </span>
          </div>
        </div>
        <div class="flex items-center gap-2">
          <% if policy(@container).update? %>
            <%= link_to edit_container_path(@container), class: "inline-flex items-center gap-2 px-4 py-2.5 rounded-lg text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 shadow-sm hover:shadow-md transition-all duration-200" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
              </svg>
              <span class="hidden sm:inline">Editar</span>
            <% end %>
          <% end %>

          <% if policy(@container).destroy? %>
            <%= button_to container_path(@container), method: :delete,
                  form: { data: { turbo_confirm: "¿Eliminar este contenedor? Esta acción no se puede deshacer." } },
                  class: "cursor-pointer inline-flex items-center gap-2 px-4 py-2.5 rounded-lg text-sm font-medium text-white bg-red-600 hover:bg-red-700 shadow-sm hover:shadow-md transition-all duration-200" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-1 12a2 2 0 01-2 2H8a2 2 0 01-2-2L5 7m5 4v6m4-6v6M9 7V4a1 1 0 011-1h4a1 1 0 011 1v3M4 7h16"/>
              </svg>
              <span class="hidden sm:inline">Eliminar</span>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Grid de contenido -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    
    <!-- Columna principal (2/3) -->
    <div class="lg:col-span-2 space-y-6">
      
      <!-- Datos Generales -->
      <section class="bg-white shadow-sm rounded-xl p-5 sm:p-6 border border-gray-100">
        <div class="flex items-center gap-3 mb-5">
          <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-blue-600 shadow-sm">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
          </div>
          <h2 class="text-xl font-bold text-gray-900">Datos Generales</h2>
        </div>
        
        <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-4">
          <div class="bg-gray-50/50 rounded-lg p-4">
            <dt class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Consolidador</dt>
            <dd class="text-base font-medium text-gray-900"><%= @container.consolidator_entity&.name || '-' %></dd>
          </div>
          <div class="bg-gray-50/50 rounded-lg p-4">
            <dt class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Línea Naviera</dt>
            <dd class="text-base font-medium text-gray-900"><%= @container.shipping_line&.iso_code || "Sin línea" %></dd>
          </div>
          <div class="bg-gray-50/50 rounded-lg p-4">
            <dt class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Tipo-tamaño</dt>
            <dd class="text-base font-medium text-gray-900"><%= @container.type_size.presence || '-' %></dd>
          </div>
          <div class="bg-gray-50/50 rounded-lg p-4">
            <dt class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Buque</dt>
            <dd class="text-base font-medium text-gray-900"><%= @container.nombre_buque %></dd>
          </div>
          <div class="bg-gray-50/50 rounded-lg p-4">
            <dt class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">BL Master</dt>
            <dd class="text-base font-medium text-gray-900 font-mono"><%= @container.bl_master || '-' %></dd>
          </div>
          <div class="bg-gray-50/50 rounded-lg p-4">
            <dt class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Puerto de Origen</dt>
            <dd class="text-base font-medium text-gray-900"><%= @container.origin_port&.display_name || '-' %></dd>
          </div>
          <div class="bg-gray-50/50 rounded-lg p-4">
            <dt class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Puerto de Destino</dt>
            <dd class="text-base font-medium text-gray-900"><%= @container.destination_port&.display_name || '-' %></dd>
          </div>
          <div class="bg-gray-50/50 rounded-lg p-4">
            <dt class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Viaje</dt>
            <dd class="text-base font-medium text-gray-900 font-mono"><%= @container.viaje || '-' %></dd>
          </div>
          <div class="bg-gray-50/50 rounded-lg p-4">
            <dt class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Recinto</dt>
            <dd class="text-base font-medium text-gray-900"><%= @container.recinto || '-' %></dd>
          </div>
          <div class="bg-gray-50/50 rounded-lg p-4">
            <dt class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Fecha de Transferencia</dt>
            <dd class="text-base font-medium text-gray-900"><%= @container.fecha_transferencia ? l(@container.fecha_transferencia, format: :long) : '-' %></dd>
          </div>
          <div class="bg-gray-50/50 rounded-lg p-4">
            <dt class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Almacén</dt>
            <dd class="text-base font-medium text-gray-900"><%= @container.almacen || '-' %></dd>
          </div>
          <div class="bg-gray-50/50 rounded-lg p-4">
            <dt class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Referencia</dt>
            <dd class="text-base font-medium text-gray-900 font-mono"><%= @container.archivo_nr || '-' %></dd>
          </div>
          <div class="bg-gray-50/50 rounded-lg p-4">
            <dt class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Sello</dt>
            <dd class="text-base font-medium text-gray-900 font-mono"><%= @container.sello || '-' %></dd>
          </div>
          <div class="bg-gray-50/50 rounded-lg p-4">
            <dt class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Ejecutivo</dt>
            <dd class="text-base font-medium text-gray-900 font-mono"><%= @container.ejecutivo || '-' %></dd>
          </div>
          <div class="bg-gray-50/50 rounded-lg p-4">
            <dt class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Fecha y Hora de Descarga</dt>
            <dd class="text-base font-medium text-gray-900"><%= @container.fecha_descarga ? l(@container.fecha_descarga, format: :long) : '-' %></dd>
          </div>
          <div class="bg-gray-50/50 rounded-lg p-4">
            <dt class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Fecha Tentativa de Desconsolidación</dt>
            <dd class="text-base font-medium text-gray-900"><%= @container.fecha_tentativa_desconsolidacion ? l(@container.fecha_tentativa_desconsolidacion, format: :long) : '-' %></dd>
          </div>
          <div class="bg-gray-50/50 rounded-lg p-4">
            <dt class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Fecha de Desconsolidación</dt>
            <dd class="text-base font-medium text-gray-900"><%= @container.fecha_desconsolidacion ? l(@container.fecha_desconsolidacion, format: :long) : '-' %></dd>
          </div>
          <div class="bg-gray-50/50 rounded-lg p-4">
            <dt class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Fecha y Hora de Revalidación BL Master</dt>
            <dd class="text-base font-medium text-gray-900"><%= @container.fecha_revalidacion_bl_master ? l(@container.fecha_revalidacion_bl_master, format: :long) : '-' %></dd>
          </div>
        </dl>
      </section>

      <!-- Partidas -->

      <section id="partidas" class="bg-white shadow-sm rounded-xl p-5 sm:p-6 border border-gray-100">
        <!-- Encabezado: icono, título, contador y botones en una sola fila -->
        <div class="flex flex-col gap-2 mb-5">
          <div class="flex flex-wrap items-center justify-between gap-4">
            <div class="flex items-center gap-3 min-w-0">
              <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-green-600 shadow-sm">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                </svg>
              </div>
              <h2 class="text-xl font-bold text-gray-900 whitespace-nowrap">Partidas</h2>
              <span class="ml-2 px-3 py-1 rounded-full text-xs font-semibold bg-green-100 text-green-800">
                <%= @container.bl_house_lines.count %> <%= @container.bl_house_lines.count == 1 ? 'partida' : 'partidas' %>
              </span>
            </div>
            <div class="flex flex-wrap items-center gap-2">
              <% if policy(BlHouseLine).create? %>
                <%= link_to new_bl_house_line_path(container_id: @container.id), class: "inline-flex items-center gap-2 px-4 py-2.5 rounded-lg text-sm font-medium text-white bg-green-600 hover:bg-green-700 shadow-sm hover:shadow-md transition-all duration-200" do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
                  </svg>
                  <span class="hidden sm:inline">Nueva Partida</span>
                <% end %>
              <% end %>
              <% if policy(@container).destroy_all_bl_house_lines? %>
                <% can_bulk_delete = @container.bl_house_lines.any? && !@bl_house_lines_docs_present %>
                <%= button_to destroy_all_bl_house_lines_container_path(@container), method: :delete,
                      form: { data: { turbo_confirm: "¿Eliminar todas las partidas? Solo es posible si ninguna tiene documentos adjuntos." } },
                      class: "inline-flex items-center gap-2 px-4 py-2.5 rounded-lg text-sm font-medium border #{can_bulk_delete ? 'border-red-200 text-red-700 bg-red-50 hover:bg-red-100 cursor-pointer' : 'border-gray-200 text-gray-400 bg-gray-50 cursor-not-allowed'} transition-all duration-200",
                      disabled: !can_bulk_delete do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-1 12a2 2 0 01-2 2H8a2 2 0 01-2-2L5 7m5 4v6m4-6v6M9 7V4a1 1 0 011-1h4a1 1 0 011 1v3M4 7h16"/>
                  </svg>
                  <span class="hidden sm:inline">Eliminar todas</span>
                <% end %>
              <% end %>
            </div>
          </div>

          <!-- Segunda fila: sección de importar partidas -->
          <% if policy(BlHouseLine).import_from_container? %>
          <div class="w-full">
            <div class="w-full rounded-lg border border-gray-200 bg-white shadow-sm p-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mt-2">
              <div class="flex items-center gap-2 text-sm text-gray-800">
                <div class="w-9 h-9 rounded-full bg-green-50 text-green-700 flex items-center justify-center shadow-inner">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a2 2 0 002 2h12a2 2 0 002-2v-1M12 12a4 4 0 100-8 4 4 0 000 8zm0 0v4" />
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-gray-900">Importar partidas</p>
                </div>
                <button type="button" title="Formatos: XLSX/CSV. Límite: 2 MB y 500 filas. Columnas requeridas: blhouse, cantidad, embalaje, contiene, marcas, peso, volumen (clase_imo, tipo_imo opcionales)." class="p-2 rounded-full text-gray-500 hover:text-gray-800 hover:bg-gray-100 transition-colors" aria-label="Ayuda sobre importación">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M12 14a4 4 0 10-4-4" />
                  </svg>
                </button>
              </div>
              <div class="flex flex-wrap items-center gap-2">
                <%= form_with url: import_bl_house_lines_container_path(@container), method: :post, html: { multipart: true, class: "flex flex-wrap items-center gap-2" } do |f| %>
                  <%= f.file_field :file, accept: ".xlsx,.csv", class: "cursor-pointer block w-56 text-sm text-gray-800 bg-white border border-gray-300 rounded-lg px-3 py-2 shadow-inner file:mr-3 file:py-2 file:px-3 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-green-600 file:text-white hover:file:bg-green-700 focus:outline-none focus:ring-2 focus:ring-green-500" %>
                  <%= f.submit "Importar", class: "cursor-pointer inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium text-white bg-green-700 hover:bg-green-800 shadow-sm transition-all duration-200" %>
                <% end %>
              </div>
            </div>
          </div>
          <% end %>
        </div>

        <% if @container.bl_house_lines.any? %>
          <div class="space-y-3">
            <% @container.bl_house_lines.each do |bl_house_line| %>
              <div class="border border-gray-200 rounded-lg p-4 hover:border-green-300 hover:bg-green-50/30 transition-all duration-200">
                <div class="flex justify-between items-start mb-2">
                  <div class="flex-1">
                    <h3 class="font-semibold text-gray-900">Partida #<%= bl_house_line.partida %></h3>
                    <p class="text-sm text-gray-600 mt-1"><%= bl_house_line.contiene&.truncate(60) %></p>
                  </div>
                  <div class="text-right">
                    <p class="text-sm font-medium text-gray-900"><%= bl_house_line.cantidad %> unidades</p>
                    <span class="inline-block mt-1 px-2 py-0.5 rounded-full text-xs font-medium <%= bl_house_line.status == 'finalizado' ? 'bg-green-100 text-green-800' : 'bg-blue-100 text-blue-800' %>">
                      <%= bl_house_line.status.humanize %>
                    </span>
                  </div>
                </div>
                <div class="flex justify-between items-center mt-3 pt-3 border-t border-gray-100">
                  <div class="text-xs text-gray-500">
                    BL: <%= bl_house_line.blhouse %>
                  </div>
                  <%= link_to bl_house_line_path(bl_house_line), class: "text-green-600 hover:text-green-800 text-sm font-medium" do %>
                    Ver detalles →
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-8">
            <svg class="w-16 h-16 text-gray-300 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
            </svg>
            <h3 class="text-sm font-medium text-gray-900 mb-1">No hay partidas</h3>
            <p class="text-sm text-gray-500 mb-4">Crea la primera partida para este contenedor</p>
            <% if policy(BlHouseLine).create? %>
              <%= link_to new_bl_house_line_path(container_id: @container.id), class: "inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium text-green-700 bg-green-50 hover:bg-green-100 border border-green-200 transition-all duration-200" do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
                </svg>
                Crear primera partida
              <% end %>
            <% end %>
          </div>
        <% end %>
      </section>

    </div>

    <!-- Columna lateral (1/3) -->
    <div class="space-y-6">

      <% unless current_user&.tramitador? %>
      <!-- Servicios -->
      <details id="servicios" class="group bg-white shadow-sm rounded-xl p-5 border border-gray-100" data-collapsible="true">
        <summary class="flex items-center justify-between cursor-pointer list-none">
          <div class="flex items-center gap-3">
            <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-purple-600 shadow-sm">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
              </svg>
            </div>
            <h2 class="text-lg font-bold text-gray-900">Servicios</h2>
            <span class="px-3 py-1 rounded-full text-xs font-semibold bg-purple-100 text-purple-800">
              <%= @container.container_services.count %>
            </span>
          </div>
          <svg class="w-5 h-5 text-gray-500 transition-transform duration-200 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </summary>

        <div class="mt-4">
        <div class="flex items-center justify-end mb-4">
          <div class="flex items-center gap-2">
            <% unless current_user&.customs_broker? || is_consolidator %>
              <button type="button"
                      data-action="click->modal#open"
                      data-modal-id="container-service-modal"
                      class="inline-flex items-center gap-2 px-3 py-1.5 rounded-lg text-xs font-semibold text-white bg-purple-600 hover:bg-purple-700 transition-all duration-200 cursor-pointer">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                </svg>
                Agregar servicio
              </button>
            <% end %>

          </div>
        </div>

        <% if @container.container_services.any? %>
          <div class="space-y-3">
            <% @container.container_services.each do |service| %>
              <div class="border border-gray-200 rounded-lg p-4 hover:border-purple-300 hover:bg-purple-50/30 transition-all duration-200">
                <div class="flex justify-between items-start mb-2">
                  <div class="flex items-start gap-3 flex-1">
                    <% if current_user&.admin_or_executive? && Rails.application.config.x.facturador.enabled && Rails.application.config.x.facturador.manual_actions_enabled && !service.facturado? %>
                      <div class="pt-0.5">
                        <%= check_box_tag "invoiceable_ids[]", service.id, false,
                            form: "container-batch-invoice-form",
                            id: "container_service_batch_#{service.id}",
                            class: "js-container-batch-checkbox h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500 cursor-pointer" %>
                      </div>
                    <% end %>

                    <div class="flex-1">
                    <h3 class="font-semibold text-gray-900"><%= service.service_catalog.name %></h3>
                    <% if service.billed_to_entity.present? %>
                      <p class="text-xs text-gray-600 mt-1">Facturar a: <%= service.billed_to_entity.name %></p>
                    <% end %>
                    </div>
                  </div>
                  <div class="text-right">
                    <p class="text-base font-bold text-gray-900">$<%= number_with_delimiter(service.amount, delimiter: ',') %> <%= service.currency || 'MXN' %></p>
                    <% if service.facturado? %>
                      <span class="inline-block mt-1 px-2 py-0.5 rounded-full text-[11px] font-medium bg-green-100 text-green-800">Facturado</span>
                    <% else %>
                      <span class="inline-block mt-1 px-2 py-0.5 rounded-full text-[11px] font-medium bg-yellow-100 text-yellow-800">Pendiente</span>
                    <% end %>
                  </div>
                </div>
                <div class="grid grid-cols-2 gap-3 text-xs text-gray-700">
                  <% if (invoice = service.latest_invoice).present? %>
                    <div class="col-span-2">
                      <span class="text-gray-500">CFDI:</span>
                      <% status_for_display = invoice.effective_status %>
                      <% badge_class = case status_for_display
                        when 'issued' then 'bg-emerald-100 text-emerald-800'
                        when 'queued' then 'bg-blue-100 text-blue-800'
                        when 'failed' then 'bg-red-100 text-red-800'
                        when 'cancel_pending' then 'bg-amber-100 text-amber-800'
                        when 'cancelled' then 'bg-slate-100 text-slate-800'
                        else 'bg-gray-100 text-gray-700'
                      end %>
                      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[11px] font-semibold <%= badge_class %>"><%= t("activerecord.attributes.invoice.statuses.#{status_for_display}", default: status_for_display.humanize) %></span>
                      <% invoice_reference = invoice.sat_uuid.presence || "Factura ##{invoice.id}" %>
                      <%= link_to invoice_reference, invoice_path(invoice), class: "ml-2 text-[11px] text-blue-700 hover:text-blue-900 underline underline-offset-2 font-mono" %>

                      <% if invoice.failed? && !invoice.last_error_code.to_s.start_with?("FACTURADOR_CANCEL_") %>
                        <details class="mt-2 rounded-md border border-red-200 bg-red-50 p-2" data-role="invoice-issue-error">
                          <summary class="cursor-pointer list-none flex items-center justify-between gap-2 text-[10px] uppercase tracking-wider text-red-700">
                            <span>Error de emisión</span>
                            <span class="text-[9px] normal-case font-medium text-red-800">Mostrar detalle</span>
                          </summary>
                          <div class="mt-2 space-y-1 border-t border-red-200 pt-2">
                            <p class="text-[11px] font-semibold text-red-800 break-all"><%= invoice.last_error_code.presence || '-' %></p>
                            <p class="text-[11px] text-red-700 whitespace-pre-wrap break-all"><%= invoice.last_error_message.presence || '-' %></p>
                            <% if invoice.provider_response.to_h["subestatus"].present? %>
                              <p class="text-[10px] text-red-700">Subestatus proveedor: <%= invoice.provider_response.to_h["subestatus"] %></p>
                            <% end %>
                          </div>
                        </details>
                      <% elsif current_user&.admin_or_executive? && invoice.last_error_code.to_s.start_with?("FACTURADOR_CANCEL_") && invoice.last_error_message.present? %>
                        <details class="mt-2 rounded-md border border-amber-200 bg-amber-50 p-2" data-role="invoice-cancel-notice">
                          <summary class="cursor-pointer list-none flex items-center justify-between gap-2 text-[10px] uppercase tracking-wider text-amber-700">
                            <span>Aviso de cancelación</span>
                            <span class="text-[9px] normal-case font-medium text-amber-800">Mostrar detalle</span>
                          </summary>
                          <div class="mt-2 space-y-1 border-t border-amber-200 pt-2">
                            <p class="text-[11px] font-semibold text-amber-900 break-all"><%= invoice.last_error_code %></p>
                            <p class="text-[11px] text-amber-800 whitespace-pre-wrap break-all"><%= invoice.last_error_message %></p>
                          </div>
                        </details>
                      <% end %>
                    </div>
                  <% end %>
                  <div>
                    <span class="text-gray-500">Fecha programada:</span>
                    <span class="font-medium"><%= service.fecha_programada ? l(service.fecha_programada, format: :short) : '-' %></span>
                  </div>
                  <% if service.factura.present? %>
                    <div>
                      <span class="text-gray-500">Factura:</span>
                      <span class="font-medium font-mono"><%= service.factura %></span>
                    </div>
                  <% end %>
                  <% if service.observaciones.present? %>
                    <div class="col-span-2">
                      <span class="text-gray-500">Observaciones:</span>
                      <p class="text-gray-700 mt-1"><%= service.observaciones %></p>
                    </div>
                  <% end %>

                  <% if current_user&.admin_or_executive? && Rails.application.config.x.facturador.enabled && Rails.application.config.x.facturador.manual_actions_enabled %>
                    <div class="col-span-2 pt-2 border-t border-gray-100 flex flex-wrap gap-2">
                      <% if invoice.present? %>
                        <% if invoice.cancel_retryable? %>
                          <% cancel_button_label = invoice.last_error_code.to_s.start_with?("FACTURADOR_CANCEL_") ? "Reintentar cancelación CFDI" : "Cancelar CFDI" %>
                          <%= form_with url: cancel_invoice_path(invoice), method: :patch, local: true, class: "flex flex-wrap items-center gap-2" do |f| %>
                            <%= f.submit cancel_button_label,
                                data: {
                                  turbo_confirm: "Esta acción solicitará la cancelación del CFDI en PAC/SAT.\n\nSi el PAC no confirma de inmediato, la factura quedará como pendiente de cancelación hasta la conciliación.\n\nMotivo aplicado: 02 - Sin relación.\n\n¿Deseas continuar?"
                                },
                                class: "inline-flex items-center px-2.5 py-1.5 rounded-md text-xs font-semibold bg-red-50 text-red-700 border border-red-200 hover:bg-red-100" %>
                          <% end %>

                          <%= button_to "Sincronizar XML/PDF", sync_documents_invoice_path(invoice), method: :post, class: "inline-flex items-center px-2.5 py-1.5 rounded-md text-xs font-semibold bg-indigo-50 text-indigo-700 border border-indigo-200 hover:bg-indigo-100" %>

                          <% if invoice.xml_file.attached? %>
                            <%= link_to "XML", rails_blob_path(invoice.xml_file, disposition: "attachment"), class: "inline-flex items-center px-2.5 py-1.5 rounded-md text-xs font-semibold bg-slate-50 text-slate-700 border border-slate-200 hover:bg-slate-100" %>
                          <% end %>

                          <% if invoice.pdf_file.attached? %>
                            <%= link_to "PDF", rails_blob_path(invoice.pdf_file, disposition: "attachment"), class: "inline-flex items-center px-2.5 py-1.5 rounded-md text-xs font-semibold bg-slate-50 text-slate-700 border border-slate-200 hover:bg-slate-100" %>
                          <% end %>
                        <% elsif invoice.status == "cancel_pending" %>
                          <%= button_to "Sincronizar XML/PDF", sync_documents_invoice_path(invoice), method: :post, class: "inline-flex items-center px-2.5 py-1.5 rounded-md text-xs font-semibold bg-indigo-50 text-indigo-700 border border-indigo-200 hover:bg-indigo-100" %>

                          <% if invoice.xml_file.attached? %>
                            <%= link_to "XML", rails_blob_path(invoice.xml_file, disposition: "attachment"), class: "inline-flex items-center px-2.5 py-1.5 rounded-md text-xs font-semibold bg-slate-50 text-slate-700 border border-slate-200 hover:bg-slate-100" %>
                          <% end %>

                          <% if invoice.pdf_file.attached? %>
                            <%= link_to "PDF", rails_blob_path(invoice.pdf_file, disposition: "attachment"), class: "inline-flex items-center px-2.5 py-1.5 rounded-md text-xs font-semibold bg-slate-50 text-slate-700 border border-slate-200 hover:bg-slate-100" %>
                          <% end %>
                        <% elsif !invoice.status.in?(["queued", "cancel_pending"]) %>
                          <%= button_to "Reintentar emisión CFDI",
                              issue_manual_invoices_path(invoiceable_type: "ContainerService", invoiceable_id: service.id),
                              method: :post,
                              form: { data: { turbo_confirm: "Se enviará nuevamente la solicitud de emisión CFDI para este servicio.\n\n¿Deseas continuar?" } },
                              class: "inline-flex items-center px-2.5 py-1.5 rounded-md text-xs font-semibold bg-blue-50 text-blue-700 border border-blue-200 hover:bg-blue-100" %>
                        <% end %>
                      <% else %>
                        <%= button_to "Emitir CFDI",
                            issue_manual_invoices_path(invoiceable_type: "ContainerService", invoiceable_id: service.id),
                            method: :post,
                            form: { data: { turbo_confirm: "Se emitirá el CFDI para este servicio.\n\n¿Deseas continuar?" } },
                            class: "inline-flex items-center px-2.5 py-1.5 rounded-md text-xs font-semibold bg-blue-50 text-blue-700 border border-blue-200 hover:bg-blue-100" %>
                      <% end %>
                    </div>
                  <% end %>

                  <% unless current_user&.customs_broker? || is_consolidator || service.facturado? %>
                    <div class="col-span-2 pt-2 border-t border-gray-100 flex justify-end gap-2">
                      <button type="button"
                              data-action="click->modal#open"
                              data-modal-id="container-service-edit-modal-<%= service.id %>"
                              class="inline-flex items-center gap-1.5 px-2.5 py-1.5 rounded-md text-xs font-semibold bg-amber-50 text-amber-700 border border-amber-200 hover:bg-amber-100 cursor-pointer">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                        </svg>
                        Editar servicio
                      </button>
                      <%= button_to container_path(@container),
                          method: :patch,
                          params: {
                            source: "show_services",
                            service_action: "destroy",
                            container: {
                              container_services_attributes: {
                                "0" => {
                                  id: service.id,
                                  _destroy: "1"
                                }
                              }
                            }
                          },
                          form: { data: { turbo_confirm: "¿Eliminar este servicio? Esta acción no se puede deshacer." } },
                          class: "inline-flex items-center gap-1.5 px-2.5 py-1.5 rounded-md text-xs font-semibold bg-red-50 text-red-700 border border-red-200 hover:bg-red-100" do %>
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-1 12a2 2 0 01-2 2H8a2 2 0 01-2-2L5 7m5 4v6m4-6v6M9 7V4a1 1 0 011-1h4a1 1 0 011 1v3M4 7h16"/>
                        </svg>
                        Eliminar servicio
                      <% end %>
                    </div>
                  <% end %>
                </div>
              </div>
            <% end %>

            <% if current_user&.admin_or_executive? && Rails.application.config.x.facturador.enabled && Rails.application.config.x.facturador.manual_actions_enabled %>
              <div id="container-batch-invoice-wrapper" class="hidden pt-3 border-t border-gray-100 flex justify-end">
                <%= form_with url: issue_manual_batch_invoices_path, method: :post, local: true, id: "container-batch-invoice-form", class: "inline-flex items-center gap-2" do %>
                  <%= hidden_field_tag :invoiceable_type, "ContainerService" %>
                  <%= submit_tag "Facturar seleccionados",
                      class: "inline-flex items-center gap-2 px-3 py-1.5 rounded-lg text-xs font-semibold text-white bg-blue-600 hover:bg-blue-700 transition-all duration-200 cursor-pointer",
                      disabled: true,
                      data: { turbo_confirm: "Se emitirá un CFDI único para los servicios seleccionados.\n\n¿Deseas continuar?" } %>
                  <span id="container-batch-selected-count" class="text-xs font-semibold text-blue-700 bg-blue-50 border border-blue-200 rounded-lg px-2 py-1 whitespace-nowrap">
                    0 seleccionados
                  </span>
                <% end %>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-sm text-gray-500">No hay servicios registrados.</p>
        <% end %>
        </div>
      </details>
      <% end %>
      
      <% unless current_user&.tramitador? %>
      <!-- Documentos -->
      <details class="group bg-white shadow-sm rounded-xl p-5 border border-gray-100" data-collapsible="true">
        <summary class="flex items-center justify-between cursor-pointer list-none">
          <div class="flex items-center gap-3">
            <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-orange-600 shadow-sm">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
              </svg>
            </div>
            <h2 class="text-lg font-bold text-gray-900">Documentos</h2>
          </div>
          <svg class="w-5 h-5 text-gray-500 transition-transform duration-200 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </summary>

        <div class="mt-4">
        
        <div class="space-y-3">
          <!-- BL Master -->
          <div class="flex items-center justify-between p-3 rounded-lg <%= @container.bl_master_documento.attached? ? 'bg-green-50 border border-green-200' : 'bg-gray-50 border border-gray-200' %>">
            <div class="flex items-center gap-3">
              <svg class="w-8 h-8 <%= @container.bl_master_documento.attached? ? 'text-green-600' : 'text-gray-400' %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
              </svg>
              <div>
                <p class="text-sm font-semibold text-gray-900">BL Master</p>
                <p class="text-xs text-gray-500" title="<%= @container.bl_master_documento.filename if @container.bl_master_documento.attached? %>">
                  <% if @container.bl_master_documento.attached? %>
                    <%= truncate_filename(@container.bl_master_documento.filename, max_length: 25) %>
                  <% else %>
                    No adjunto
                  <% end %>
                </p>
              </div>
            </div>
            <% if @container.bl_master_documento.attached? %>
              <%= link_to rails_blob_path(@container.bl_master_documento, disposition: "inline"), target: "_blank", class: "p-2 text-green-600 hover:bg-green-100 rounded-lg transition-colors", title: "Ver documento" do %>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                </svg>
              <% end %>
            <% end %>
          </div>

          <!-- Tarja -->
          <div class="flex items-center justify-between p-3 rounded-lg <%= @container.tarja_documento.attached? ? 'bg-green-50 border border-green-200' : 'bg-gray-50 border border-gray-200' %>">
            <div class="flex items-center gap-3">
              <svg class="w-8 h-8 <%= @container.tarja_documento.attached? ? 'text-green-600' : 'text-gray-400' %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
              </svg>
              <div>
                <p class="text-sm font-semibold text-gray-900">Tarja</p>
                <p class="text-xs text-gray-500" title="<%= @container.tarja_documento.filename if @container.tarja_documento.attached? %>">
                  <% if @container.tarja_documento.attached? %>
                    <%= truncate_filename(@container.tarja_documento.filename, max_length: 25) %>
                  <% else %>
                    No adjunto
                  <% end %>
                </p>
              </div>
            </div>
            <% if @container.tarja_documento.attached? %>
              <%= link_to rails_blob_path(@container.tarja_documento, disposition: "inline"), target: "_blank", class: "p-2 text-green-600 hover:bg-green-100 rounded-lg transition-colors", title: "Ver documento" do %>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                </svg>
              <% end %>
            <% end %>
          </div>

          <% if @container.documentos_completos? %>
            <div class="mt-4 p-3 bg-green-50 border border-green-200 rounded-lg">
              <div class="flex items-center gap-2 text-green-800">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <p class="text-sm font-medium">Documentos completos</p>
              </div>
            </div>
          <% else %>
            <div class="mt-4 p-3 bg-yellow-50 border border-yellow-200 rounded-lg">
              <div class="flex items-center gap-2 text-yellow-800">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                </svg>
                <p class="text-sm font-medium">Documentos incompletos</p>
              </div>
            </div>
          <% end %>
        </div>
        </div>
      </details>
      <% end %>

      <% unless current_user&.tramitador? %>
      <!-- Historial de Status -->
      <details class="group bg-white shadow-sm rounded-xl p-5 border border-gray-100" data-collapsible="true">
        <summary class="flex items-center justify-between cursor-pointer list-none">
          <div class="flex items-center gap-3">
            <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-indigo-600 shadow-sm">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <h2 class="text-lg font-bold text-gray-900">Historial</h2>
          </div>
          <svg class="w-5 h-5 text-gray-500 transition-transform duration-200 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </summary>

        <div class="mt-4">
        
        <% if @container.container_status_histories.any? %>
          <div class="space-y-3">
            <% @container.container_status_histories.order(fecha_actualizacion: :desc).limit(5).each do |history| %>
              <div class="flex gap-3 pb-3 border-b border-gray-100 last:border-0">
                <div class="flex-shrink-0 w-8 h-8 rounded-full <%= status_badge_class(history.status).split.first %> flex items-center justify-center">
                  <%= status_icon(history.status) %>
                </div>
                <div class="flex-1 min-w-0">
                  <p class="text-sm font-semibold text-gray-900"><%= status_nombre(history.status) %></p>
                  <p class="text-xs text-gray-500 mt-0.5"><%= l(history.fecha_actualizacion, format: :short) %></p>
                  <% if history.observaciones.present? %>
                    <p class="text-xs text-gray-600 mt-1"><%= history.observaciones %></p>
                  <% end %>
                  <p class="text-xs text-gray-400 mt-1">por <%= history.user&.email || "Sistema" %></p>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-6">
            <svg class="w-12 h-12 text-gray-300 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <p class="text-sm text-gray-500">Sin historial</p>
          </div>
        <% end %>
        </div>
      </details>
      <% end %>

    </div>
  </div>

  <section class="space-y-4 mt-6">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <div class="flex items-center gap-3">
        <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-blue-600 shadow-sm">
          <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7a2 2 0 012-2h3.172a2 2 0 011.414.586l.828.828A2 2 0 0011.828 7H19a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V7z"/>
          </svg>
        </div>
        <h2 class="text-lg font-bold text-gray-900">Fotografías del contenedor</h2>
      </div>

      <% if @container.photos.count.positive? && policy(Photo).download? %>
        <%= link_to "Descargar todas las fotos (#{@container.photos.count})",
              photos_download_all_container_path(@container),
              class: "w-full sm:w-auto inline-flex items-center justify-center rounded-full border border-indigo-300 bg-indigo-50 px-4 py-2 text-sm font-medium text-indigo-700 hover:bg-indigo-100" %>
      <% end %>
    </div>

    <%= render "shared/photo_module", attachable: @container, section: "apertura", title: "Apertura", subtitle: "Regularmente 5, hasta 15" %>
    <%= render "shared/photo_module", attachable: @container, section: "desconsolidacion", title: "Desconsolidación", subtitle: "Regularmente 30-40" %>
    <%= render "shared/photo_module", attachable: @container, section: "vacio", title: "Vacío", subtitle: "Regularmente 20-30" %>
  </section>
</div>

<% unless current_user&.customs_broker? || current_user&.tramitador? || is_consolidator %>
  <div id="container-service-modal" data-modal-target="modal" class="hidden fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full z-50" data-action="click->modal#closeOnBackdrop">
    <div class="relative top-16 mx-auto p-5 border w-full max-w-2xl shadow-lg rounded-xl bg-white">
      <div class="flex items-center justify-between border-b border-gray-100 pb-3 mb-4">
        <h3 class="text-lg font-bold text-gray-900">Agregar servicio a contenedor</h3>
        <button type="button" data-action="click->modal#close" class="cursor-pointer text-gray-400 hover:text-gray-600" aria-label="Cerrar modal">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
