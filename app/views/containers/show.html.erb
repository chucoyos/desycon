          <div class="mt-6 flex justify-end gap-2">
            <button type="button" data-action="click->modal#close" class="cursor-pointer px-4 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 transition-colors">Cancelar</button>
            <%= f.submit "Actualizar servicio", class: "cursor-pointer px-4 py-2 bg-purple-600 text-white rounded-lg hover:bg-purple-700 transition-colors" %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
<% end %>

<script>
  window.desyconSyncServiceAmountFromCatalog = function(select) {
    if (!select) return;

    var wrapper = select.closest('.space-y-4') || select.closest('.service-card') || select.closest('form');
    if (!wrapper) return;

    var amountInput = wrapper.querySelector('input.js-service-amount-input');
    if (!amountInput || amountInput.disabled) return;

    var selectedValue = select.value;
    var amountRaw = null;
    var rawMap = select.getAttribute('data-catalog-amounts');

    if (rawMap && selectedValue) {
      try {
        var map = JSON.parse(rawMap);
        amountRaw = map[selectedValue] || null;
      } catch (error) {
        amountRaw = null;
      }
    }

    if (!amountRaw) {
      var selectedOption = select.selectedOptions && select.selectedOptions[0];
      amountRaw = selectedOption && selectedOption.dataset ? selectedOption.dataset.amount : null;
    }

    if (amountRaw === null || amountRaw === undefined || amountRaw === '') return;

    var parsed = Number.parseFloat(String(amountRaw).replace(',', '.'));
    if (!Number.isFinite(parsed)) return;

    amountInput.value = parsed.toFixed(2);
    amountInput.dataset.autofilledFromCatalog = 'true';
  };

  (function() {
    function normalizeCatalogAmountValue(rawAmount) {
      if (rawAmount === null || rawAmount === undefined || rawAmount === '') return null;
      var parsed = Number.parseFloat(String(rawAmount).replace(',', '.'));
      return Number.isFinite(parsed) ? parsed.toFixed(2) : null;
    }

    function findServiceAmountInput(select) {
      var fieldsWrapper = select.closest('.space-y-4') || select.closest('.service-card') || select.closest('form');
      if (!fieldsWrapper) return null;
      return fieldsWrapper.querySelector('input.js-service-amount-input');
    }

    function getCatalogAmountFromSelect(select) {
      var amountFromMap = null;
      var selectedValue = select.value;
      var rawMap = select.getAttribute('data-catalog-amounts');

      if (rawMap && selectedValue) {
        try {
          var catalogAmountsMap = JSON.parse(rawMap);
          amountFromMap = catalogAmountsMap[selectedValue] || null;
        } catch (error) {
          amountFromMap = null;
        }
      }

      var selectedOption = select.selectedOptions[0];
      var amountFromOption = selectedOption && selectedOption.dataset ? selectedOption.dataset.amount : null;

      return normalizeCatalogAmountValue(amountFromMap || amountFromOption);
    }

    function syncContainerModalServiceAmount(select) {
      if (!select) return;

      var amountInput = findServiceAmountInput(select);
      if (!amountInput) return;

      var catalogAmount = getCatalogAmountFromSelect(select);
      if (!catalogAmount) return;

      if (amountInput.value.trim() === '' || amountInput.dataset.autofilledFromCatalog === 'true') {
        amountInput.value = catalogAmount;
        amountInput.dataset.autofilledFromCatalog = 'true';
      }
    }

    function initContainerModalServiceAmount() {
      document.querySelectorAll('select.js-service-catalog-select').forEach(function(select) {
        syncContainerModalServiceAmount(select);

        if (select.dataset.amountSyncInitialized === 'true') return;
        select.dataset.amountSyncInitialized = 'true';

        select.addEventListener('change', function() {
          var amountInput = findServiceAmountInput(select);
          if (amountInput) amountInput.dataset.autofilledFromCatalog = 'true';
          syncContainerModalServiceAmount(select);
        });
      });

      document.querySelectorAll('input.js-service-amount-input').forEach(function(input) {
        if (input.dataset.amountSyncInitialized === 'true') return;
        input.dataset.amountSyncInitialized = 'true';
        input.addEventListener('input', function() {
          input.dataset.autofilledFromCatalog = 'false';
        });
      });
    }

    initContainerModalServiceAmount();
    document.addEventListener('turbo:load', initContainerModalServiceAmount);

    document.addEventListener('change', function(event) {
      var select = event.target.closest('select.js-service-catalog-select');
      if (!select) return;

      var amountInput = findServiceAmountInput(select);
      if (!amountInput || amountInput.disabled) return;

      var catalogAmount = getCatalogAmountFromSelect(select);
      if (!catalogAmount) return;

      amountInput.value = catalogAmount;
      amountInput.dataset.autofilledFromCatalog = 'true';
    });
  })();

  (function() {
    function setupContainerBatchInvoiceToggle() {
      var form = document.getElementById("container-batch-invoice-form");
      if (!form) return;

      var wrapper = document.getElementById("container-batch-invoice-wrapper");
      if (!wrapper) return;

      var submit = form.querySelector('input[type="submit"], button[type="submit"]');
      if (!submit) return;

      var countEl = document.getElementById("container-batch-selected-count");

      var checkboxes = Array.from(document.querySelectorAll('input.js-container-batch-checkbox[form="container-batch-invoice-form"]'));

      var refresh = function() {
        var selectedCount = checkboxes.filter(function(checkbox) { return checkbox.checked; }).length;
        var anySelected = selectedCount > 0;
        submit.disabled = !anySelected;
        wrapper.classList.toggle("hidden", !anySelected);

        if (countEl) {
          countEl.textContent = selectedCount + " seleccionados";
        }
      };

      checkboxes.forEach(function(checkbox) {
        checkbox.addEventListener("change", refresh);
      });

      refresh();
    }

    setupContainerBatchInvoiceToggle();
    document.addEventListener("turbo:load", setupContainerBatchInvoiceToggle);
  })();
</script>
