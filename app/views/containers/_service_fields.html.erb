<% is_new = !(f.object && f.object.respond_to?(:persisted?) && f.object.persisted?) %>
<% is_invoiced = f.object&.persisted? && f.object.respond_to?(:facturado?) && f.object.facturado? %>
<% use_autocomplete = local_assigns[:container]&.persisted? && !is_invoiced %>
<% default_bill_to_entity = f.object&.billed_to_entity || local_assigns[:container]&.consolidator_entity %>
<div class="service-card rounded-lg p-3 sm:p-4 border shadow-sm hover:shadow-md transition-all duration-200 <%= is_new ? 'bg-amber-50/50 border-amber-300 ring-2 ring-amber-200' : 'bg-white border-slate-200' %>"
  data-service-persisted="<%= is_new ? 'false' : 'true' %>"
  data-service-locked="<%= is_invoiced ? 'true' : 'false' %>">
  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 sm:gap-3 mb-3 sm:mb-4">
    <div class="flex items-center gap-2">
      <span class="h-5 w-1.5 rounded-full <%= is_new ? 'bg-amber-500' : 'bg-slate-300' %>"></span>
      <h3 class="text-xs sm:text-sm font-bold text-gray-700 uppercase tracking-wider">Servicio</h3>
      <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[11px] font-semibold border <%= is_new ? 'bg-amber-50 text-amber-800 border-amber-200' : 'bg-slate-50 text-slate-700 border-slate-200' %>">
        <%= is_new ? 'Nuevo (sin guardar)' : 'Existente' %>
      </span>
      <% if is_invoiced %>
        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[11px] font-semibold border bg-emerald-50 text-emerald-800 border-emerald-200">
          Facturado
        </span>
      <% end %>
    </div>
    <% unless is_invoiced %>
      <button type="button" class="remove-service inline-flex items-center justify-center gap-1 px-3 py-1.5 sm:py-1 rounded-lg text-xs font-medium text-red-700 bg-red-50 hover:bg-red-100 border border-red-200 transition-all duration-200 w-full sm:w-auto">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
        </svg>
        Eliminar
      </button>
    <% end %>
  </div>

  <%= f.hidden_field :_destroy %>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 sm:gap-4">
    <div>
      <%= f.label :service_catalog_id, "Servicio *", class: "block text-xs font-semibold text-gray-600 mb-1 uppercase tracking-wider" %>
      <% service_catalog_options = @service_catalogs.map { |catalog| [catalog.display_name, catalog.id, { data: { amount: catalog.amount } }] } %>
      <% if use_autocomplete %>
        <div
          data-controller="catalog-autocomplete"
          data-catalog-autocomplete-url-value="<%= service_catalogs_search_container_path(local_assigns[:container]) %>"
          data-catalog-autocomplete-min-chars-value="2"
          data-catalog-autocomplete-debounce-value="300"
          class="relative"
        >
          <%= f.hidden_field :service_catalog_id,
                class: "js-service-catalog-id-input",
                data: {
                  catalog_autocomplete_target: "hiddenInput",
                  catalog_amounts: @service_catalogs.index_by { |catalog| catalog.id.to_s }.transform_values(&:amount).to_json
                } %>

          <%= text_field_tag "#{f.object_name}_service_catalog_search",
                f.object&.service_catalog&.display_name,
                autocomplete: "off",
                placeholder: "Escribe para buscar un servicio",
                required: true,
                class: "w-full px-3 py-2 text-sm rounded-lg border border-gray-300 focus:ring-2 focus:ring-purple-500 focus:border-purple-500 transition-all duration-200",
                data: {
                  catalog_autocomplete_target: "input",
                  action: "input->catalog-autocomplete#onInput keydown->catalog-autocomplete#onKeydown focus->catalog-autocomplete#onFocus blur->catalog-autocomplete#onBlur"
                } %>

          <div data-catalog-autocomplete-target="status" class="mt-1 text-xs text-gray-500"></div>
          <div data-catalog-autocomplete-target="results" class="absolute z-30 mt-2 hidden w-full rounded-lg border border-gray-200 bg-white shadow-lg max-h-72 overflow-auto"></div>
        </div>
      <% else %>
        <%= f.select :service_catalog_id,
              options_for_select(service_catalog_options, f.object&.service_catalog_id),
              { prompt: "Selecciona un servicio" },
              disabled: is_invoiced,
          data: { catalog_amounts: @service_catalogs.index_by { |catalog| catalog.id.to_s }.transform_values(&:amount).to_json },
          onchange: "window.desyconSyncServiceAmountFromCatalog && window.desyconSyncServiceAmountFromCatalog(this)",
              class: "js-service-catalog-select w-full px-3 py-2 text-sm rounded-lg border border-gray-300 focus:ring-2 focus:ring-purple-500 focus:border-purple-500 transition-all duration-200 #{is_invoiced ? 'bg-gray-100 text-gray-500 cursor-not-allowed' : ''}" %>
      <% end %>
    </div>

    <div>
      <%= f.label :amount, "Monto *", class: "block text-xs font-semibold text-gray-600 mb-1 uppercase tracking-wider" %>
      <%= f.number_field :amount, step: "0.01", min: 0.01, disabled: is_invoiced, class: "js-service-amount-input w-full px-3 py-2 text-sm rounded-lg border border-gray-300 focus:ring-2 focus:ring-purple-500 focus:border-purple-500 transition-all duration-200 #{is_invoiced ? 'bg-gray-100 text-gray-500 cursor-not-allowed' : ''}" %>
    </div>

    <div>
      <%= f.label :billed_to_entity_id, "Facturar a", class: "block text-xs font-semibold text-gray-600 mb-1 uppercase tracking-wider" %>
      <% if use_autocomplete %>
        <div
          data-controller="catalog-autocomplete"
          data-catalog-autocomplete-url-value="<%= bill_to_clients_search_container_path(local_assigns[:container]) %>"
          data-catalog-autocomplete-min-chars-value="2"
          data-catalog-autocomplete-debounce-value="300"
          class="relative"
        >
          <%= f.hidden_field :billed_to_entity_id,
                class: "js-billed-to-entity-input",
                data: { catalog_autocomplete_target: "hiddenInput" } %>

          <%= text_field_tag "#{f.object_name}_billed_to_search",
                default_bill_to_entity&.name,
                autocomplete: "off",
                placeholder: "Escribe para buscar un cliente",
                class: "w-full px-3 py-2 text-sm rounded-lg border border-gray-300 focus:ring-2 focus:ring-purple-500 focus:border-purple-500 transition-all duration-200",
                data: {
                  catalog_autocomplete_target: "input",
                  action: "input->catalog-autocomplete#onInput keydown->catalog-autocomplete#onKeydown focus->catalog-autocomplete#onFocus blur->catalog-autocomplete#onBlur"
                } %>

          <div data-catalog-autocomplete-target="status" class="mt-1 text-xs text-gray-500"></div>
          <div data-catalog-autocomplete-target="results" class="absolute z-30 mt-2 hidden w-full rounded-lg border border-gray-200 bg-white shadow-lg max-h-72 overflow-auto"></div>
        </div>
      <% else %>
        <%= f.collection_select :billed_to_entity_id, @clients, :id, :name, { include_blank: "Selecciona cliente" }, disabled: is_invoiced, class: "js-billed-to-entity-select w-full px-3 py-2 text-sm rounded-lg border border-gray-300 focus:ring-2 focus:ring-purple-500 focus:border-purple-500 transition-all duration-200 #{is_invoiced ? 'bg-gray-100 text-gray-500 cursor-not-allowed' : ''}" %>
      <% end %>
    </div>

    <div>
      <%= f.label :fecha_programada, "Fecha Programada", class: "block text-xs font-semibold text-gray-600 mb-1 uppercase tracking-wider" %>
      <%= f.date_field :fecha_programada, disabled: is_invoiced, class: "w-full px-3 py-2 text-sm rounded-lg border border-gray-300 focus:ring-2 focus:ring-purple-500 focus:border-purple-500 transition-all duration-200 #{is_invoiced ? 'bg-gray-100 text-gray-500 cursor-not-allowed' : ''}" %>
    </div>

    <div>
      <%= f.label :factura, "Factura", class: "block text-xs font-semibold text-gray-600 mb-1 uppercase tracking-wider" %>
      <%= f.text_field :factura, placeholder: "FAC-001", disabled: is_invoiced, class: "w-full px-3 py-2 text-sm rounded-lg border border-gray-300 focus:ring-2 focus:ring-purple-500 focus:border-purple-500 transition-all duration-200 font-mono #{is_invoiced ? 'bg-gray-100 text-gray-500 cursor-not-allowed' : ''}" %>
    </div>

    <div class="sm:col-span-2 lg:col-span-3">
      <%= f.label :observaciones, "Observaciones", class: "block text-xs font-semibold text-gray-600 mb-1 uppercase tracking-wider" %>
      <%= f.text_area :observaciones, rows: 2, placeholder: "Notas adicionales sobre el servicio...", disabled: is_invoiced, class: "w-full px-3 py-2 text-sm rounded-lg border border-gray-300 focus:ring-2 focus:ring-purple-500 focus:border-purple-500 transition-all duration-200 resize-none #{is_invoiced ? 'bg-gray-100 text-gray-500 cursor-not-allowed' : ''}" %>
    </div>
  </div>
</div>
