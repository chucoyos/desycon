<section class="mb-5 rounded-2xl border border-amber-300 bg-gradient-to-r from-amber-50 to-orange-50 shadow-sm" aria-live="polite">
  <div class="px-4 py-4 sm:px-5 sm:py-4">
    <div class="flex items-start gap-3">
      <div class="mt-0.5 h-10 w-10 rounded-full bg-amber-100 text-amber-700 flex items-center justify-center shrink-0">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v4m0 4h.01M5.07 19h13.86c1.54 0 2.5-1.67 1.73-3L13.73 4c-.77-1.33-2.69-1.33-3.46 0L3.34 16c-.77 1.33.19 3 1.73 3z" />
        </svg>
      </div>

      <div class="flex-1">
        <h2 class="text-sm sm:text-base font-semibold text-amber-900">Acceso restringido temporalmente</h2>
        <p class="mt-1 text-sm text-amber-800">
          Tu agencia tiene acceso limitado por facturas vencidas con saldo pendiente. Para recuperar el acceso completo, adjunta comprobantes de pago.
        </p>

        <% if restricted_access_notice_total_count.positive? %>
          <p class="mt-3 text-xs font-semibold uppercase tracking-[0.08em] text-amber-700">
            Facturas vencidas detectadas: <%= restricted_access_notice_total_count %>
          </p>

          <div class="mt-2 flex flex-wrap gap-2">
            <% restricted_access_notice_invoices.each do |invoice_data| %>
              <%= link_to invoice_path(invoice_data[:id]), class: "inline-flex items-center rounded-full border border-amber-300 bg-white px-3 py-1 text-xs font-medium text-amber-800 hover:bg-amber-100 transition-colors" do %>
                <%= invoice_data[:label] %>
              <% end %>
            <% end %>
            <% if restricted_access_notice_total_count > restricted_access_notice_invoices.size %>
              <%= link_to invoices_path, class: "inline-flex items-center rounded-full border border-amber-300 bg-white px-3 py-1 text-xs font-medium text-amber-800 hover:bg-amber-100 transition-colors" do %>
                Ver todas
              <% end %>
            <% end %>
          </div>
        <% end %>

        <div class="mt-4 flex flex-wrap items-center gap-2">
          <%= link_to new_customs_agents_payment_evidence_path, class: "inline-flex items-center justify-center h-10 px-4 rounded-full bg-amber-600 text-white text-sm font-semibold hover:bg-amber-700 focus:outline-none focus:ring-2 focus:ring-amber-500" do %>
            Adjuntar comprobante
          <% end %>
          <%= link_to invoices_path, class: "inline-flex items-center justify-center h-10 px-4 rounded-full bg-white border border-amber-300 text-amber-800 text-sm font-semibold hover:bg-amber-100" do %>
            Ver facturas
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>
