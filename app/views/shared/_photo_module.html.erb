<%
  frame_id = dom_id(attachable, "photo_module_#{section}")
  total_photos = attachable.photos.for_section(section).count
  frame_src = if attachable.is_a?(Container)
    photos_section_frame_container_path(attachable, section: section, title: title, subtitle: subtitle)
  else
    photos_section_frame_bl_house_line_path(attachable, section: section, title: title, subtitle: subtitle)
  end
%>

<section class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
  <details
    class="group"
    data-controller="deferred-frame-loader"
    data-action="toggle->deferred-frame-loader#load"
    data-deferred-frame-loader-src-value="<%= frame_src %>">
    <summary class="list-none cursor-pointer touch-manipulation px-4 py-3.5 sm:px-5 sm:py-4 bg-gray-50/70">
      <div class="flex items-start justify-between gap-3">
        <div class="min-w-0">
          <h3 class="text-base font-semibold text-gray-900 tracking-tight"><%= title %></h3>
          <p class="mt-1 text-xs text-gray-600"><%= subtitle %></p>
          <p class="mt-1 text-[11px] text-gray-500 sm:hidden">Toca para ver u ocultar</p>
        </div>
        <div class="flex items-center gap-2 flex-shrink-0">
          <span class="inline-flex items-center rounded-full bg-blue-50 px-3 py-1 text-xs font-medium text-blue-700 ring-1 ring-blue-100 whitespace-nowrap">
            <%= total_photos %> foto(s)
          </span>
          <svg class="w-4 h-4 sm:w-5 sm:h-5 text-gray-500 transition-transform duration-200 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </div>
      </div>
    </summary>

    <turbo-frame id="<%= frame_id %>" data-deferred-frame-loader-target="frame">
      <div class="px-4 py-4 sm:px-5 sm:py-5 border-t border-gray-100 bg-white">
        <p class="text-sm text-gray-500">Despliega esta sección para cargar las fotografías.</p>
      </div>
    </turbo-frame>
  </details>
</section>