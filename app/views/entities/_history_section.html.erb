<details class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden mt-6 group">
  <summary class="px-4 sm:px-6 py-4 bg-gradient-to-r from-indigo-50 to-indigo-100 border-b border-indigo-200 cursor-pointer list-none">
    <div class="flex items-center justify-between gap-3">
      <div class="flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-indigo-600">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6l4 2m6-2a10 10 0 11-20 0 10 10 0 0120 0z" />
        </svg>
        <h2 class="text-base sm:text-lg font-semibold text-gray-900">Historial de cambios</h2>
      </div>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-indigo-700 transition-transform duration-200 group-open:rotate-180">
        <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
      </svg>
    </div>
  </summary>

  <div class="px-4 sm:px-6 py-4">
    <% events = Array(entity_events) %>
    <% if events.any? %>
      <div class="space-y-3">
        <% events.each do |event| %>
          <div class="pb-3 border-b border-gray-100 last:border-0">
            <p class="text-sm font-semibold text-gray-900"><%= event.event_type.humanize %></p>
            <p class="text-xs text-gray-500 mt-0.5"><%= l(event.created_at, format: :short) %></p>
            <p class="text-xs text-gray-500 mt-1">Actor: <span class="font-medium text-gray-700"><%= event.user&.email || "Sistema" %></span></p>

            <% if event.changed_fields_json.present? %>
              <div class="mt-2 space-y-1">
                <% event.changed_fields_json.each do |field_path, values| %>
                  <% entity_event_change_rows(field_path, values).each do |row| %>
                    <p class="text-xs text-gray-600">
                      <span class="font-semibold"><%= row[:label] %></span>:
                      <span class="text-rose-700"><%= entity_event_value_for_display(row[:before]) %></span>
                      ->
                      <span class="text-emerald-700"><%= entity_event_value_for_display(row[:after]) %></span>
                    </p>
                  <% end %>
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-sm text-gray-500">Sin historial de cambios.</p>
    <% end %>
  </div>
</details>
