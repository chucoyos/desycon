<div class="email-recipient-row grid grid-cols-1 md:grid-cols-12 gap-3 p-3 border border-slate-200 rounded-lg bg-slate-50">
  <%= recipient_fields.hidden_field :id if recipient_fields.object.persisted? %>
  <%= recipient_fields.hidden_field :_destroy, value: "0", class: "email-recipient-destroy-flag" %>

  <div class="md:col-span-5">
    <%= recipient_fields.label :email, "Correo", class: "block text-xs font-semibold text-slate-700 mb-1" %>
    <%= recipient_fields.email_field :email,
      class: "block w-full px-3 py-2 border border-slate-300 rounded-md focus:border-teal-500 focus:ring-1 focus:ring-teal-500 text-sm",
      placeholder: "ejemplo@empresa.com" %>
  </div>

  <div class="md:col-span-2">
    <%= recipient_fields.label :position, "Orden", class: "block text-xs font-semibold text-slate-700 mb-1" %>
    <%= recipient_fields.number_field :position,
      min: 0,
      class: "block w-full px-3 py-2 border border-slate-300 rounded-md focus:border-teal-500 focus:ring-1 focus:ring-teal-500 text-sm" %>
  </div>

  <div class="md:col-span-2 flex items-end">
    <label class="inline-flex items-center gap-2 text-sm text-slate-700">
      <%= recipient_fields.check_box :primary_recipient, class: "email-recipient-primary h-4 w-4 rounded border-slate-300 text-teal-600 focus:ring-teal-500" %>
      Principal
    </label>
  </div>

  <div class="md:col-span-2 flex items-end">
    <label class="inline-flex items-center gap-2 text-sm text-slate-700">
      <%= recipient_fields.check_box :active, class: "h-4 w-4 rounded border-slate-300 text-teal-600 focus:ring-teal-500" %>
      Activo
    </label>
  </div>

  <div class="md:col-span-1 flex items-end justify-end">
    <button type="button" class="remove-email-recipient-btn inline-flex items-center justify-center w-9 h-9 rounded-md border border-rose-200 text-rose-600 hover:bg-rose-50" aria-label="Eliminar correo">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>
</div>
