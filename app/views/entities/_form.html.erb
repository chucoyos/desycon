<% show_actions = local_assigns.fetch(:show_actions, true) %>

<%= form_with(model: entity, class: "space-y-6", id: "entity_form") do |form| %>
  <%= render "shared/error_messages", object: entity %>

  <!-- Basic Information -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <div class="px-4 sm:px-6 py-4 bg-gradient-to-r from-gray-50 to-gray-100 border-b border-gray-200">
      <h3 class="text-base sm:text-lg font-semibold text-gray-900">Información Básica</h3>
    </div>
    <div class="px-4 sm:px-6 py-4 space-y-4">
      <!-- Name -->
      <div>
        <%= form.label :name, "Nombre", class: "block text-sm font-semibold text-gray-700 mb-2" %>
        <div class="relative">
          <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
            <svg class="h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
            </svg>
          </div>
          <%= form.text_field :name, 
              class: "block w-full pl-10 pr-3 py-3 border-2 #{entity.errors[:name].any? ? 'border-red-300 focus:border-red-500 focus:ring-red-500' : 'border-gray-200 focus:border-teal-500 focus:ring-teal-500'} rounded-lg focus:ring-2 transition-all duration-200 text-gray-900",
              placeholder: "Ej. Comercializadora del Norte",
              required: true %>
        </div>
        <% if entity.errors[:name].any? %>
          <p class="mt-2 text-sm text-red-600 flex items-center gap-1">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
            </svg>
            <%= entity.errors[:name].first %>
          </p>
        <% end %>
      </div>

      <!-- Roles -->
      <div>
        <%= form.label :role_kind, "Rol", class: "block text-sm font-semibold text-gray-700 mb-2" %>
        <% role_options = if current_user.customs_broker?
            [["Cliente", "client"]]
          else
            [
              ["Consolidador", "consolidator"],
              ["Agencia Aduanal", "customs_agent"],
              ["Agente Aduanal", "customs_broker"],
              ["Forwarder", "forwarder"],
              ["Cliente", "client"]
            ]
          end %>
        <%= form.select :role_kind,
            options_for_select(role_options, current_user.customs_broker? ? "client" : entity.role_kind),
            { include_blank: current_user.customs_broker? ? false : "Seleccionar rol" },
            class: "block w-full px-3 py-3 border-2 border-gray-200 focus:border-teal-500 focus:ring-teal-500 rounded-lg focus:ring-2 transition-all duration-200 text-gray-900",
            disabled: current_user.customs_broker? %>
        <% if current_user.customs_broker? %>
          <p class="mt-1 text-xs text-gray-500">Las agencias aduanales solo pueden crear entidades de tipo cliente.</p>
        <% end %>
      </div>
    </div>
  </div>

  <% if current_user.admin_or_executive? %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
      <div class="px-4 sm:px-6 py-4 bg-gradient-to-r from-rose-50 to-orange-50 border-b border-rose-100">
        <h3 class="text-base sm:text-lg font-semibold text-gray-900">Regla de restricción por mora</h3>
        <p class="text-sm text-gray-600">Controla si aplica la regla automática de 72 horas hábiles para esta agencia aduanal.</p>
      </div>
      <div class="px-4 sm:px-6 py-4">
        <label class="flex items-start gap-3 p-4 rounded-lg border border-rose-200 bg-rose-50">
          <%= form.check_box :enforce_overdue_payment_rule, class: "mt-1 h-5 w-5 text-rose-700 border-rose-300 rounded focus:ring-rose-500", disabled: !entity.role_customs_agent? %>
          <div>
            <span class="block text-sm font-semibold text-gray-900">Aplicar regla automática de mora (72h hábiles)</span>
            <span class="block text-xs text-gray-600">Si está activa, la agencia puede quedar restringida automáticamente por facturas vencidas con saldo pendiente.</span>
            <% unless entity.role_customs_agent? %>
              <span class="block text-xs text-rose-700 mt-1">Solo aplica para entidades con rol Agencia Aduanal.</span>
            <% end %>
          </div>
        </label>
      </div>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
      <div class="px-4 sm:px-6 py-4 bg-gradient-to-r from-indigo-50 to-indigo-100 border-b border-indigo-200">
        <h3 class="text-base sm:text-lg font-semibold text-gray-900">Datos de Agente Aduanal</h3>
        <p class="text-sm text-gray-600">Solo aplica cuando el rol de agente aduanal está activo.</p>
      </div>
      <div class="px-4 sm:px-6 py-4">
        <%= form.label :patent_number, "Número de Patente", class: "block text-sm font-semibold text-gray-700 mb-2" %>
        <%= form.text_field :patent_number,
          class: "block w-full px-3 py-3 border-2 #{entity.errors[:patent_number].any? ? 'border-red-300 focus:border-red-500 focus:ring-red-500' : 'border-gray-200 focus:border-indigo-500 focus:ring-indigo-500'} rounded-lg focus:ring-2 transition-all duration-200 text-gray-900",
          placeholder: "Ej. 1234",
          required: entity.role_kind == "customs_broker" %>
        <% if entity.errors[:patent_number].any? %>
          <p class="mt-2 text-sm text-red-600"><%= entity.errors[:patent_number].first %></p>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Customs Agent Assignment (Only for admins/executives) -->
  <% if current_user.admin_or_executive? %>
  <div id="customs-agent-assignment-section" class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden" style="<%= entity.role_kind == 'client' ? '' : 'display: none;' %>">
    <div class="px-4 sm:px-6 py-4 bg-gradient-to-r from-gray-50 to-gray-100 border-b border-gray-200">
      <h3 class="text-base sm:text-lg font-semibold text-gray-900">Asignación de Agencia Aduanal</h3>
    </div>
    <div class="px-4 sm:px-6 py-4">
      <div>
        <%= form.label :customs_agent_id, "Agencia Aduanal", class: "block text-sm font-semibold text-gray-700 mb-2" %>
        <%= form.collection_select :customs_agent_id, 
          Entity.customs_agents.order(:name), 
            :id, 
            :name, 
            { include_blank: "Sin asignar" }, 
            class: "block w-full px-3 py-3 border-2 border-gray-200 focus:border-teal-500 focus:ring-teal-500 rounded-lg focus:ring-2 transition-all duration-200 text-gray-900" %>
        <p class="mt-1 text-sm text-gray-500">Asigna el cliente a una agencia aduanal (opcional)</p>
      </div>
    </div>
  </div>

  <% if entity.role_kind == "consolidator" %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
      <div class="px-4 sm:px-6 py-4 bg-gradient-to-r from-amber-50 to-amber-100 border-b border-amber-200 flex items-center justify-between">
        <div>
          <h3 class="text-base sm:text-lg font-semibold text-gray-900">Documentos requeridos para revalidación</h3>
          <p class="text-sm text-gray-600">Define qué documentos debe adjuntar la agencia aduanal según el consolidador del contenedor.</p>
        </div>
        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-amber-200 text-amber-900 border border-amber-300">Solo aplica a consolidadores</span>
      </div>

      <div class="px-4 sm:px-6 py-4 grid grid-cols-1 md:grid-cols-2 gap-4">
        <label class="flex items-start gap-3 p-4 rounded-lg border border-amber-200 bg-amber-50">
          <%= form.check_box :requires_bl_endosado_documento, class: "mt-1 h-5 w-5 text-amber-700 border-amber-300 rounded focus:ring-amber-500" %>
          <div>
            <span class="block text-sm font-semibold text-gray-900">BL endosado</span>
            <span class="block text-xs text-gray-600">Requerir archivo de BL endosado.</span>
          </div>
        </label>

        <label class="flex items-start gap-3 p-4 rounded-lg border border-amber-200 bg-amber-50">
          <%= form.check_box :requires_liberacion_documento, class: "mt-1 h-5 w-5 text-amber-700 border-amber-300 rounded focus:ring-amber-500" %>
          <div>
            <span class="block text-sm font-semibold text-gray-900">Liberación</span>
            <span class="block text-xs text-gray-600">Requerir documento de liberación.</span>
          </div>
        </label>

        <label class="flex items-start gap-3 p-4 rounded-lg border border-amber-200 bg-amber-50">
          <%= form.check_box :requires_encomienda_documento, class: "mt-1 h-5 w-5 text-amber-700 border-amber-300 rounded focus:ring-amber-500" %>
          <div>
            <span class="block text-sm font-semibold text-gray-900">Encomienda</span>
            <span class="block text-xs text-gray-600">Requerir documento de encomienda.</span>
          </div>
        </label>

        <label class="flex items-start gap-3 p-4 rounded-lg border border-amber-200 bg-amber-50">
          <%= form.check_box :requires_pago_documento, class: "mt-1 h-5 w-5 text-amber-700 border-amber-300 rounded focus:ring-amber-500" %>
          <div>
            <span class="block text-sm font-semibold text-gray-900">Pago</span>
            <span class="block text-xs text-gray-600">Requerir comprobante de pago.</span>
          </div>
        </label>
      </div>
    </div>
  <% end %>
  <% end %>

  <div id="entity-email-recipients-section" class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden" style="<%= (entity.role_customs_agent? || entity.role_consolidator?) ? '' : 'display: none;' %>">
    <div class="px-4 sm:px-6 py-4 bg-gradient-to-r from-sky-50 to-cyan-50 border-b border-sky-100">
      <div class="flex items-center justify-between gap-4">
        <div>
          <h3 class="text-base sm:text-lg font-semibold text-gray-900">Correos de envío de CFDI</h3>
          <p class="text-sm text-gray-600">Configura múltiples correos para envío automático. Aplica solo a Agencia Aduanal y Consolidador.</p>
        </div>
        <button type="button" id="add-email-recipient-btn" class="inline-flex items-center gap-2 px-3 py-2 rounded-md border border-sky-200 text-sky-700 hover:bg-sky-100 transition-colors text-sm font-semibold">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
          </svg>
          Agregar correo
        </button>
      </div>
    </div>

    <div class="px-4 sm:px-6 py-4 space-y-3">
      <% if entity.errors[:entity_email_recipients].any? %>
        <div class="rounded-md border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-700">
          <%= entity.errors[:entity_email_recipients].join(", ") %>
        </div>
      <% end %>

      <div id="email-recipients-container" class="space-y-3">
        <%= form.fields_for :entity_email_recipients do |recipient_fields| %>
          <%= render "entities/email_recipient_fields", recipient_fields: recipient_fields %>
        <% end %>
      </div>

      <template id="email-recipient-template">
        <%= form.fields_for :entity_email_recipients, EntityEmailRecipient.new(active: true), child_index: "NEW_EMAIL_RECIPIENT" do |recipient_fields| %>
          <%= render "entities/email_recipient_fields", recipient_fields: recipient_fields %>
        <% end %>
      </template>
    </div>
  </div>

  <!-- Fiscal Profile -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <div class="px-4 sm:px-6 py-4 bg-gradient-to-r from-gray-50 to-gray-100 border-b border-gray-200">
      <div class="flex items-center justify-between">
        <h3 class="text-base sm:text-lg font-semibold text-gray-900">Perfil Fiscal</h3>
        <button type="button"
                id="toggle-fiscal-profile-btn"
                class="inline-flex items-center px-3 py-1.5 border border-gray-300 rounded-md text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-teal-500 transition-colors duration-150">
          <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"/>
          </svg>
          Ocultar
        </button>
      </div>
      <p class="text-xs text-gray-500 mt-1">Si el rol es <span class="font-semibold">Cliente</span>, todos los campos del perfil fiscal son obligatorios.</p>
    </div>

    <!-- Fiscal Profile Form (Initially Visible) -->
    <div id="fiscal-profile-section" class="px-4 sm:px-6 py-4">
      <% if entity.fiscal_profile %>
        <%= form.fields_for :fiscal_profile do |fp| %>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <%= fp.label :rfc, "RFC", class: "block text-sm font-semibold text-gray-700 mb-2" %>
              <%= fp.text_field :rfc, 
                  class: "block w-full px-3 py-3 border-2 #{entity.fiscal_profile&.errors[:rfc].any? ? 'border-red-300 focus:border-red-500 focus:ring-red-500' : 'border-gray-200 focus:border-teal-500 focus:ring-teal-500'} rounded-lg focus:ring-2 transition-all duration-200 text-gray-900",
                  placeholder: "Ej. XAXX010101000",
                  required: (current_user.customs_broker? || entity.role_kind == "client"),
                  data: { client_required: "fiscal-field" },
                  maxlength: 13 %>
              <% if entity.fiscal_profile&.errors[:rfc].any? %>
                <p class="mt-2 text-sm text-red-600 flex items-center gap-1">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
                  </svg>
                  <%= entity.fiscal_profile.errors[:rfc].first %>
                </p>
              <% end %>
            </div>

            <div>
              <%= fp.label :razon_social, "Razón Social", class: "block text-sm font-semibold text-gray-700 mb-2" %>
              <%= fp.text_field :razon_social, 
                  class: "block w-full px-3 py-3 border-2 border-gray-200 focus:border-teal-500 focus:ring-teal-500 rounded-lg focus:ring-2 transition-all duration-200 text-gray-900",
                  placeholder: "Ej. Comercializadora del Norte SA de CV",
                  required: (current_user.customs_broker? || entity.role_kind == "client"),
                  data: { client_required: "fiscal-field" } %>
            </div>

            <div>
              <%= fp.label :regimen, "Régimen Fiscal", class: "block text-sm font-semibold text-gray-700 mb-2" %>
              <%= fp.select :regimen,
                  FiscalProfile::REGIMENES.map { |k, v| ["#{k} - #{v}", k] },
                  { include_blank: "Seleccionar régimen" },
                  required: (current_user.customs_broker? || entity.role_kind == "client"),
                  data: { client_required: "fiscal-field" },
                  class: "block w-full px-3 py-3 border-2 border-gray-200 focus:border-teal-500 focus:ring-teal-500 rounded-lg focus:ring-2 transition-all duration-200 text-gray-900" %>
            </div>

            <div>
              <%= fp.label :uso_cfdi, "Uso CFDI", class: "block text-sm font-semibold text-gray-700 mb-2" %>
              <%= fp.select :uso_cfdi,
                  FiscalProfile::USOS_CFDI.map { |k, v| ["#{k} - #{v}", k] },
                  { include_blank: "Seleccionar uso CFDI" },
                  required: (current_user.customs_broker? || entity.role_kind == "client"),
                  data: { client_required: "fiscal-field" },
                  class: "block w-full px-3 py-3 border-2 border-gray-200 focus:border-teal-500 focus:ring-teal-500 rounded-lg focus:ring-2 transition-all duration-200 text-gray-900" %>
            </div>

            <div>
              <%= fp.label :metodo_pago, "Método de Pago", class: "block text-sm font-semibold text-gray-700 mb-2" %>
              <%= fp.select :metodo_pago,
                  FiscalProfile::METODOS_PAGO.map { |k, v| ["#{k} - #{v}", k] },
                  { include_blank: "Seleccionar método de pago" },
                  required: (current_user.customs_broker? || entity.role_kind == "client"),
                  data: { payment_rule: "metodo-pago", client_required: "fiscal-field" },
                  class: "block w-full px-3 py-3 border-2 border-gray-200 focus:border-teal-500 focus:ring-teal-500 rounded-lg focus:ring-2 transition-all duration-200 text-gray-900" %>
            </div>

            <div>
              <%= fp.label :forma_pago, "Forma de Pago", class: "block text-sm font-semibold text-gray-700 mb-2" %>
              <%= fp.select :forma_pago,
                  FiscalProfile::FORMAS_PAGO.map { |k, v| ["#{k} - #{v}", k] },
                  { include_blank: "Seleccionar forma de pago" },
                  required: (current_user.customs_broker? || entity.role_kind == "client"),
                  data: { payment_rule: "forma-pago", client_required: "fiscal-field" },
                  class: "block w-full px-3 py-3 border-2 border-gray-200 focus:border-teal-500 focus:ring-teal-500 rounded-lg focus:ring-2 transition-all duration-200 text-gray-900" %>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="text-center py-8">
          <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
          <h3 class="mt-2 text-sm font-medium text-gray-900">No hay perfil fiscal</h3>
          <p class="mt-1 text-sm text-gray-500">El perfil fiscal se creará automáticamente cuando guardes la entidad.</p>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Addresses -->
  <% unless entity.persisted? %>
  <!-- Address fields for new entities (nested attributes) -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <div class="px-4 sm:px-6 py-4 bg-gradient-to-r from-gray-50 to-gray-100 border-b border-gray-200">
      <h3 class="text-base sm:text-lg font-semibold text-gray-900">Dirección Principal</h3>
      <p class="text-xs text-gray-500 mt-1">Campos obligatorios: <span class="font-semibold">CP y Email</span>.</p>
    </div>
    <div class="px-4 sm:px-6 py-4">
      <%= form.fields_for :addresses do |address_form| %>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          <div>
            <%= address_form.label :tipo, "Tipo", class: "block text-sm font-semibold text-gray-700 mb-2" %>
            <%= address_form.select :tipo,
                Address::TIPOS.map { |k, v| [v, k] },
              { include_blank: "Seleccionar tipo", selected: address_form.object.tipo.presence || "matriz" },
                class: "block w-full px-3 py-3 border-2 border-gray-200 focus:border-teal-500 focus:ring-teal-500 rounded-lg focus:ring-2 transition-all duration-200 text-gray-900" %>
          </div>

          <div>
            <%= address_form.label :calle, "Calle", class: "block text-sm font-semibold text-gray-700 mb-2" %>
            <%= address_form.text_field :calle,
                class: "block w-full px-3 py-3 border-2 border-gray-200 focus:border-teal-500 focus:ring-teal-500 rounded-lg focus:ring-2 transition-all duration-200 text-gray-900",
              placeholder: "Ej. Av. Insurgentes Sur" %>
          </div>

          <div>
            <%= address_form.label :numero_exterior, "Número Exterior", class: "block text-sm font-semibold text-gray-700 mb-2" %>
            <%= address_form.text_field :numero_exterior,
                class: "block w-full px-3 py-3 border-2 border-gray-200 focus:border-teal-500 focus:ring-teal-500 rounded-lg focus:ring-2 transition-all duration-200 text-gray-900",
              placeholder: "Ej. 123" %>
          </div>

          <div>
            <%= address_form.label :numero_interior, "Número Interior", class: "block text-sm font-semibold text-gray-700 mb-2" %>
            <%= address_form.text_field :numero_interior,
                class: "block w-full px-3 py-3 border-2 border-gray-200 focus:border-teal-500 focus:ring-teal-500 rounded-lg focus:ring-2 transition-all duration-200 text-gray-900",
              placeholder: "Ej. A (opcional)" %>
          </div>

          <div>
            <%= address_form.label :colonia, "Colonia", class: "block text-sm font-semibold text-gray-700 mb-2" %>
            <%= address_form.text_field :colonia,
                class: "block w-full px-3 py-3 border-2 border-gray-200 focus:border-teal-500 focus:ring-teal-500 rounded-lg focus:ring-2 transition-all duration-200 text-gray-900",
              placeholder: "Ej. Del Valle" %>
          </div>

          <div>
            <%= address_form.label :codigo_postal, "Código Postal (obligatorio)", class: "block text-sm font-semibold text-gray-700 mb-2" %>
            <%= address_form.text_field :codigo_postal,
                class: "block w-full px-3 py-3 border-2 border-gray-200 focus:border-teal-500 focus:ring-teal-500 rounded-lg focus:ring-2 transition-all duration-200 text-gray-900",
              placeholder: "Ej. 12345",
              required: true %>
          </div>

          <div>
            <%= address_form.label :municipio, "Municipio", class: "block text-sm font-semibold text-gray-700 mb-2" %>
            <%= address_form.text_field :municipio,
                class: "block w-full px-3 py-3 border-2 border-gray-200 focus:border-teal-500 focus:ring-teal-500 rounded-lg focus:ring-2 transition-all duration-200 text-gray-900",
              placeholder: "Ej. Monterrey" %>
          </div>

          <div>
            <%= address_form.label :estado, "Estado", class: "block text-sm font-semibold text-gray-700 mb-2" %>
            <%= address_form.text_field :estado,
                class: "block w-full px-3 py-3 border-2 border-gray-200 focus:border-teal-500 focus:ring-teal-500 rounded-lg focus:ring-2 transition-all duration-200 text-gray-900",
              placeholder: "Ej. Nuevo Leon" %>
          </div>

          <div>
            <%= address_form.label :pais, "País", class: "block text-sm font-semibold text-gray-700 mb-2" %>
            <%= address_form.select :pais,
                Address.paises_con_banderas.map { |display, code| [display, code] },
              { include_blank: "Seleccionar país" },
                class: "block w-full px-3 py-3 border-2 border-gray-200 focus:border-teal-500 focus:ring-teal-500 rounded-lg focus:ring-2 transition-all duration-200 text-gray-900" %>
          </div>

          <div class="sm:col-span-2 lg:col-span-3">
            <%= address_form.label :email, "Email (obligatorio)", class: "block text-sm font-semibold text-gray-700 mb-2" %>
            <%= address_form.email_field :email,
                class: "block w-full px-3 py-3 border-2 border-gray-200 focus:border-teal-500 focus:ring-teal-500 rounded-lg focus:ring-2 transition-all duration-200 text-gray-900",
              placeholder: "Ej. facturacion@empresa.com",
              required: true %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
  <% end %>

  <script>
    function initializeFormJavaScript() {
      const formElement = document.getElementById('entity_form');
      if (!formElement || formElement.dataset.jsInitialized === 'true') {
        return;
      }
      formElement.dataset.jsInitialized = 'true';

      // Toggle fiscal profile section
      const toggleFiscalBtn = document.getElementById('toggle-fiscal-profile-btn');
      const fiscalProfileSection = document.getElementById('fiscal-profile-section');

      if (toggleFiscalBtn && fiscalProfileSection) {
        // Clone the button to remove any existing event listeners
        const newToggleFiscalBtn = toggleFiscalBtn.cloneNode(true);
        toggleFiscalBtn.parentNode.replaceChild(newToggleFiscalBtn, toggleFiscalBtn);

        newToggleFiscalBtn.addEventListener('click', function() {
          if (fiscalProfileSection.classList.contains('hidden')) {
            fiscalProfileSection.classList.remove('hidden');
            this.innerHTML = `
              <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"/>
              </svg>
              Ocultar
            `;
            this.classList.remove('text-gray-700', 'border-gray-300', 'hover:bg-gray-50');
            this.classList.add('text-red-700', 'border-red-300', 'hover:bg-red-50');
          } else {
            fiscalProfileSection.classList.add('hidden');
            this.innerHTML = `
              <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
              Mostrar
            `;
            this.classList.remove('text-red-700', 'border-red-300', 'hover:bg-red-50');
            this.classList.add('text-gray-700', 'border-gray-300', 'hover:bg-gray-50');
          }
        });
      }

      // Toggle customs agent assignment section based on selected role (new and edit)
      const roleKindSelect = document.getElementById('entity_role_kind');
      const customsAgentAssignmentSection = document.getElementById('customs-agent-assignment-section');
      const toggleFiscalRequiredFields = (requiredForClient) => {
        document.querySelectorAll('[data-client-required="fiscal-field"]').forEach((field) => {
          field.required = requiredForClient;
        });
      };

      if (roleKindSelect && customsAgentAssignmentSection) {
        const toggleCustomsAgentAssignmentSection = () => {
          if (roleKindSelect.value === 'client') {
            customsAgentAssignmentSection.style.display = 'block';
          } else {
            customsAgentAssignmentSection.style.display = 'none';
          }
        };

        roleKindSelect.addEventListener('change', toggleCustomsAgentAssignmentSection);
        roleKindSelect.addEventListener('change', () => toggleFiscalRequiredFields(roleKindSelect.value === 'client'));
        toggleCustomsAgentAssignmentSection();
        toggleFiscalRequiredFields(roleKindSelect.value === 'client');
      } else if (roleKindSelect) {
        roleKindSelect.addEventListener('change', () => toggleFiscalRequiredFields(roleKindSelect.value === 'client'));
        toggleFiscalRequiredFields(roleKindSelect.value === 'client');
      } else {
        toggleFiscalRequiredFields(<%= current_user.customs_broker? ? 'true' : 'false' %>);
      }

      const recipientsSection = document.getElementById('entity-email-recipients-section');
      const recipientsContainer = document.getElementById('email-recipients-container');
      const addRecipientButton = document.getElementById('add-email-recipient-btn');
      const recipientTemplate = document.getElementById('email-recipient-template');
      const nextRecipientIndex = () => {
        if (!recipientsContainer) return 0;

        const names = Array.from(recipientsContainer.querySelectorAll('input[name*="[entity_email_recipients_attributes]"]'))
          .map((input) => input.name);

        const numericIndexes = names.map((name) => {
          const match = name.match(/\[entity_email_recipients_attributes\]\[(\d+)\]/);
          return match ? parseInt(match[1], 10) : null;
        }).filter((index) => Number.isInteger(index));

        if (numericIndexes.length === 0) return 0;
        return Math.max(...numericIndexes) + 1;
      };

      const roleSupportsRecipients = (role) => ['customs_agent', 'consolidator'].includes(role);
      const toggleRecipientSection = () => {
        if (!recipientsSection || !roleKindSelect) return;
        recipientsSection.style.display = roleSupportsRecipients(roleKindSelect.value) ? 'block' : 'none';
      };

      const ensureSinglePrimary = (currentCheckbox) => {
        if (!currentCheckbox.checked) return;
        recipientsContainer?.querySelectorAll('.email-recipient-primary').forEach((checkbox) => {
          if (checkbox !== currentCheckbox) checkbox.checked = false;
        });
      };

      const addRecipientRow = () => {
        if (!recipientTemplate || !recipientsContainer) return;
        const uniqueIndex = nextRecipientIndex();
        const html = recipientTemplate.innerHTML.replace(/NEW_EMAIL_RECIPIENT/g, uniqueIndex.toString());
        recipientsContainer.insertAdjacentHTML('beforeend', html);
      };

      if (roleKindSelect) {
        roleKindSelect.addEventListener('change', toggleRecipientSection);
        toggleRecipientSection();
      }

      addRecipientButton?.addEventListener('click', addRecipientRow);

      recipientsContainer?.addEventListener('click', (event) => {
        const removeButton = event.target.closest('.remove-email-recipient-btn');
        if (!removeButton) return;

        const row = removeButton.closest('.email-recipient-row');
        if (!row) return;

        const destroyInput = row.querySelector('.email-recipient-destroy-flag');
        const idInput = row.querySelector('input[name*="[id]"]');

        if (destroyInput && idInput && idInput.value) {
          destroyInput.value = '1';
          row.classList.add('hidden');
        } else {
          row.remove();
        }
      });

      recipientsContainer?.addEventListener('change', (event) => {
        if (event.target.classList.contains('email-recipient-primary')) {
          ensureSinglePrimary(event.target);
        }
      });

      // Toggle addresses form (only for persisted entities)
      <% if entity.persisted? %>
      const toggleAddressesBtn = document.getElementById('toggle-addresses-btn');
      const newAddressSection = document.getElementById('new-address-section');

      if (toggleAddressesBtn && newAddressSection) {
        // Clone the button to remove any existing event listeners
        const newToggleAddressesBtn = toggleAddressesBtn.cloneNode(true);
        toggleAddressesBtn.parentNode.replaceChild(newToggleAddressesBtn, toggleAddressesBtn);

        newToggleAddressesBtn.addEventListener('click', function() {
          if (newAddressSection.classList.contains('hidden')) {
            newAddressSection.classList.remove('hidden');
            this.innerHTML = `
              <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
              </svg>
              Cancelar
            `;
            this.classList.remove('text-gray-700', 'border-gray-300', 'hover:bg-gray-50');
            this.classList.add('text-red-700', 'border-red-300', 'hover:bg-red-50');
          } else {
            newAddressSection.classList.add('hidden');
            this.innerHTML = `
              <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
              </svg>
              Agregar Dirección
            `;
            this.classList.remove('text-red-700', 'border-red-300', 'hover:bg-red-50');
            this.classList.add('text-gray-700', 'border-gray-300', 'hover:bg-gray-50');
          }
        });
      }
      <% end %>

      const PPD = 'PPD';
      const FORMA_POR_DEFINIR = '99';
      const toggleFormaPagoOptions = (metodoSelect, formaSelect) => {
        const ppdSelected = metodoSelect.value === PPD;

        Array.from(formaSelect.options).forEach((option) => {
          const keepVisible = option.value === '' || option.value === FORMA_POR_DEFINIR || !ppdSelected;
          option.disabled = !keepVisible;
          option.hidden = !keepVisible;
        });

        if (ppdSelected) {
          formaSelect.value = FORMA_POR_DEFINIR;
        }
      };

      document.querySelectorAll('select[data-payment-rule="metodo-pago"]').forEach((metodoSelect) => {
        const formaSelectName = metodoSelect.name.replace('[metodo_pago]', '[forma_pago]');
        const formaSelect = document.querySelector(`select[name="${formaSelectName}"]`);
        if (!formaSelect) return;

        metodoSelect.addEventListener('change', () => toggleFormaPagoOptions(metodoSelect, formaSelect));
        toggleFormaPagoOptions(metodoSelect, formaSelect);
      });
    }

    // Initialize on page load and after Turbo navigation
    document.addEventListener('DOMContentLoaded', initializeFormJavaScript);
    document.addEventListener('turbo:load', initializeFormJavaScript);
    
    // Also initialize immediately
    initializeFormJavaScript();
  </script>

  <% if show_actions %>
    <!-- Form Actions -->
    <div class="mt-8 flex flex-wrap gap-3 px-5 py-4">
      <%= form.submit entity.persisted? ? 'Actualizar Entidad' : 'Crear Entidad',
          class: "cursor-pointer inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-full bg-gradient-to-r from-teal-600 to-cyan-700 text-white text-sm font-semibold shadow-md shadow-teal-200 hover:from-teal-700 hover:to-cyan-800 transition" %>
      <%= link_to "Cancelar", entities_path,
          class: "cursor-pointer inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-full border border-slate-200 text-slate-700 text-sm font-semibold hover:bg-slate-50 transition" %>
    </div>
  <% end %>
<% end %>