<% fiscal_address = entity.fiscal_address %>
<% sucursales = entity.shipping_addresses %>

<div id="addresses_container">
  <div id="addresses_section" class="mt-6">
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
      <div class="px-4 sm:px-6 py-4 bg-gradient-to-r from-gray-50 to-gray-100 border-b border-gray-200">
        <div class="flex items-center justify-between gap-3">
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-teal-600">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
            </svg>
            <h2 class="text-base sm:text-lg font-semibold text-gray-900">Domicilio fiscal</h2>
          </div>
          <% if fiscal_address.present? %>
            <button type="button" data-action="click->modal#open" data-modal-id="address-modal" data-address-id="<%= fiscal_address.id %>" class="inline-flex items-center justify-center gap-1 px-3 py-1.5 rounded-lg text-sm font-medium text-teal-700 bg-teal-50 hover:bg-teal-100 border border-teal-200 transition-colors" title="Editar domicilio fiscal">
              Editar
            </button>
          <% else %>
            <button type="button" data-action="click->modal#open" data-modal-id="new-address-modal" data-address-tipo="matriz" class="inline-flex items-center justify-center gap-1 px-3 py-1.5 rounded-lg text-sm font-medium text-green-700 bg-green-50 hover:bg-green-100 border border-green-200 transition-colors" title="Agregar domicilio fiscal">
              Agregar
            </button>
          <% end %>
        </div>
      </div>

      <div class="px-4 sm:px-6 py-4">
        <% if fiscal_address.present? %>
          <div class="p-4 bg-gray-50 rounded-lg border border-gray-200">
            <div class="space-y-2">
              <% if fiscal_address.calle.present? %>
                <p class="text-sm text-gray-900"><strong>Calle:</strong> <%= fiscal_address.calle %> <%= fiscal_address.numero_exterior %> <%= "Int. #{fiscal_address.numero_interior}" if fiscal_address.numero_interior.present? %></p>
              <% end %>
              <% if fiscal_address.colonia.present? %>
                <p class="text-sm text-gray-900"><strong>Colonia:</strong> <%= fiscal_address.colonia %></p>
              <% end %>
              <% if fiscal_address.municipio.present? %>
                <p class="text-sm text-gray-900"><strong>Municipio:</strong> <%= fiscal_address.municipio %></p>
              <% end %>
              <% if fiscal_address.estado.present? %>
                <p class="text-sm text-gray-900"><strong>Estado:</strong> <%= fiscal_address.estado %></p>
              <% end %>
              <% if fiscal_address.codigo_postal.present? %>
                <p class="text-sm text-gray-900"><strong>CP:</strong> <%= fiscal_address.codigo_postal %></p>
              <% end %>
              <% if fiscal_address.pais.present? %>
                <p class="text-sm text-gray-900"><strong>País:</strong> <%= fiscal_address.pais %></p>
              <% end %>
              <% if fiscal_address.email.present? %>
                <p class="text-sm text-gray-900"><strong>Email:</strong> <%= fiscal_address.email %></p>
              <% end %>
            </div>
          </div>
        <% else %>
          <p class="text-sm text-gray-500">No hay domicilio fiscal registrado.</p>
        <% end %>
      </div>

      <div class="px-4 sm:px-6 pb-5">
        <details class="rounded-lg border border-slate-200 bg-slate-50/60">
          <summary class="cursor-pointer select-none px-4 py-3 text-sm font-semibold text-slate-700 flex items-center justify-between">
            <span>Sucursales (opcional) - <%= sucursales.size %></span>
          </summary>
          <div class="px-4 pb-4 pt-1 space-y-3">
            <div>
              <button type="button" data-action="click->modal#open" data-modal-id="new-address-modal" data-address-tipo="sucursal" class="inline-flex items-center justify-center gap-1 px-3 py-1.5 rounded-lg text-sm font-medium text-green-700 bg-green-50 hover:bg-green-100 border border-green-200 transition-colors" title="Agregar sucursal">
                Agregar sucursal
              </button>
            </div>

            <% if sucursales.any? %>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <% sucursales.each do |address| %>
                  <div class="p-4 bg-white rounded-lg border border-gray-200">
                    <div class="flex items-start justify-between">
                      <div class="flex-1 space-y-2">
                        <% if address.calle.present? %>
                          <p class="text-sm text-gray-900"><strong>Calle:</strong> <%= address.calle %> <%= address.numero_exterior %> <%= "Int. #{address.numero_interior}" if address.numero_interior.present? %></p>
                        <% end %>
                        <% if address.colonia.present? %>
                          <p class="text-sm text-gray-900"><strong>Colonia:</strong> <%= address.colonia %></p>
                        <% end %>
                        <% if address.municipio.present? %>
                          <p class="text-sm text-gray-900"><strong>Municipio:</strong> <%= address.municipio %></p>
                        <% end %>
                        <% if address.estado.present? %>
                          <p class="text-sm text-gray-900"><strong>Estado:</strong> <%= address.estado %></p>
                        <% end %>
                        <% if address.codigo_postal.present? %>
                          <p class="text-sm text-gray-900"><strong>CP:</strong> <%= address.codigo_postal %></p>
                        <% end %>
                        <% if address.pais.present? %>
                          <p class="text-sm text-gray-900"><strong>País:</strong> <%= address.pais %></p>
                        <% end %>
                      </div>
                      <div class="ml-2 flex items-center gap-1">
                        <button type="button" data-action="click->modal#open" data-modal-id="address-modal" data-address-id="<%= address.id %>" class="p-1 text-gray-400 hover:text-teal-600 transition-colors" title="Editar sucursal">
                          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
                          </svg>
                        </button>
                        <%= button_to entity_address_path(entity, address), method: :delete, class: "p-1 text-red-400 hover:text-red-600 transition-colors", title: "Eliminar sucursal", data: { turbo_confirm: "¿Seguro que deseas eliminar esta sucursal?" } do %>
                          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                          </svg>
                        <% end %>
                      </div>
                    </div>
                  </div>
                <% end %>
              </div>
            <% else %>
              <p class="text-sm text-gray-500">No hay sucursales registradas.</p>
            <% end %>
          </div>
        </details>
      </div>
    </div>
  </div>
</div>