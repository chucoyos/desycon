<%
  if params[:role] == "customs_broker"
    page_title = "Nuevo Agente Aduanal"
    page_description = "Crear un agente aduanal con patente"
  else
    page_title = current_user.customs_broker? ? "Nuevo Cliente" : "Nueva Entidad"
    page_description = current_user.customs_broker? ? "Registrar un nuevo cliente" : "Crear una nueva entidad en el sistema"
  end
%>
<% content_for :title, page_title %>

<div class="w-full px-4 sm:px-6 lg:px-8 py-6 sm:py-8" data-controller="modal">
  <!-- Header -->
  <div class="mb-6 sm:mb-8">
    <div class="flex items-start justify-between gap-4 mb-4 sm:mb-6">
      <div class="flex items-center gap-3 sm:gap-4">
      <div class="flex items-center justify-center w-12 h-12 sm:w-14 sm:h-14 bg-gradient-to-br from-teal-500 to-cyan-600 rounded-2xl shadow-lg">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 sm:w-7 sm:h-7 text-white">
          <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" />
        </svg>
      </div>
      <div>
        <h1 class="text-2xl sm:text-3xl font-bold text-gray-900"><%= page_title %></h1>
        <p class="text-sm sm:text-base text-gray-500 mt-1"><%= page_description %></p>
      </div>
      </div>

      <% if current_user.customs_broker? %>
        <button
          type="button"
          data-action="click->modal#open"
          data-modal-id="new-client-quick-guide-modal"
          class="cursor-pointer inline-flex items-center gap-2 px-3 py-2 rounded-md border border-teal-200 bg-teal-50 text-teal-700 hover:bg-teal-100 text-sm font-semibold"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.852l.041-.02M21 12a9 9 0 11-18 0 9 9 0 0118 0zM12 8.25h.008v.008H12V8.25z" />
          </svg>
          Guía rápida
        </button>
      <% end %>
    </div>
  </div>

  <%= render "form", entity: @entity %>

  <% if current_user.customs_broker? %>
    <div id="new-client-quick-guide-modal" data-modal-target="modal" data-action="click->modal#closeOnBackdrop" class="hidden fixed inset-0 z-50 overflow-y-auto bg-slate-900/50 backdrop-blur-sm px-4 py-6" role="dialog" aria-modal="true" aria-labelledby="new-client-guide-title">
      <div class="mx-auto max-w-3xl">
        <div class="rounded-2xl bg-white shadow-2xl border border-slate-200 overflow-hidden">
          <div class="flex items-start justify-between gap-4 px-5 py-4 border-b border-slate-200 bg-gradient-to-r from-teal-50 to-white">
            <div>
              <h3 id="new-client-guide-title" class="text-lg font-bold text-slate-900 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-teal-600">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M18 7.5v9A2.25 2.25 0 0115.75 18.75h-7.5A2.25 2.25 0 016 16.5v-9A2.25 2.25 0 018.25 5.25h7.5A2.25 2.25 0 0118 7.5z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 9.75h6M9 12.75h6M9 15.75h3" />
                </svg>
                Guía rápida: Nuevo Cliente
              </h3>
              <p class="text-sm text-slate-600 mt-1">Guía simple para que puedas registrar un cliente sin dudas.</p>
            </div>
            <button type="button" data-action="click->modal#close" class="cursor-pointer inline-flex items-center justify-center h-9 w-9 rounded-full text-slate-500 hover:text-slate-700 hover:bg-slate-100" aria-label="Cerrar guía">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
          </div>

          <div class="px-5 py-5 space-y-4 text-sm text-slate-700">
            <div class="rounded-lg border border-teal-200 bg-teal-50 px-4 py-3">
              <p class="font-semibold text-teal-900 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-teal-700">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m6 2.25a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                Administración de clientes para facturación
              </p>
              <p class="mt-1">En esta sección puedes administrar tus <span class="font-semibold">clientes</span> para la facturación de servicios.</p>
              <p class="mt-1">Aquí podrás registrar su información básica, fiscal y de contacto para tenerla lista al momento de facturar.</p>
            </div>

            <div class="rounded-lg border border-slate-200 bg-white px-4 py-3">
              <p class="font-semibold text-slate-900 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-slate-700">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
                Sección: Información básica
              </p>
              <p class="mt-1"><span class="font-semibold">Obligatorio:</span> Nombre del cliente.</p>
              <p class="mt-1"><span class="font-semibold">No editable para ti:</span> Rol (queda en Cliente).</p>
            </div>

            <div class="rounded-lg border border-indigo-200 bg-indigo-50 px-4 py-3">
              <p class="font-semibold text-indigo-900 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-indigo-700">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6M7 4h7l5 5v11a2 2 0 01-2 2H7a2 2 0 01-2-2V6a2 2 0 012-2z" />
                </svg>
                Sección: Perfil fiscal
              </p>
              <p class="mt-1">Para cliente, todos los campos de perfil fiscal son <span class="font-semibold">obligatorios</span>:</p>
              <p class="mt-1">RFC, Razón Social, Régimen Fiscal, Uso CFDI, Método de Pago y Forma de Pago.</p>
            </div>

            <div class="rounded-lg border border-amber-200 bg-amber-50 px-4 py-3">
              <p class="font-semibold text-amber-900 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-amber-700">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 7.5l8.25-4.5 8.25 4.5m-16.5 0v9l8.25 4.5m8.25-13.5v9L12 21" />
                </svg>
                Sección: Dirección principal
              </p>
              <p class="mt-1"><span class="font-semibold">Obligatorio:</span> Código Postal.</p>
              <p class="mt-1"><span class="font-semibold">Opcionales:</span> calle, números, colonia, municipio, estado, país y email.</p>
            </div>

            <div class="rounded-lg border border-rose-200 bg-rose-50 px-4 py-3">
              <p class="font-semibold text-rose-900 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-rose-700">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9.303 3.376l-7.5-12.99a1.5 1.5 0 00-2.598 0l-7.5 12.99A1.5 1.5 0 004.5 18.75h15a1.5 1.5 0 001.303-2.624z" />
                </svg>
                Validaciones y envío
              </p>
              <p class="mt-1">Si falta un campo obligatorio o hay datos inválidos, el sistema mostrará los errores para corregirlos.</p>
              <p class="mt-1">Cuando todo esté correcto, usa <span class="font-semibold">Crear Entidad</span> para guardar el nuevo cliente.</p>
            </div>
          </div>

          <div class="px-5 py-4 border-t border-slate-200 bg-slate-50 flex justify-end">
            <button type="button" data-action="click->modal#close" class="cursor-pointer inline-flex items-center px-4 py-2 rounded-md bg-teal-600 hover:bg-teal-700 text-white text-sm font-semibold">
              Entendido
            </button>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>
