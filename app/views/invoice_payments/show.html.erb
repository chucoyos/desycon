<% content_for :title, "Pago ##{@payment.id}" %>

<div class="w-full max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-8">
  <% status_badge_classes = case @payment.status
    when "registered" then "bg-emerald-50 text-emerald-700 border-emerald-200"
    when "complement_queued" then "bg-blue-50 text-blue-700 border-blue-200"
    when "complement_issued" then "bg-violet-50 text-violet-700 border-violet-200"
    when "failed" then "bg-rose-50 text-rose-700 border-rose-200"
    else "bg-slate-50 text-slate-700 border-slate-200"
    end %>

  <div class="mb-5">
    <div class="flex flex-wrap items-center gap-2">
      <%= link_to invoice_path(@invoice, anchor: "payments-section"), class: "inline-flex items-center gap-2 px-3.5 py-2 rounded-full text-sm font-medium text-slate-700 hover:bg-slate-100 transition-all duration-200 group" do %>
        <svg class="w-5 h-5 transition-transform group-hover:-translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/>
        </svg>
        <span>Volver a la factura</span>
      <% end %>

      <% if current_user&.admin_or_executive? %>
        <%= link_to admin_invoice_payment_evidences_path, class: "inline-flex items-center gap-2 px-3.5 py-2 rounded-full text-sm font-medium text-indigo-700 hover:bg-indigo-50 transition-all duration-200" do %>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h12M9 12l4 4m-4-4l4-4M3 6h12M3 12h2M3 18h12" />
          </svg>
          <span>Volver a evidencias</span>
        <% end %>
      <% end %>
    </div>
  </div>

  <section class="rounded-3xl border border-slate-200 bg-white shadow-[0_10px_30px_rgba(15,23,42,0.08)] overflow-hidden">
    <div class="px-6 sm:px-8 py-6 bg-gradient-to-r from-slate-50 via-white to-slate-50 border-b border-slate-200">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.08em] text-slate-500">Detalle de pago</p>
          <h1 class="text-2xl font-bold text-slate-900 mt-1 inline-flex items-center gap-2">
            <svg class="w-6 h-6 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Pago #<%= @payment.id %>
          </h1>
        </div>
        <span class="inline-flex items-center self-start px-3 py-1 rounded-full border text-xs font-semibold <%= status_badge_classes %>">
          <%= @payment.status_label %>
        </span>
      </div>
    </div>

    <div class="p-6 sm:p-8 space-y-7">
      <div>
        <h2 class="text-sm font-semibold uppercase tracking-[0.08em] text-slate-500 mb-3 inline-flex items-center gap-2">
          <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          Datos del pago
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3 text-sm">
          <div class="rounded-2xl border border-slate-200 bg-slate-50/70 p-4">
            <p class="text-slate-500">Monto</p>
            <p class="font-semibold text-slate-900"><%= number_to_currency(@payment.amount) %></p>
          </div>
          <div class="rounded-2xl border border-slate-200 bg-slate-50/70 p-4">
            <p class="text-slate-500">Moneda</p>
            <p class="font-semibold text-slate-900"><%= @payment.currency %></p>
          </div>
          <div class="rounded-2xl border border-slate-200 bg-slate-50/70 p-4">
            <p class="text-slate-500">Fecha pago</p>
            <p class="font-semibold text-slate-900"><%= l(@payment.paid_at, format: :long) %></p>
          </div>
          <div class="rounded-2xl border border-slate-200 bg-slate-50/70 p-4">
            <p class="text-slate-500">Forma pago</p>
            <p class="font-semibold text-slate-900"><%= [@payment.payment_method, FiscalProfile::FORMAS_PAGO[@payment.payment_method]].compact.join(' - ') %></p>
          </div>
          <div class="rounded-2xl border border-slate-200 bg-slate-50/70 p-4">
            <p class="text-slate-500">Referencia</p>
            <p class="font-semibold text-slate-900"><%= @payment.reference.presence || '-' %></p>
          </div>
          <div class="rounded-2xl border border-slate-200 bg-slate-50/70 p-4">
            <p class="text-slate-500">Clave de rastreo</p>
            <p class="font-semibold text-slate-900"><%= @payment.tracking_key.presence || '-' %></p>
          </div>
        </div>
      </div>

      <div class="rounded-2xl border border-slate-200 bg-white p-5">
        <h2 class="text-sm font-semibold uppercase tracking-[0.08em] text-slate-500 mb-2 inline-flex items-center gap-2">
          <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6M7 4h10a2 2 0 012 2v12a2 2 0 01-2 2H7a2 2 0 01-2-2V6a2 2 0 012-2z" />
          </svg>
          Notas
        </h2>
        <p class="text-sm font-medium text-slate-900"><%= @payment.notes.presence || '-' %></p>
      </div>

      <% if @payment.receipt_file.attached? %>
        <div class="rounded-2xl border border-indigo-100 bg-indigo-50/60 p-5">
          <h2 class="text-sm font-semibold uppercase tracking-[0.08em] text-indigo-700 mb-3 inline-flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m.75 12h6m-6 3h3.75M9 3H6.375A2.625 2.625 0 003.75 5.625v12.75A2.625 2.625 0 006.375 21h11.25a2.625 2.625 0 002.625-2.625V9.75L14.25 3H9z" />
            </svg>
            Comprobante del pago
          </h2>
          <div class="flex flex-wrap items-center gap-2">
            <%= link_to rails_blob_path(@payment.receipt_file_attachment, disposition: "inline"), target: "_blank", rel: "noopener", class: "inline-flex items-center gap-1.5 px-4 h-9 rounded-full text-xs font-semibold bg-slate-700 text-white hover:bg-slate-800 shadow-sm" do %>
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
              </svg>
              Ver comprobante
            <% end %>
            <%= link_to rails_blob_path(@payment.receipt_file_attachment, disposition: "attachment"), class: "inline-flex items-center gap-1.5 px-4 h-9 rounded-full text-xs font-semibold bg-indigo-600 text-white hover:bg-indigo-700 shadow-sm" do %>
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 16V4m0 12l-3-3m3 3l3-3M4 20h16" />
              </svg>
              Descargar comprobante
            <% end %>
          </div>
        </div>
      <% end %>

      <% if @payment_evidences.any? %>
        <div class="rounded-2xl border border-amber-200 bg-amber-50/60 p-5">
          <h2 class="text-sm font-semibold uppercase tracking-[0.08em] text-amber-700 mb-3 inline-flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.856-1.487M15 10a3 3 0 11-6 0 3 3 0 016 0zM6 20a6 6 0 0110.89-1.23M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
            </svg>
            Evidencia enviada por agencia
          </h2>
          <div class="space-y-3">
            <% @payment_evidences.each do |evidence| %>
              <div class="rounded-2xl border border-amber-200 bg-white p-4 shadow-sm">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                  <div>
                    <p class="text-xs text-slate-500">Referencia</p>
                    <p class="font-semibold text-slate-900"><%= evidence.reference.presence || '-' %></p>
                  </div>
                  <div>
                    <p class="text-xs text-slate-500">Clave de rastreo</p>
                    <p class="font-semibold text-slate-900"><%= evidence.tracking_key.presence || '-' %></p>
                  </div>
                  <div>
                    <p class="text-xs text-slate-500">Agencia</p>
                    <p class="font-semibold text-slate-900"><%= evidence.customs_agent&.name.presence || '-' %></p>
                  </div>
                  <div>
                    <p class="text-xs text-slate-500">Enviado por</p>
                    <p class="font-semibold text-slate-900"><%= evidence.submitted_by&.email.presence || '-' %></p>
                  </div>
                </div>

                <% if evidence.review_comment.present? %>
                  <div class="mt-3 rounded-xl border border-amber-200 bg-amber-50/70 p-3">
                    <p class="text-xs text-amber-700">Comentario de revision</p>
                    <p class="mt-1 text-sm font-medium text-slate-900"><%= evidence.review_comment %></p>
                  </div>
                <% end %>

                <% if evidence.receipt_file.attached? %>
                  <div class="mt-3 flex flex-wrap items-center gap-2">
                    <%= link_to rails_blob_path(evidence.receipt_file_attachment, disposition: "inline"), target: "_blank", rel: "noopener", class: "inline-flex items-center gap-1.5 px-4 h-9 rounded-full text-xs font-semibold bg-slate-700 text-white hover:bg-slate-800 shadow-sm" do %>
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                      </svg>
                      Ver comprobante
                    <% end %>
                    <%= link_to rails_blob_path(evidence.receipt_file_attachment, disposition: "attachment"), class: "inline-flex items-center gap-1.5 px-4 h-9 rounded-full text-xs font-semibold bg-indigo-600 text-white hover:bg-indigo-700 shadow-sm" do %>
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 16V4m0 12l-3-3m3 3l3-3M4 20h16" />
                      </svg>
                      Descargar comprobante
                    <% end %>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

      <div class="pt-1 flex items-center gap-2">
        <% if @payment.complement_invoice_id.blank? && @payment.status.in?(["registered", "failed"]) %>
          <%= link_to edit_invoice_invoice_payment_path(@invoice, @payment), class: "inline-flex items-center gap-1.5 px-4 h-10 rounded-full text-sm font-semibold bg-indigo-600 text-white shadow-sm hover:bg-indigo-700" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
            </svg>
            Editar pago
          <% end %>
        <% end %>
      </div>
    </div>
  </section>
</div>
