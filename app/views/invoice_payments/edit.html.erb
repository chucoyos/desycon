<% content_for :title, "Editar pago ##{@payment.id}" %>
<%
  serie = @invoice.provider_response.to_h["serie"].presence || @invoice.payload_snapshot.to_h["serie"].presence
  folio = @invoice.provider_response.to_h["folio"].presence ||
          @invoice.provider_response.to_h["noComprobante"].presence ||
          @invoice.payload_snapshot.to_h["folio"].presence ||
          @invoice.payload_snapshot.to_h["noComprobante"].presence ||
          @invoice.provider_response.to_h["numeroComprobante"].presence ||
          @invoice.payload_snapshot.to_h["numeroComprobante"].presence ||
          @invoice.facturador_comprobante_id&.to_s

  invoice_heading = if serie.present? && folio.present?
    "Factura #{serie} #{folio}"
  elsif folio.present?
    "Factura #{folio}"
  elsif serie.present?
    "Factura #{serie}"
  else
    "Factura ##{@invoice.id}"
  end
%>

<div class="w-full max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-8">
  <div class="mb-5">
    <%= link_to invoice_path(@invoice, anchor: "payments-section"), class: "inline-flex items-center gap-2 px-3.5 py-2 rounded-full text-sm font-medium text-slate-700 hover:bg-slate-100 transition-all duration-200 group" do %>
      <svg class="w-5 h-5 transition-transform group-hover:-translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/>
      </svg>
      <span>Volver a la factura</span>
    <% end %>
  </div>

  <section class="rounded-3xl border border-slate-200 bg-white shadow-[0_10px_30px_rgba(15,23,42,0.08)] overflow-hidden">
    <div class="px-6 sm:px-8 py-6 bg-gradient-to-r from-slate-50 via-white to-slate-50 border-b border-slate-200 flex flex-col md:flex-row md:items-center md:justify-between gap-3">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.08em] text-slate-500">Editar pago</p>
        <h1 class="text-2xl font-bold text-slate-900 mt-1 inline-flex items-center gap-2">
          <svg class="w-6 h-6 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Pago #<%= @payment.id %>
        </h1>
        <p class="text-xs text-slate-500 mt-1">Actualiza los datos del pago antes de emitir su complemento.</p>
      </div>
      <span class="inline-flex items-center self-start px-3 py-1 rounded-full text-xs font-semibold bg-white border border-indigo-100 text-indigo-700">
        <%= invoice_heading %>
      </span>
    </div>

    <%= form_with model: [@invoice, @payment], local: true, class: "p-6 sm:p-8 space-y-6" do |f| %>
      <div>
        <h2 class="text-sm font-semibold uppercase tracking-[0.08em] text-slate-500 mb-3 inline-flex items-center gap-2">
          <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          Datos principales
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-medium text-slate-700 mb-1">Monto</label>
            <%= f.number_field :amount, step: "0.01", min: "0.01", required: true, placeholder: "0.00", class: "w-full h-11 rounded-xl border border-slate-300 bg-white px-3 text-sm shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500" %>
          </div>

          <div>
            <label class="block text-xs font-medium text-slate-700 mb-1">Fecha pago</label>
            <%= f.datetime_local_field :paid_at, value: @payment.paid_at&.strftime('%Y-%m-%dT%H:%M'), required: true, class: "w-full h-11 rounded-xl border border-slate-300 bg-white px-3 text-sm shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500" %>
          </div>

          <div>
            <label class="block text-xs font-medium text-slate-700 mb-1">Forma pago</label>
            <%= f.select :payment_method,
                FiscalProfile::FORMAS_PAGO.map { |code, label| ["#{code} - #{label}", code] },
                {},
                class: "w-full h-11 rounded-xl border border-slate-300 bg-white px-3 text-sm shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500" %>
          </div>

          <div>
            <label class="block text-xs font-medium text-slate-700 mb-1">Referencia</label>
            <%= f.text_field :reference, class: "w-full h-11 rounded-xl border border-slate-300 bg-white px-3 text-sm shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500" %>
          </div>

          <div>
            <label class="block text-xs font-medium text-slate-700 mb-1">Clave de rastreo</label>
            <%= f.text_field :tracking_key, class: "w-full h-11 rounded-xl border border-slate-300 bg-white px-3 text-sm shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500" %>
          </div>
        </div>
      </div>

      <div class="rounded-2xl border border-indigo-100 bg-indigo-50/60 p-5">
        <h2 class="text-sm font-semibold uppercase tracking-[0.08em] text-indigo-700 mb-3 inline-flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m.75 12h6m-6 3h3.75M9 3H6.375A2.625 2.625 0 003.75 5.625v12.75A2.625 2.625 0 006.375 21h11.25a2.625 2.625 0 002.625-2.625V9.75L14.25 3H9z" />
          </svg>
          Comprobante
        </h2>
        <label class="block text-xs font-medium text-slate-700 mb-1">Adjuntar nuevo comprobante</label>
        <%= f.file_field :receipt_file, class: "w-full h-11 rounded-xl border border-slate-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500" %>

        <% if @payment.receipt_file.attached? %>
          <div class="mt-3 flex flex-wrap items-center gap-2">
            <%= link_to rails_blob_path(@payment.receipt_file_attachment, disposition: "inline"), target: "_blank", rel: "noopener", class: "inline-flex items-center gap-1.5 px-4 h-9 rounded-full text-xs font-semibold bg-slate-700 text-white hover:bg-slate-800 shadow-sm" do %>
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
              </svg>
              Ver actual
            <% end %>
            <%= link_to rails_blob_path(@payment.receipt_file_attachment, disposition: "attachment"), class: "inline-flex items-center gap-1.5 px-4 h-9 rounded-full text-xs font-semibold bg-indigo-600 text-white hover:bg-indigo-700 shadow-sm" do %>
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 16V4m0 12l-3-3m3 3l3-3M4 20h16" />
              </svg>
              Descargar actual
            <% end %>
          </div>
        <% end %>
      </div>

      <div>
        <label class="block text-xs font-medium text-slate-700 mb-1">Notas</label>
        <%= f.text_area :notes, rows: 4, class: "w-full rounded-xl border border-slate-300 bg-white px-3 py-2.5 text-sm shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500" %>
      </div>

      <div class="flex items-center justify-end gap-2 pt-2">
        <%= link_to invoice_path(@invoice, anchor: "payments-section"), class: "inline-flex items-center justify-center gap-1.5 h-10 px-4 rounded-full text-sm font-medium bg-slate-100 text-slate-700 hover:bg-slate-200" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
          Cancelar
        <% end %>
        <button type="submit" class="inline-flex items-center justify-center gap-1.5 h-10 px-5 rounded-full text-sm font-semibold bg-indigo-600 text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          Guardar cambios
        </button>
      </div>
    <% end %>
  </section>
</div>
