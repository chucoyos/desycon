<% content_for :title, "Dashboard de Inteligencia Operativa y Financiera" %>

<%
  month_labels = @revenue_metrics[:month_labels]
  facturado_series = @revenue_metrics[:emitted]
  cobrado_series = @revenue_metrics[:collected]
  por_cobrar_series = @revenue_metrics[:outstanding]

  month_over_month = lambda do |current_value, previous_value|
    change = current_value - previous_value

    if previous_value.zero?
      {
        label: "Sin base comparativa",
        class_name: "text-slate-500"
      }
    else
      percent = ((change / previous_value) * 100).round(1)
      sign = percent.positive? ? "+" : ""
      {
        label: "#{sign}#{percent}% vs mes anterior",
        class_name: percent.positive? ? "text-emerald-600" : (percent.negative? ? "text-rose-600" : "text-slate-500")
      }
    end
  end

  revenue_chart_data = [
    { name: "Cobrado", data: month_labels.zip(cobrado_series).to_h },
    { name: "Por cobrar", data: month_labels.zip(por_cobrar_series).to_h }
  ]
  revenue_chart_colors = {
    "Cobrado" => "#2563eb",
    "Por cobrar" => "#dc2626",
    "Total" => "#0f766e"
  }

  revenue_by_port_chart_data = @revenue_metrics.fetch(:emitted_by_destination_port, {}).map do |port_name, values|
    { name: port_name, data: month_labels.zip(values).to_h }
  end
  revenue_by_port_color_palette = ["#0ea5e9", "#f97316", "#eab308", "#22c55e", "#64748b", "#a855f7", "#ec4899", "#14b8a6"]
  revenue_by_port_color_by_name = revenue_by_port_chart_data.each_with_index.to_h do |series, index|
    [series[:name], revenue_by_port_color_palette[index % revenue_by_port_color_palette.length]]
  end
  destination_series_by_port_code = if Facturador::Config.environment.to_s.strip.downcase == "sandbox"
    Facturador::PayloadBuilder::IMPORT_DESTINATION_SERIES_BY_PORT_CODE_SANDBOX
  else
    Facturador::PayloadBuilder::IMPORT_DESTINATION_SERIES_BY_PORT_CODE_PRODUCTION
  end
  revenue_port_label_to_serie = destination_series_by_port_code.each_with_object({}) do |(port_code, serie), acc|
    port_label = Admin::ManagementDashboard::RevenueMonthlyService::DESTINATION_PORT_LABELS_BY_CODE[port_code]
    next if port_label.blank?

    acc[port_label] = serie.to_s
  end
  destination_port_code_by_label = Admin::ManagementDashboard::RevenueMonthlyService::DESTINATION_PORT_LABELS_BY_CODE.invert
    .merge(Admin::ManagementDashboard::RevenueMonthlyService::UNCLASSIFIED_PORT_LABEL => "N/A")

  containers_chart_data = [
    { name: "Creados", data: month_labels.zip(@operations_metrics.dig(:containers, :created)).to_h },
    { name: "Desconsolidados", data: month_labels.zip(@operations_metrics.dig(:containers, :unconsolidated)).to_h }
  ]

  bl_lines_chart_data = [
    { name: "Creadas", data: month_labels.zip(@operations_metrics.dig(:bl_house_lines, :created)).to_h },
    { name: "Revalidadas", data: month_labels.zip(@operations_metrics.dig(:bl_house_lines, :revalidated)).to_h },
    { name: "Despachadas", data: month_labels.zip(@operations_metrics.dig(:bl_house_lines, :dispatched)).to_h }
  ]

  destination_ports_chart_data = @operations_metrics[:destination_port_importation].map do |port_name, values|
    { name: port_name, data: month_labels.zip(values).to_h }
  end

  destination_ports_chart_colors = [
    "#2563eb", # blue
    "#dc2626", # red
    "#16a34a", # green
    "#7c3aed", # violet
    "#ea580c", # orange
    "#0891b2", # cyan
    "#ca8a04", # amber
    "#be185d"  # rose
  ]
%>

<div class="w-full px-4 sm:px-6 lg:px-8 py-6 space-y-6">
  <div class="bg-white border border-slate-200 rounded-2xl p-5 sm:p-6 shadow-sm">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
      <div>
        <h1 class="text-2xl sm:text-3xl font-bold text-slate-900">Dashboard de Inteligencia Operativa y Financiera</h1>
        <p class="mt-1 text-sm text-slate-600">Vista gerencial mensual de ingresos y operación (YTD).</p>
      </div>

      <%= form_with url: admin_management_dashboard_path, method: :get, class: "flex items-end gap-2" do %>
        <div>
          <label for="year" class="block text-xs font-semibold uppercase tracking-wider text-slate-500 mb-1">Año</label>
          <%= select_tag :year,
            options_for_select(@available_years.map { |year| [year, year] }, @selected_year),
            id: "year",
            class: "h-10 px-3 rounded-lg border border-slate-300 bg-white text-sm text-slate-800 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
        </div>
        <%= submit_tag "Aplicar", class: "h-10 px-4 rounded-lg bg-blue-600 text-white text-sm font-semibold hover:bg-blue-700 cursor-pointer" %>
      <% end %>
    </div>
  </div>

  <section class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
    <div class="bg-white border border-slate-200 rounded-xl p-4 shadow-sm">
      <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Ingresos Emitidos YTD</p>
      <p class="mt-2 text-2xl font-bold text-emerald-700"><%= number_to_currency(@revenue_metrics.dig(:totals, :emitted)) %></p>
    </div>
    <div class="bg-white border border-slate-200 rounded-xl p-4 shadow-sm">
      <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Ingresos Cobrados YTD</p>
      <p class="mt-2 text-2xl font-bold text-blue-700"><%= number_to_currency(@revenue_metrics.dig(:totals, :collected)) %></p>
    </div>
    <div class="bg-white border border-slate-200 rounded-xl p-4 shadow-sm">
      <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Ingresos por Cobrar YTD</p>
      <p class="mt-2 text-2xl font-bold text-rose-700"><%= number_to_currency(@revenue_metrics.dig(:totals, :outstanding)) %></p>
    </div>
    <div class="bg-white border border-slate-200 rounded-xl p-4 shadow-sm">
      <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Contenedores Creados YTD</p>
      <p class="mt-2 text-2xl font-bold text-slate-900"><%= @operations_metrics.dig(:totals, :containers_created) %></p>
    </div>
    <div class="bg-white border border-slate-200 rounded-xl p-4 shadow-sm">
      <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Contenedores Desconsolidados YTD</p>
      <p class="mt-2 text-2xl font-bold text-green-700"><%= @operations_metrics.dig(:totals, :containers_unconsolidated) %></p>
    </div>
    <div class="bg-white border border-slate-200 rounded-xl p-4 shadow-sm">
      <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Partidas Creadas YTD</p>
      <p class="mt-2 text-2xl font-bold text-slate-900"><%= @operations_metrics.dig(:totals, :bl_created) %></p>
    </div>
    <div class="bg-white border border-slate-200 rounded-xl p-4 shadow-sm">
      <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Partidas Revalidadas YTD</p>
      <p class="mt-2 text-2xl font-bold text-violet-700"><%= @operations_metrics.dig(:totals, :bl_revalidated) %></p>
    </div>
    <div class="bg-white border border-slate-200 rounded-xl p-4 shadow-sm">
      <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Partidas Despachadas YTD</p>
      <p class="mt-2 text-2xl font-bold text-green-700"><%= @operations_metrics.dig(:totals, :bl_dispatched) %></p>
    </div>
  </section>

  <section
    class="bg-white border border-slate-200 rounded-2xl p-5 shadow-sm"
    data-controller="revenue-chart-links"
    data-revenue-chart-links-year-value="<%= @selected_year %>"
    data-revenue-chart-links-invoices-path-value="<%= invoices_path %>"
    data-revenue-chart-links-chart-id-value="revenue-monthly-chart"
  >
    <h2 class="text-lg font-bold text-slate-900">Ingresos Mensuales (YTD)</h2>
    <p class="text-sm text-slate-600 mb-4">Cobrado y por cobrar por mes. El total apilado representa lo facturado.</p>
    <%= column_chart revenue_chart_data,
      id: "revenue-monthly-chart",
      height: "320px",
      legend: "top",
      thousands: ",",
      prefix: "$",
      colors: [revenue_chart_colors["Cobrado"], revenue_chart_colors["Por cobrar"]],
      library: {
        plotOptions: {
          column: {
            stacking: "normal",
            pointWidth: 32,
            pointPadding: 0.08,
            groupPadding: 0.18
          }
        },
        plugins: {
          legend: {
            labels: {
              boxWidth: 12,
              boxHeight: 12
            }
          }
        }
      } %>

    <div class="mt-4 border-t border-slate-200 pt-3 overflow-x-auto">
      <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Desglose por mes</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 xl:grid-cols-6 gap-3 min-w-[980px]">
        <% month_labels.each_with_index do |month_label, index| %>
          <% month_collected = cobrado_series[index].to_d %>
          <% month_outstanding = por_cobrar_series[index].to_d %>
          <% month_total = month_collected + month_outstanding %>
          <% previous_month_total = index.positive? ? (cobrado_series[index - 1].to_d + por_cobrar_series[index - 1].to_d) : 0.to_d %>
          <% month_total_mom = month_over_month.call(month_total, previous_month_total) %>
          <div class="rounded-xl border border-slate-200 bg-slate-50 p-3">
            <p class="text-[11px] font-semibold text-slate-500 uppercase tracking-wider"><%= month_label %></p>

            <div class="mt-2 space-y-1.5 text-xs">
              <div class="flex items-center justify-between gap-2">
                <span class="inline-flex items-center gap-1.5 text-slate-700">
                  <span class="w-2 h-2 rounded-full" style="background-color: <%= revenue_chart_colors['Cobrado'] %>"></span>
                  Cobrado
                </span>
                <span class="font-semibold text-slate-900"><%= number_to_currency(month_collected) %></span>
              </div>

              <div class="flex items-center justify-between gap-2">
                <span class="inline-flex items-center gap-1.5 text-slate-700">
                  <span class="w-2 h-2 rounded-full" style="background-color: <%= revenue_chart_colors['Por cobrar'] %>"></span>
                  Por cobrar
                </span>
                <span class="font-semibold text-slate-900"><%= number_to_currency(month_outstanding) %></span>
              </div>

              <div class="pt-1 mt-1 border-t border-slate-200 flex items-center justify-between gap-2">
                <span class="inline-flex items-center gap-1.5 text-slate-800 font-semibold">
                  <span class="w-2 h-2 rounded-full" style="background-color: <%= revenue_chart_colors['Total'] %>"></span>
                  Total
                </span>
                <span class="font-bold text-slate-900"><%= number_to_currency(month_total) %></span>
              </div>

              <p class="pt-1 text-[11px] font-semibold <%= month_total_mom[:class_name] %>"><%= month_total_mom[:label] %></p>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </section>

  <section
    class="bg-white border border-slate-200 rounded-2xl p-5 shadow-sm"
    data-controller="revenue-by-port-chart-links"
    data-revenue-by-port-chart-links-year-value="<%= @selected_year %>"
    data-revenue-by-port-chart-links-invoices-path-value="<%= invoices_path %>"
    data-revenue-by-port-chart-links-chart-id-value="revenue-by-port-monthly-chart"
    data-revenue-by-port-chart-links-port-series-by-label-value='<%= revenue_port_label_to_serie.to_json %>'
  >
    <h2 class="text-lg font-bold text-slate-900">Ingresos Mensuales por Puerto (Serie CFDI)</h2>
    <p class="text-sm text-slate-600 mb-4">Clasificacion mensual de ingresos facturados por puerto segun la serie del CFDI (barras apiladas).</p>
    <% if revenue_by_port_chart_data.any? %>
      <%= column_chart revenue_by_port_chart_data,
        id: "revenue-by-port-monthly-chart",
        height: "320px",
        legend: "top",
        thousands: ",",
        prefix: "$",
        colors: revenue_by_port_chart_data.map { |series| revenue_by_port_color_by_name[series[:name]] },
        library: {
          plotOptions: {
            column: {
              stacking: "normal",
              pointWidth: 32,
              pointPadding: 0.08,
              groupPadding: 0.18
            }
          },
          plugins: {
            legend: {
              labels: {
                boxWidth: 12,
                boxHeight: 12
              }
            }
          }
        } %>

      <div class="mt-4 border-t border-slate-200 pt-3 overflow-x-auto">
        <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Desglose por mes</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 xl:grid-cols-6 gap-3 min-w-[980px]">
          <% month_labels.each_with_index do |month_label, index| %>
            <% month_total = revenue_by_port_chart_data.sum do |series|
              series[:data][month_label].to_d
            end %>
            <% previous_month_total = if index.positive?
              previous_month_label = month_labels[index - 1]
              revenue_by_port_chart_data.sum { |series| series[:data][previous_month_label].to_d }
            else
              0.to_d
            end %>
            <% month_total_mom = month_over_month.call(month_total, previous_month_total) %>
            <div class="rounded-xl border border-slate-200 bg-slate-50 p-3">
              <p class="text-[11px] font-semibold text-slate-500 uppercase tracking-wider"><%= month_label %></p>

              <div class="mt-2 space-y-1.5 text-xs">
                <% revenue_by_port_chart_data.each do |series| %>
                  <% amount = series[:data][month_label].to_d %>
                  <% raw_port_code = destination_port_code_by_label.fetch(series[:name], series[:name]) %>
                  <% port_code = raw_port_code.to_s.sub(/\AMX/, "") %>
                  <div class="flex items-center justify-between gap-2">
                    <span class="inline-flex items-center gap-1.5 text-slate-700">
                      <span class="w-2 h-2 rounded-full" style="background-color: <%= revenue_by_port_color_by_name[series[:name]] %>"></span>
                      <span title="<%= series[:name] %>"><%= port_code %></span>
                    </span>
                    <span class="font-semibold text-slate-900"><%= number_to_currency(amount) %></span>
                  </div>
                <% end %>

                <div class="pt-1 mt-1 border-t border-slate-200 flex items-center justify-between gap-2">
                  <span class="inline-flex items-center gap-1.5 text-slate-800 font-semibold">
                    <span class="w-2 h-2 rounded-full" style="background-color: #0f766e"></span>
                    Total
                  </span>
                  <span class="font-bold text-slate-900"><%= number_to_currency(month_total) %></span>
                </div>

                <p class="pt-1 text-[11px] font-semibold <%= month_total_mom[:class_name] %>"><%= month_total_mom[:label] %></p>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% else %>
      <p class="text-sm text-slate-500">No hay ingresos clasificados por puerto para el periodo seleccionado.</p>
    <% end %>
  </section>

  <section class="grid grid-cols-1 xl:grid-cols-2 gap-6">
    <div class="bg-white border border-slate-200 rounded-2xl p-5 shadow-sm">
      <h2 class="text-lg font-bold text-slate-900">Operación de Contenedores (YTD)</h2>
      <p class="text-sm text-slate-600 mb-4">Creados y desconsolidados por mes.</p>
      <%= line_chart containers_chart_data,
        height: "320px",
        legend: "top",
        curve: false,
        discrete: true,
        colors: ["#334155", "#0ea5e9"],
        library: {
          plugins: {
            legend: {
              labels: {
                boxWidth: 12,
                boxHeight: 12
              }
            }
          }
        } %>
    </div>

    <div class="bg-white border border-slate-200 rounded-2xl p-5 shadow-sm">
      <h2 class="text-lg font-bold text-slate-900">Partidas (YTD)</h2>
      <p class="text-sm text-slate-600 mb-4">Creadas, revalidadas y despachadas por mes.</p>
      <%= line_chart bl_lines_chart_data,
        height: "320px",
        legend: "top",
        curve: false,
        discrete: true,
        colors: ["#f59e0b", "#8b5cf6", "#22c55e"],
        library: {
          plugins: {
            legend: {
              labels: {
                boxWidth: 12,
                boxHeight: 12
              }
            }
          }
        } %>
    </div>
  </section>

  <section class="bg-white border border-slate-200 rounded-2xl p-5 shadow-sm">
    <h2 class="text-lg font-bold text-slate-900">Clasificación por Puerto Destino (Solo Importación)</h2>
    <p class="text-sm text-slate-600 mb-4">Conteo mensual de contenedores por puerto: Manzanillo, Lazaro Cardenas, Altamira y Veracruz.</p>
    <%= line_chart destination_ports_chart_data,
      height: "320px",
      legend: "top",
      curve: false,
      discrete: true,
      colors: destination_ports_chart_colors,
      library: {
        plotOptions: {
          series: {
            lineWidth: 3,
            marker: {
              enabled: true,
              radius: 4,
              symbol: "circle"
            }
          }
        },
        plugins: {
          legend: {
            labels: {
              boxWidth: 12,
              boxHeight: 12
            }
          }
        }
      } %>
  </section>
</div>
