<% content_for :title, "Revisión de evidencia ##{@evidence.id}" %>
<%
  serie = @invoice&.provider_response.to_h["serie"].presence || @invoice&.payload_snapshot.to_h["serie"].presence
  folio = @invoice&.provider_response.to_h["folio"].presence ||
          @invoice&.provider_response.to_h["noComprobante"].presence ||
          @invoice&.provider_response.to_h["numeroComprobante"].presence ||
          @invoice&.facturador_comprobante_id&.to_s

  invoice_label = if @invoice.blank?
    "Sin factura seleccionada"
  elsif serie.present? && folio.present?
    "Factura #{serie} #{folio}"
  elsif folio.present?
    "Factura #{folio}"
  elsif serie.present?
    "Factura #{serie}"
  else
    "Factura ##{@invoice.id}"
  end
%>

<div class="w-full px-4 sm:px-6 lg:px-8 py-4 sm:py-6 lg:py-8">
  <div class="mb-6 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
    <div>
      <h1 class="font-bold text-3xl text-gray-900">Evidencia #<%= @evidence.id %></h1>
      <p class="text-sm text-gray-500 mt-1"><%= invoice_label %> | Referencia enviada: <span class="font-semibold"><%= @evidence.reference %></span></p>
    </div>
    <%= link_to "Volver", admin_invoice_payment_evidences_path, class: "cursor-pointer inline-flex items-center px-4 py-2 rounded-lg border border-gray-300 bg-white text-gray-700 hover:bg-gray-50 text-sm font-medium" %>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-1 space-y-6">
      <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5">
        <h2 class="text-sm font-semibold text-gray-700 uppercase tracking-wider mb-4">Resumen</h2>
        <dl class="space-y-3 text-sm text-gray-700">
          <div>
            <dt class="text-gray-500">Estado</dt>
            <dd class="font-semibold"><%= @evidence.status_label %></dd>
          </div>
          <div>
            <dt class="text-gray-500">Agencia</dt>
            <dd class="font-semibold"><%= @evidence.customs_agent&.name %></dd>
          </div>
          <div>
            <dt class="text-gray-500">Enviado por</dt>
            <dd class="font-semibold"><%= @evidence.submitted_by&.email %></dd>
          </div>
          <div>
            <dt class="text-gray-500">Clave de rastreo</dt>
            <dd class="font-semibold"><%= @evidence.tracking_key.presence || "-" %></dd>
          </div>
          <div>
            <dt class="text-gray-500">Pago vinculado</dt>
            <dd class="font-semibold"><%= @evidence.invoice_payment_id.present? ? "##{@evidence.invoice_payment_id}" : "Sin vincular" %></dd>
          </div>
        </dl>

        <% if @evidence.receipt_file.attached? %>
          <div class="mt-5 flex items-center gap-2">
            <%= link_to "Ver comprobante", rails_blob_path(@evidence.receipt_file, disposition: "inline"), target: "_blank", rel: "noopener", class: "cursor-pointer inline-flex items-center px-3 py-2 rounded-md bg-slate-600 hover:bg-slate-700 text-white text-sm font-semibold" %>
            <%= link_to "Descargar comprobante", rails_blob_path(@evidence.receipt_file, disposition: "attachment"), class: "cursor-pointer inline-flex items-center px-3 py-2 rounded-md bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold" %>
          </div>
        <% end %>
      </div>

      <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5">
        <h2 class="text-sm font-semibold text-gray-700 uppercase tracking-wider mb-4">Facturas vinculadas</h2>
        <% if @evidence_invoices.any? %>
          <ul class="space-y-2 max-h-56 overflow-y-auto pr-1">
            <% @evidence_invoices.each do |evidence_invoice| %>
              <% inv_serie = evidence_invoice.provider_response.to_h["serie"].presence || evidence_invoice.payload_snapshot.to_h["serie"].presence %>
              <% inv_folio = evidence_invoice.provider_response.to_h["folio"].presence || evidence_invoice.provider_response.to_h["noComprobante"].presence || evidence_invoice.provider_response.to_h["numeroComprobante"].presence || evidence_invoice.facturador_comprobante_id&.to_s %>
              <% inv_label = [inv_serie, inv_folio].compact.join(" ").presence || "Factura ##{evidence_invoice.id}" %>
              <li class="rounded-lg border border-gray-200 px-3 py-2 text-sm flex items-center justify-between gap-2 <%= @invoice&.id == evidence_invoice.id ? 'bg-indigo-50 border-indigo-200' : '' %>">
                <%= link_to inv_label, invoice_path(evidence_invoice), class: "font-semibold text-indigo-700 hover:text-indigo-900" %>
                <span class="text-gray-500"><%= number_to_currency(evidence_invoice.outstanding_amount) %></span>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-sm text-gray-500">No hay facturas vinculadas a esta evidencia.</p>
        <% end %>
      </div>
    </div>

    <div class="lg:col-span-2 space-y-6">
      <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Registrar pago nuevo desde evidencia</h2>
        <% grouped_ppd_available = @evidence_invoices.many? && @evidence_invoices.all? { |linked_invoice| linked_invoice.payment_method_code == FiscalProfile::METODO_PAGO_PPD } %>
        <% if @invoice.present? %>
          <% payment_method_code = @invoice.payment_method_code %>
          <% payment_method_label = FiscalProfile::METODOS_PAGO[payment_method_code].presence || "No definido" %>
          <div class="mb-4 rounded-lg border border-gray-200 bg-gray-50 px-3 py-3 text-sm text-gray-700">
            <p class="mb-1">Factura seleccionada: <span class="font-semibold"><%= invoice_label %></span></p>
            <p class="mb-1">Cliente: <span class="font-semibold"><%= @invoice.receiver_entity&.name %></span></p>
            <p class="mb-1">Método de pago: <span class="font-semibold"><%= payment_method_code %> - <%= payment_method_label %></span></p>
            <p>Total: <span class="font-semibold"><%= number_to_currency(@invoice.total) %></span> | Saldo pendiente: <span class="font-semibold"><%= number_to_currency(@invoice.outstanding_amount) %></span></p>
          </div>
        <% else %>
          <div class="mb-4 rounded-lg border border-amber-200 bg-amber-50 px-3 py-3 text-sm text-amber-800">
            <% if grouped_ppd_available %>
              Ingresa montos por factura para registrar pagos y emitir un solo REP agrupado.
            <% else %>
              Selecciona una factura vinculada para registrar el pago.
            <% end %>
          </div>
        <% end %>
        <%= form_with url: register_payment_admin_invoice_payment_evidence_path(@evidence), method: :post, scope: :register_payment, local: true, class: "grid grid-cols-1 md:grid-cols-2 gap-4" do |f| %>
          <% if grouped_ppd_available %>
            <div class="md:col-span-2 rounded-lg border border-indigo-200 bg-indigo-50 px-3 py-3">
              <p class="text-sm font-semibold text-indigo-900">Registro agrupado de pagos (un solo REP)</p>
              <p class="text-xs text-indigo-700 mt-0.5">Captura el monto pagado por cada factura incluida en el comprobante.</p>
              <div class="mt-3 space-y-2">
                <% @evidence_invoices.each do |linked_invoice| %>
                  <% linked_serie = linked_invoice.provider_response.to_h["serie"].presence || linked_invoice.payload_snapshot.to_h["serie"].presence %>
                  <% linked_folio = linked_invoice.provider_response.to_h["folio"].presence || linked_invoice.provider_response.to_h["noComprobante"].presence || linked_invoice.provider_response.to_h["numeroComprobante"].presence || linked_invoice.facturador_comprobante_id&.to_s %>
                  <% linked_label = [linked_serie, linked_folio].compact.join(" ").presence || "Factura ##{linked_invoice.id}" %>
                  <div class="grid grid-cols-1 md:grid-cols-3 gap-2 items-center rounded-md border border-indigo-100 bg-white px-3 py-2">
                    <p class="text-sm font-medium text-slate-800"><%= linked_label %></p>
                    <p class="text-xs text-slate-500">Saldo: <%= number_to_currency(linked_invoice.outstanding_amount) %></p>
                    <%= number_field_tag "register_payment[invoice_amounts][#{linked_invoice.id}]", linked_invoice.outstanding_amount.to_s("F"), step: "0.01", min: "0", class: "grouped-invoice-amount-input w-full px-3 py-2 border border-gray-300 rounded-md text-sm" %>
                  </div>
                <% end %>
              </div>
            </div>
          <% else %>
            <%= f.hidden_field :invoice_id, value: @invoice&.id %>
          <% end %>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Monto</label>
            <%= f.number_field :amount, step: "0.01", min: "0.01", value: @invoice&.outstanding_amount&.to_s("F"), required: !grouped_ppd_available, disabled: grouped_ppd_available, id: "grouped-payment-total-amount", class: "w-full px-3 py-2 border border-gray-300 rounded-md disabled:bg-gray-100" %>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Fecha de pago</label>
            <%= f.date_field :paid_at, value: Date.current, required: true, class: "w-full px-3 py-2 border border-gray-300 rounded-md" %>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Forma de pago</label>
            <%= f.select :payment_method, options_for_select(@payment_method_options, "03"), {}, class: "w-full px-3 py-2 border border-gray-300 rounded-md", required: true %>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Referencia</label>
            <%= f.text_field :reference, value: @evidence.reference, class: "w-full px-3 py-2 border border-gray-300 rounded-md" %>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Clave de rastreo</label>
            <%= f.text_field :tracking_key, value: @evidence.tracking_key, class: "w-full px-3 py-2 border border-gray-300 rounded-md" %>
          </div>
          <div class="md:col-span-2">
            <label class="block text-sm font-medium text-gray-700 mb-1">Notas</label>
            <%= f.text_area :notes, rows: 2, class: "w-full px-3 py-2 border border-gray-300 rounded-md" %>
          </div>
          <div class="md:col-span-2">
            <label class="block text-sm font-medium text-gray-700 mb-1">Comentario de revisión (opcional)</label>
            <%= f.text_area :review_comment, rows: 2, class: "w-full px-3 py-2 border border-gray-300 rounded-md" %>
          </div>
          <div class="md:col-span-2">
            <% disable_submit = grouped_ppd_available ? false : @invoice.blank? %>
            <%= f.submit "Registrar y vincular pago", disabled: disable_submit, class: "cursor-pointer inline-flex items-center px-4 py-2 rounded-md bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold disabled:opacity-50 disabled:cursor-not-allowed" %>
          </div>
        <% end %>
      </div>

      <div class="bg-white rounded-xl border border-red-200 shadow-sm p-5">
        <h2 class="text-lg font-semibold text-red-700 mb-4">Rechazar evidencia</h2>
        <%= form_with url: reject_admin_invoice_payment_evidence_path(@evidence), method: :patch, local: true, class: "space-y-4" do |f| %>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Motivo de rechazo</label>
            <%= f.text_area :review_comment, rows: 3, required: true, class: "w-full px-3 py-2 border border-gray-300 rounded-md", placeholder: "Describe por qué se rechaza la evidencia" %>
          </div>
          <%= f.submit "Rechazar evidencia", class: "cursor-pointer inline-flex items-center px-4 py-2 rounded-md bg-red-600 hover:bg-red-700 text-white text-sm font-semibold" %>
        <% end %>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener("turbo:load", initGroupedEvidenceAmountField);
  document.addEventListener("turbo:render", initGroupedEvidenceAmountField);

  function initGroupedEvidenceAmountField() {
    const amountField = document.getElementById("grouped-payment-total-amount");
    if (!amountField) return;

    const groupedInputs = Array.from(document.querySelectorAll(".grouped-invoice-amount-input"));
    if (groupedInputs.length === 0) return;

    const form = amountField.closest("form");
    if (!form || form.dataset.groupedAmountBound === "true") return;

    const syncTotal = () => {
      const total = groupedInputs.reduce((sum, input) => {
        const value = Number.parseFloat(input.value);
        return sum + (Number.isFinite(value) ? value : 0);
      }, 0);

      amountField.value = total.toFixed(2);
    };

    groupedInputs.forEach((input) => {
      input.addEventListener("input", syncTotal);
      input.addEventListener("change", syncTotal);
    });

    syncTotal();
    form.dataset.groupedAmountBound = "true";
  }
</script>