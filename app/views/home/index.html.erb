<% content_for :title, "Bienvenido a Global DYC" %>

<div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-slate-100 via-blue-50 to-slate-100 px-4 sm:px-6 lg:px-8 py-10 sm:py-12">
  <div class="max-w-6xl w-full">
    <div class="bg-white rounded-3xl shadow-2xl overflow-hidden border border-slate-200/70">
      <div class="grid grid-cols-1 lg:grid-cols-2">
        <!-- Hero Section - Lado Izquierdo -->
        <div class="relative min-h-[320px] sm:min-h-[420px] lg:min-h-[680px] p-8 sm:p-10 lg:p-12 flex flex-col justify-center overflow-hidden">
          <%= image_tag "login.jpeg", alt: "Operación logística portuaria", class: "absolute inset-0 h-full w-full object-cover object-center" %>
          <div class="absolute inset-0 bg-gradient-to-tr from-slate-950/85 via-blue-950/65 to-blue-700/35"></div>
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_20%_20%,rgba(255,255,255,0.25),transparent_45%)]"></div>

          <div class="relative z-10 text-white">
            <div class="mb-5 inline-flex items-center gap-3 rounded-full border border-white/25 bg-white/10 px-4 py-2 backdrop-blur-sm">
              <span class="inline-block h-2.5 w-2.5 rounded-full bg-emerald-300"></span>
              <span class="text-xs sm:text-sm font-semibold tracking-wide uppercase">Global DYC</span>
            </div>

            <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold leading-tight max-w-lg">
              Sistema de Gestion de Carga LCL
            </h2>

            <p class="mt-4 text-sm sm:text-base text-blue-100/95 max-w-lg leading-relaxed">
              Plataforma integral para la administracion de revalidaciones y asignacion electronica de mercancia.
            </p>
          </div>
        </div>

        <!-- Formulario de Login - Lado Derecho -->
        <div class="p-8 sm:p-10 lg:p-14 flex flex-col justify-center bg-gradient-to-br from-white to-slate-50/70">
          <div class="w-full max-w-md mx-auto">
            <div class="mb-9">
              <div class="inline-flex items-center justify-center rounded-2xl bg-white border border-slate-200 shadow-lg p-2 mb-4">
                <%= image_tag "logoDyC.jpeg", alt: "Logo Global DYC", class: "h-16 w-16 sm:h-20 sm:w-20 rounded-xl object-contain" %>
              </div>
              <h3 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-2">Iniciar Sesión</h3>
              <p class="text-gray-600 text-lg">Accede a tu cuenta para continuar</p>
            </div>

            <%= form_for(User.new, url: user_session_path, html: { class: "space-y-6" }) do |f| %>
              <div>
                <%= f.label :email, "Correo Electrónico", class: "block text-sm font-semibold text-gray-700 mb-2" %>
                <div class="relative group">
                  <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                    <svg class="h-5 w-5 text-gray-400 group-focus-within:text-blue-600 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 12a4 4 0 10-8 0 4 4 0 008 0zm0 0v1.5a2.5 2.5 0 005 0V12a9 9 0 10-9 9m4.5-1.206a8.959 8.959 0 01-4.5 1.207"/>
                    </svg>
                  </div>
                  <%= f.email_field :email, autofocus: true, autocomplete: "email", 
                      class: "block w-full pl-12 pr-4 py-3.5 border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all duration-200 text-gray-900 placeholder-gray-400 hover:border-gray-300",
                      placeholder: "correo@ejemplo.com" %>
                </div>
              </div>

              <div>
                <%= f.label :password, "Contraseña", class: "block text-sm font-semibold text-gray-700 mb-2" %>
                <div class="relative group">
                  <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                    <svg class="h-5 w-5 text-gray-400 group-focus-within:text-blue-600 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                    </svg>
                  </div>
                  <%= f.password_field :password, autocomplete: "current-password",
                      class: "block w-full pl-12 pr-4 py-3.5 border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all duration-200 text-gray-900 placeholder-gray-400 hover:border-gray-300",
                      placeholder: "••••••••" %>
                </div>
              </div>

              <div class="flex items-center">
                <%= f.check_box :remember_me, class: "h-4 w-4 text-blue-600 focus:ring-2 focus:ring-blue-500 border-gray-300 rounded transition-all" %>
                <%= f.label :remember_me, "Recordarme", class: "ml-3 block text-sm font-medium text-gray-700" %>
              </div>

              <div>
                <%= f.submit "Iniciar Sesión", class: "w-full flex justify-center items-center gap-2 py-3.5 px-4 border border-transparent rounded-xl shadow-lg text-base font-semibold text-white bg-gradient-to-r from-slate-800 to-blue-800 hover:from-slate-900 hover:to-blue-900 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-all duration-200 cursor-pointer transform hover:scale-[1.02]" %>
              </div>
            <% end %>

            <div class="mt-8">
              <div class="relative">
                <div class="absolute inset-0 flex items-center">
                  <div class="w-full border-t-2 border-gray-200"></div>
                </div>
                <div class="relative flex justify-center text-sm">
                  <span class="px-4 bg-gradient-to-r from-white via-gray-50 to-white text-gray-500 font-medium">¿Necesitas ayuda?</span>
                </div>
              </div>

              <div class="mt-6 text-center">
                <%= link_to new_user_password_path, class: "inline-flex items-center gap-2 text-sm font-semibold text-blue-600 hover:text-blue-700 transition-colors group" do %>
                  <svg class="w-4 h-4 group-hover:rotate-12 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/>
                  </svg>
                  ¿Olvidaste tu contraseña?
                <% end %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Footer -->
    <div class="mt-10 text-center">
      <p class="text-sm text-gray-600 font-medium">
        © <%= Time.current.year %> Global DYC. Todos los derechos reservados.
      </p>
      <p class="text-xs text-gray-500 mt-2">Sistema de Gestión de Carga LCL v1.0</p>
    </div>
  </div>
</div>
