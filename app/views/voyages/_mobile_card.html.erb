<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4">
  <div class="flex items-start justify-between gap-3">
    <div class="min-w-0">
      <div class="flex items-center gap-2">
        <span class="text-sm font-semibold text-gray-900 font-mono"><%= voyage.viaje %></span>
        <% if voyage.voyage_type.present? %>
          <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-indigo-100 text-indigo-800">
            <%= voyage.voyage_type.titleize %>
          </span>
        <% end %>
      </div>
      <p class="mt-1 text-sm text-gray-600"><%= voyage.vessel&.name || "Sin buque" %></p>
      <p class="text-xs text-gray-500"><%= voyage.destination_port&.display_name || "Sin destino" %></p>
    </div>

    <div class="relative inline-block text-left" data-controller="dropdown">
      <button type="button" class="p-2 text-gray-500 hover:text-gray-700 hover:bg-gray-100 rounded-full transition-colors focus:outline-none" data-action="click->dropdown#toggle" title="Opciones">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2z"></path>
        </svg>
      </button>
      <div data-dropdown-target="menu" class="hidden absolute right-0 mt-2 w-56 rounded-xl shadow-xl bg-white border border-gray-100 z-50 origin-top-right ring-1 ring-black ring-opacity-5 focus:outline-none">
        <div class="py-2" role="menu">
          <%= link_to voyage_path(voyage), class: "flex items-center gap-3 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 hover:text-gray-900 transition-colors", role: "menuitem" do %>
            <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
            </svg>
            Ver detalles
          <% end %>

          <%= link_to edit_voyage_path(voyage), class: "flex items-center gap-3 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 hover:text-gray-900 transition-colors", role: "menuitem" do %>
            <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
            </svg>
            Editar
          <% end %>

          <div class="border-t border-gray-100 my-1"></div>
          <%= button_to voyage_path(voyage), method: :delete, data: { turbo_confirm: "¿Eliminar este viaje? Se debe mover primero los contenedores asociados." }, class: "group flex w-full items-center gap-3 px-4 py-2.5 text-sm text-red-600 hover:bg-red-50 hover:text-red-900 transition-colors", role: "menuitem" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
            </svg>
            Eliminar
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <div class="mt-3 grid grid-cols-2 gap-2 text-xs">
    <div class="rounded-lg border border-blue-100 bg-blue-50 px-2.5 py-2 text-blue-700">
      <p class="font-semibold">ETA</p>
      <p><%= voyage.eta ? l(voyage.eta, format: :long) : "-" %></p>
    </div>
    <div class="rounded-lg border border-slate-200 bg-slate-50 px-2.5 py-2 text-slate-700">
      <p class="font-semibold">ATA</p>
      <p><%= voyage.ata ? l(voyage.ata, format: :long) : "-" %></p>
    </div>
  </div>
</div>
