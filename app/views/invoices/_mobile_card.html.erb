<% can_view_details = policy(invoice).show? %>
<% can_attach_payment_evidence = policy(invoice).attach_payment_evidence? %>
<% payment_evidence_new_path = if current_user.consolidator? && current_user.entity&.role_consolidator?
  new_consolidators_payment_evidence_path(invoice_ids: [ invoice.id ])
else
  new_customs_agents_payment_evidence_path(invoice_id: invoice.id)
end %>
<% serie = invoice.provider_response.to_h["serie"].presence || invoice.payload_snapshot.to_h["serie"].presence %>
<% folio = invoice.provider_response.to_h["folio"].presence ||
           invoice.provider_response.to_h["noComprobante"].presence ||
           invoice.payload_snapshot.to_h["folio"].presence ||
           invoice.payload_snapshot.to_h["noComprobante"].presence ||
           invoice.provider_response.to_h["numeroComprobante"].presence ||
           invoice.payload_snapshot.to_h["numeroComprobante"].presence ||
           invoice.facturador_comprobante_id&.to_s %>
<% status_for_display = invoice.effective_status %>
<% issue_status_badge_class = case status_for_display
  when "issued" then "bg-emerald-100 text-emerald-800 border-emerald-200"
  when "queued" then "bg-blue-100 text-blue-800 border-blue-200"
  when "failed" then "bg-rose-100 text-rose-800 border-rose-200"
  when "cancel_pending" then "bg-amber-100 text-amber-800 border-amber-200"
  when "cancelled" then "bg-slate-100 text-slate-800 border-slate-200"
  else "bg-gray-100 text-gray-700 border-gray-200"
end %>
<% payment_status_badge_class = case invoice.payment_status
  when "paid" then "bg-emerald-100 text-emerald-800 border-emerald-200"
  when "partial" then "bg-blue-100 text-blue-800 border-blue-200"
  else "bg-amber-100 text-amber-800 border-amber-200"
end %>

<div class="bg-white shadow-sm rounded-xl p-4 border border-gray-100">
  <div class="flex items-start justify-between gap-3">
    <div class="min-w-0">
      <p class="text-xs text-gray-500"><%= l(invoice.created_at, format: :short) %></p>
      <% if can_view_details %>
        <%= link_to(invoice_path(invoice), class: "inline-flex items-center mt-1 text-sm font-semibold text-indigo-700 hover:text-indigo-900") do %>
          <%= invoice.receiver_entity&.name || "Sin receptor" %>
        <% end %>
      <% else %>
        <p class="mt-1 text-sm font-semibold text-gray-900"><%= invoice.receiver_entity&.name || "Sin receptor" %></p>
      <% end %>
      <p class="mt-1 text-xs font-mono text-gray-600">
        <% if serie.present? || folio.present? %>
          <%= [serie, folio].compact.join("-") %>
        <% else %>
          Sin serie/folio
        <% end %>
      </p>
    </div>

    <div class="relative inline-block text-left" data-controller="dropdown">
      <button type="button" class="h-10 w-10 inline-flex items-center justify-center rounded-full text-slate-500 hover:text-slate-700 hover:bg-slate-100 transition-colors focus:outline-none focus:ring-2 focus:ring-indigo-500" data-action="click->dropdown#toggle" title="Opciones">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2z"></path>
        </svg>
      </button>

      <div data-dropdown-target="menu" class="hidden absolute right-0 mt-2 w-64 rounded-2xl border border-slate-200 bg-white shadow-[0_14px_40px_rgba(15,23,42,0.16)] z-50 origin-top-right">
        <div class="py-2" role="menu">
          <% if can_view_details %>
            <%= link_to invoice_path(invoice), class: "flex items-center gap-3 px-4 py-2.5 text-sm text-slate-700 hover:bg-slate-50 hover:text-slate-900 transition-colors", role: "menuitem" do %>
              <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
              </svg>
              Ver detalle
            <% end %>
          <% end %>

          <% if can_attach_payment_evidence %>
            <%= link_to payment_evidence_new_path, class: "flex items-center gap-3 px-4 py-2.5 text-sm text-indigo-700 hover:bg-indigo-50 hover:text-indigo-900 transition-colors", role: "menuitem", data: { turbo_frame: "payment_evidence_modal" } do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6M7 4h7l5 5v11a2 2 0 01-2 2H7a2 2 0 01-2-2V6a2 2 0 012-2z" />
              </svg>
              Adjuntar comprobante de pago
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <div class="mt-3 flex flex-wrap items-center gap-2">
    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold border <%= issue_status_badge_class %>">
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5-2a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <%= t("activerecord.attributes.invoice.statuses.#{status_for_display}", default: status_for_display.humanize) %>
    </span>

    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold border <%= payment_status_badge_class %>">
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h5M5 6h14a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2z" />
      </svg>
      <%= invoice.payment_status_label %>
    </span>
  </div>

  <div class="mt-3 pt-3 border-t border-gray-100 flex items-center justify-between">
    <span class="text-xs text-gray-500">Saldo pendiente</span>
    <span class="text-sm font-semibold text-gray-900"><%= number_to_currency(invoice.outstanding_amount || 0) %></span>
  </div>
</div>
