<%
  serie = @invoice.provider_response.to_h["serie"].presence || @invoice.payload_snapshot.to_h["serie"].presence
  folio = @invoice.provider_response.to_h["folio"].presence ||
          @invoice.provider_response.to_h["noComprobante"].presence ||
          @invoice.payload_snapshot.to_h["folio"].presence ||
          @invoice.payload_snapshot.to_h["noComprobante"].presence ||
          @invoice.provider_response.to_h["numeroComprobante"].presence ||
          @invoice.payload_snapshot.to_h["numeroComprobante"].presence ||
          @invoice.facturador_comprobante_id&.to_s

  invoice_heading = if serie.present? && folio.present?
    "#{serie} #{folio}"
  elsif folio.present?
    folio.to_s
  elsif serie.present?
    serie.to_s
  else
    "##{@invoice.id}"
  end
%>
<% content_for :title, invoice_heading %>
<% can_sync_documents = policy(@invoice).sync_documents? %>
<% can_sync_files = policy(@invoice).sync_files? %>
<% can_cancel_invoice = policy(@invoice).cancel? %>
<% can_send_email = policy(@invoice).send_email? %>
<% can_retry_issue = policy(@invoice).retry_issue? %>
<% can_manage_payments = policy(@invoice).register_payment? %>
<% can_destroy_invoice = policy(@invoice).destroy? %>
<% can_sync_files_now = @invoice.sat_uuid.present? && @invoice.status.in?(["issued", "cancel_pending", "cancelled"]) %>
<% files_already_synced = @invoice.xml_file.attached? && @invoice.pdf_file.attached? %>

<div class="w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 sm:py-6 lg:py-8" data-controller="modal">
  <div class="mb-4 sm:mb-6">
    <%= link_to invoices_path, class: "cursor-pointer inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium text-indigo-700 hover:bg-indigo-50 transition-all duration-200 group" do %>
      <svg class="w-5 h-5 transition-transform group-hover:-translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/>
      </svg>
      <span>Volver a facturas</span>
    <% end %>
  </div>

  <div class="bg-white shadow-md rounded-2xl overflow-hidden mb-6">
    <div class="px-4 sm:px-6 lg:px-8 py-5 sm:py-6 border-b border-gray-100 bg-gradient-to-r from-gray-50 to-white">
      <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
        <div class="flex-1">
          <div class="flex items-center gap-3 mb-2">
            <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-gradient-to-br from-indigo-500 to-indigo-600 shadow-lg">
              <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6M7 4h10a2 2 0 012 2v12a2 2 0 01-2 2H7a2 2 0 01-2-2V6a2 2 0 012-2z"/>
              </svg>
            </div>
            <div>
              <h1 class="text-2xl sm:text-3xl font-bold text-gray-900"><%= invoice_heading %></h1>
              <p class="text-sm text-gray-500">UUID: <span class="font-mono"><%= @invoice.sat_uuid.presence || "-" %></span></p>
            </div>
          </div>
        </div>

        <div class="flex flex-col gap-2 sm:items-end">
          <div class="flex items-center gap-2 flex-wrap sm:justify-end">
            <% status_for_display = @invoice.effective_status %>
            <% badge_class = case status_for_display
              when 'issued' then 'bg-emerald-100 text-emerald-800 border-emerald-200'
              when 'queued' then 'bg-blue-100 text-blue-800 border-blue-200'
              when 'failed' then 'bg-red-100 text-red-800 border-red-200'
              when 'cancel_pending' then 'bg-amber-100 text-amber-800 border-amber-200'
              when 'cancelled' then 'bg-slate-100 text-slate-800 border-slate-200'
              else 'bg-gray-100 text-gray-700 border-gray-200'
            end %>
            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold border <%= badge_class %>"><%= t("activerecord.attributes.invoice.statuses.#{status_for_display}", default: status_for_display.humanize) %></span>

            <% if can_sync_files_now %>
              <% if can_sync_documents %>
                <% sync_button_label = files_already_synced ? "Re-sincronizar XML/PDF" : "Sincronizar XML/PDF" %>
                <%= button_to sync_button_label, sync_documents_invoice_path(@invoice), method: :post, class: "cursor-pointer inline-flex items-center px-3 py-1.5 rounded-md text-xs font-semibold bg-indigo-50 text-indigo-700 border border-indigo-200 hover:bg-indigo-100" %>
              <% elsif can_sync_files && !files_already_synced %>
                <%= button_to "Sincronizar XML/PDF", sync_files_invoice_path(@invoice), method: :post, class: "cursor-pointer inline-flex items-center px-3 py-1.5 rounded-md text-xs font-semibold bg-indigo-50 text-indigo-700 border border-indigo-200 hover:bg-indigo-100" %>
              <% end %>
            <% end %>

            <% if can_cancel_invoice && @invoice.cancel_retryable? %>
              <% cancel_button_label = @invoice.last_error_code.to_s.start_with?("FACTURADOR_CANCEL_") ? "Reintentar cancelación CFDI" : "Cancelar CFDI" %>
              <button type="button"
                      data-action="click->modal#open"
                      data-modal-id="invoice-cancel-modal"
                    class="cursor-pointer inline-flex items-center px-3 py-1.5 rounded-md text-xs font-semibold bg-red-50 text-red-700 border border-red-200 hover:bg-red-100">
                <%= cancel_button_label %>
              </button>
            <% end %>

            <% if can_send_email && @invoice.status.in?(["issued", "cancelled"]) && @invoice.sat_uuid.present? %>
              <%= button_to "Enviar CFDI por correo", send_email_invoice_path(@invoice), method: :post, class: "cursor-pointer inline-flex items-center px-3 py-1.5 rounded-md text-xs font-semibold bg-cyan-50 text-cyan-700 border border-cyan-200 hover:bg-cyan-100" %>
            <% end %>

            <% show_retry_issue = can_retry_issue && @invoice.failed? && @invoice.last_error_code.to_s.start_with?("FACTURADOR_ISSUE_") %>
            <% if show_retry_issue %>
              <%= button_to "Reintentar emisión CFDI", retry_issue_invoice_path(@invoice), method: :post, class: "cursor-pointer inline-flex items-center px-3 py-1.5 rounded-md text-xs font-semibold bg-blue-50 text-blue-700 border border-blue-200 hover:bg-blue-100" %>
            <% end %>

            <% if @invoice.xml_file.attached? %>
              <%= link_to "Descargar XML", rails_blob_path(@invoice.xml_file, disposition: "attachment"), class: "cursor-pointer inline-flex items-center px-3 py-1.5 rounded-md text-xs font-semibold bg-slate-50 text-slate-700 border border-slate-200 hover:bg-slate-100" %>
            <% end %>

            <% if @invoice.pdf_file.attached? %>
              <%= link_to "Descargar PDF", rails_blob_path(@invoice.pdf_file, disposition: "attachment"), class: "cursor-pointer inline-flex items-center px-3 py-1.5 rounded-md text-xs font-semibold bg-slate-50 text-slate-700 border border-slate-200 hover:bg-slate-100" %>
            <% end %>

            <% if can_destroy_invoice %>
              <% delete_confirm_message = if @invoice.kind == "pago"
                "Se eliminará este REP NO timbrado y se desvinculará de sus pagos relacionados para permitir su regeneración.\n\nEsta acción no cancela CFDI timbrados y no se puede deshacer.\n\n¿Deseas continuar?"
              else
                "Se eliminará esta factura NO timbrada junto con sus pagos relacionados.\n\nEsta acción no cancela CFDI timbrados y no se puede deshacer.\n\n¿Deseas continuar?"
              end %>
              <%= button_to invoice_path(@invoice),
                  method: :delete,
                  form: { data: { turbo_confirm: delete_confirm_message } },
                  class: "cursor-pointer inline-flex items-center px-3 py-1.5 rounded-md text-xs font-semibold bg-rose-50 text-rose-700 border border-rose-200 hover:bg-rose-100" do %>
                <span><%= @invoice.kind == "pago" ? "Eliminar REP no timbrado" : "Eliminar factura no timbrada" %></span>
              <% end %>
            <% end %>
          </div>

          <% if @invoice_hbl.present? || @invoice_agency.present? %>
            <div class="w-full mt-2.5 grid grid-cols-1 sm:grid-cols-2 gap-4 sm:max-w-xl sm:justify-items-end">
              <div class="w-full sm:max-w-[16rem]">
                <p class="text-xs uppercase tracking-wider text-gray-500">HBL</p>
                <p class="text-base font-bold text-gray-900"><%= @invoice_hbl.presence || "-" %></p>
              </div>
              <div class="w-full sm:max-w-[16rem]">
                <p class="text-xs uppercase tracking-wider text-gray-500">Agencia aduanal</p>
                <p class="text-base font-bold text-gray-900"><%= @invoice_agency.presence || "-" %></p>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <% show_processing_banner = @invoice.status == "queued" %>
    <% if show_processing_banner %>
      <div class="mx-4 sm:mx-6 lg:mx-8 mt-4 rounded-xl border border-blue-200 bg-blue-50 p-4">
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-blue-600 mt-0.5 animate-pulse" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6l4 2m6-2a10 10 0 11-20 0 10 10 0 0120 0z"/>
          </svg>
          <div>
            <p class="text-sm font-semibold text-blue-900">Emisión del CFDI en proceso</p>
            <p class="text-sm text-blue-800 mt-1">Esta vista se actualizará automáticamente. El envío de correo se procesa en segundo plano y no bloquea esta pantalla.</p>
          </div>
        </div>
      </div>
    <% end %>

    <% if params[:from_manual_create].present? || @invoice.status == "queued" %>
      <script>
        (function() {
          const currentUrl = new URL(window.location.href);
          if (currentUrl.searchParams.has('from_manual_create')) {
            currentUrl.searchParams.delete('from_manual_create');
            const query = currentUrl.searchParams.toString();
            const nextUrl = currentUrl.pathname + (query ? `?${query}` : '') + currentUrl.hash;
            window.history.replaceState({}, '', nextUrl);
          }

          if (<%= @invoice.status == "queued" ? "true" : "false" %>) {
            const refreshDelayMs = 7000;
            window.setTimeout(() => {
              if (document.visibilityState === 'visible') {
                window.location.reload();
              }
            }, refreshDelayMs);
          }
        })();
      </script>
    <% end %>

    <div class="p-4 sm:p-6 lg:p-8 grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4">
      <div class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <p class="text-xs text-gray-500 uppercase tracking-wider mb-1">Total</p>
        <p class="text-lg font-semibold text-gray-900"><%= number_to_currency(@invoice.total || 0) %></p>
      </div>
      <div class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <p class="text-xs text-gray-500 uppercase tracking-wider mb-1">Subtotal</p>
        <p class="text-lg font-semibold text-gray-900"><%= number_to_currency(@invoice.subtotal || 0) %></p>
      </div>
      <div class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <p class="text-xs text-gray-500 uppercase tracking-wider mb-1">Impuestos</p>
        <p class="text-lg font-semibold text-gray-900"><%= number_to_currency(@invoice.tax_total || 0) %></p>
      </div>
      <div class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <p class="text-xs text-gray-500 uppercase tracking-wider mb-1">Saldo pendiente</p>
        <p class="text-lg font-semibold text-gray-900"><%= number_to_currency(@invoice.outstanding_amount || 0) %></p>
      </div>
    </div>
  </div>

  <div class="space-y-6">
      <section class="bg-white shadow-sm rounded-xl p-5 border border-gray-100">
        <h2 class="text-lg font-bold text-gray-900 mb-4">Información fiscal</h2>

        <% payload = @invoice.payload_snapshot.to_h.deep_stringify_keys %>
        <% provider = @invoice.provider_response.to_h.deep_stringify_keys %>
        <% receptor = payload.fetch("receptor", {}).to_h %>
        <% conceptos = Array(payload["conceptos"]) %>
        <% payment_entries = Array(payload.dig("complemento", "complementoPago20", "pago")).map { |entry| entry.to_h.deep_stringify_keys } %>
        <% related_payment_documents = payment_entries.flat_map { |entry| Array(entry["doctoRelacionado"]).map { |doc| doc.to_h.deep_stringify_keys } } %>
        <% related_uuids = related_payment_documents.map { |doc| doc["idDocumento"].to_s }.reject(&:blank?).uniq %>
        <% source_invoices_by_uuid = Invoice.includes(:receiver_entity).where(sat_uuid: related_uuids).index_by(&:sat_uuid) %>
        <% uso_cfdi_code = receptor["usoCFDI"].presence %>
        <% regimen_receptor_code = receptor["regimenFiscalReceptor"].presence %>
        <% forma_pago_code = payload["formaPago"].presence %>
        <% metodo_pago_code = payload["metodoPago"].presence %>
        <% uso_cfdi_label = uso_cfdi_code && FiscalProfile::USOS_CFDI[uso_cfdi_code] %>
        <% regimen_receptor_label = regimen_receptor_code && FiscalProfile::REGIMENES[regimen_receptor_code] %>
        <% forma_pago_label = forma_pago_code && FiscalProfile::FORMAS_PAGO[forma_pago_code] %>
        <% metodo_pago_label = metodo_pago_code && FiscalProfile::METODOS_PAGO[metodo_pago_code] %>
        <% sat_clave_prod_serv_labels = {
             "80151600" => "Servicios de comercio internacional",
             "01010101" => "No existe en el catálogo"
           } %>
        <% sat_clave_unidad_labels = {
             "E48" => "Unidad de servicio",
             "H87" => "Pieza"
           } %>

        <div class="grid grid-cols-1 gap-4 text-sm">
          <div class="bg-gray-50 rounded-xl p-4 border border-gray-200">
            <h3 class="text-sm font-bold text-gray-900 mb-3">Receptor</h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
              <div>

                <p class="text-gray-500">Nombre</p>
                <p class="font-semibold text-gray-900"><%= receptor["nombre"].presence || @invoice.receiver_entity&.name || '-' %></p>
              </div>
              <div>
                <p class="text-gray-500">RFC</p>
                <p class="font-semibold text-gray-900 font-mono"><%= receptor["rfc"].presence || '-' %></p>
              </div>
              <div>
                <p class="text-gray-500">Uso CFDI</p>
                <p class="font-semibold text-gray-900"><%= uso_cfdi_code ? [uso_cfdi_code, uso_cfdi_label].compact.join(' - ') : '-' %></p>
              </div>
              <div>
                <p class="text-gray-500">Régimen</p>
                <p class="font-semibold text-gray-900"><%= regimen_receptor_code ? [regimen_receptor_code, regimen_receptor_label].compact.join(' - ') : '-' %></p>
              </div>
              <div>
                <p class="text-gray-500">Domicilio fiscal</p>
                <p class="font-semibold text-gray-900"><%= receptor["domicilioFiscalReceptor"].presence || '-' %></p>
              </div>
            </div>
          </div>

          <div class="bg-gray-50 rounded-xl p-4 border border-gray-200">
            <h3 class="text-sm font-bold text-gray-900 mb-3">Datos del CFDI</h3>
            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-3">
              <div>
                <p class="text-gray-500">Serie / Folio</p>
                <p class="font-semibold text-gray-900 font-mono"><%= [serie, folio].compact_blank.join(' ') .presence || '-' %></p>
              </div>
              <div>
                <p class="text-gray-500">UUID</p>
                <p class="font-semibold text-gray-900 font-mono"><%= @invoice.sat_uuid.presence || '-' %></p>
              </div>
              <div>
                <p class="text-gray-500">Tipo comprobante</p>
                <p class="font-semibold text-gray-900"><%= payload["tipoDeComprobante"].presence || @invoice.kind.humanize %></p>
              </div>
              <div>
                <p class="text-gray-500">Versión / Moneda</p>
                <p class="font-semibold text-gray-900"><%= [payload["version"], payload["moneda"].presence || @invoice.currency].compact_blank.join(' / ') %></p>
              </div>
              <div>
                <p class="text-gray-500">Forma de pago</p>
                <p class="font-semibold text-gray-900"><%= forma_pago_code ? [forma_pago_code, forma_pago_label].compact.join(' - ') : '-' %></p>
              </div>
              <div>
                <p class="text-gray-500">Método de pago</p>
                <p class="font-semibold text-gray-900"><%= metodo_pago_code ? [metodo_pago_code, metodo_pago_label].compact.join(' - ') : '-' %></p>
              </div>
              <div>
                <p class="text-gray-500">Fecha emisión</p>
                <p class="font-semibold text-gray-900"><%= payload["fecha"].presence || (@invoice.issued_at ? l(@invoice.issued_at, format: :long) : '-') %></p>
              </div>
              <div>
                <p class="text-gray-500">Comprobante proveedor</p>
                <p class="font-semibold text-gray-900"><%= provider["idComprobante"].presence || @invoice.facturador_comprobante_id || '-' %></p>
              </div>
            </div>
          </div>

          <% if @invoice.kind == "pago" %>
            <div class="bg-gray-50 rounded-xl p-4 border border-gray-200">
              <h3 class="text-sm font-bold text-gray-900 mb-3">CFDIs incluidos en este REP</h3>

              <% if related_payment_documents.any? %>
                <div class="overflow-x-auto">
                  <table class="min-w-full divide-y divide-gray-200 text-sm">
                    <thead class="bg-white">
                      <tr>
                        <th class="px-3 py-2 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Serie</th>
                        <th class="px-3 py-2 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Folio</th>
                        <th class="px-3 py-2 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">RECEPTOR</th>
                        <th class="px-3 py-2 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">UUID</th>
                        <th class="px-3 py-2 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Total</th>
                        <th class="px-3 py-2 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Saldo</th>
                      </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100 bg-white">
                      <% related_payment_documents.each do |related_doc| %>
                        <% source_invoice = source_invoices_by_uuid[related_doc["idDocumento"].to_s] %>
                        <% source_provider = source_invoice&.provider_response.to_h.deep_stringify_keys || {} %>
                        <% source_snapshot = source_invoice&.payload_snapshot.to_h.deep_stringify_keys || {} %>
                        <% source_serie = source_provider["serie"].presence || source_snapshot["serie"].presence %>
                        <% source_folio = source_provider["folio"].presence || source_provider["noComprobante"].presence || source_provider["numeroComprobante"].presence || source_invoice&.facturador_comprobante_id&.to_s %>
                        <% row_serie = related_doc["serie"].presence || source_serie.presence || (source_provider["serie"].to_s.strip.casecmp("sin serie").zero? ? "Sin Serie" : nil) %>
                        <% row_folio = related_doc["folio"].presence || source_folio %>
                        <% row_receiver_name = source_invoice&.receiver_entity&.name.presence || source_snapshot.dig("receptor", "nombre").presence %>
                        <% row_saldo = related_doc["impSaldoInsoluto"].present? ? related_doc["impSaldoInsoluto"].to_d : source_invoice&.outstanding_amount %>
                        <tr>
                          <td class="px-3 py-2 text-gray-700"><%= row_serie.presence || '-' %></td>
                          <td class="px-3 py-2 text-gray-700"><%= row_folio.presence || '-' %></td>
                          <td class="px-3 py-2 text-gray-700" title="<%= row_receiver_name.presence || '' %>"><%= row_receiver_name.present? ? truncate(row_receiver_name, length: 38) : '-' %></td>
                          <td class="px-3 py-2 text-gray-900 font-mono">
                            <% if source_invoice.present? %>
                              <%= link_to related_doc["idDocumento"].presence || source_invoice.sat_uuid, invoice_path(source_invoice), class: "text-indigo-700 hover:text-indigo-900" %>
                            <% else %>
                              <%= related_doc["idDocumento"].presence || '-' %>
                            <% end %>
                          </td>
                          <td class="px-3 py-2 text-gray-700"><%= source_invoice.present? ? number_to_currency(source_invoice.total) : '-' %></td>
                          <td class="px-3 py-2 text-gray-700"><%= row_saldo.present? ? number_to_currency(row_saldo) : '-' %></td>
                        </tr>
                      <% end %>
                    </tbody>
                  </table>
                </div>
              <% else %>
                <p class="text-sm text-gray-500">No hay CFDIs relacionados registrados en el complemento de pago.</p>
              <% end %>
            </div>
          <% end %>

          <div class="bg-gray-50 rounded-xl p-4 border border-gray-200">
            <h3 class="text-sm font-bold text-gray-900 mb-3">Conceptos</h3>
            <% if conceptos.any? %>
              <div class="space-y-3 pr-1">
                <% conceptos.each_with_index do |concepto, idx| %>
                  <% item = concepto.to_h %>
                  <% clave_prod_serv_code = item["claveProdServ"].presence %>
                  <% clave_unidad_code = item["claveUnidad"].presence %>
                  <% clave_prod_serv_label = clave_prod_serv_code && sat_clave_prod_serv_labels[clave_prod_serv_code] %>
                  <% clave_unidad_label = clave_unidad_code && sat_clave_unidad_labels[clave_unidad_code] %>
                  <% traslados = Array(item.dig("impuestos", "traslados")) %>
                  <% concepto_importe = item["importe"].to_d %>
                  <% concepto_iva = traslados.sum { |traslado| traslado.to_h["importe"].to_d } %>
                  <% concepto_total = concepto_importe + concepto_iva %>
                  <div class="bg-white rounded-lg border border-gray-200 p-3">
                    <p class="text-xs text-gray-500 mb-2">Concepto <%= idx + 1 %></p>
                    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-3 items-start">
                      <div class="xl:col-span-2">
                        <p class="text-gray-500 text-xs">Descripción</p>
                        <p class="text-sm font-semibold text-gray-900"><%= item["descripcion"].presence || '-' %></p>
                      </div>
                      <div>
                        <p class="text-gray-500 text-xs">Prod/Serv</p>
                        <p class="text-sm font-semibold text-gray-900"><%= clave_prod_serv_code ? [clave_prod_serv_code, clave_prod_serv_label].compact.join(' - ') : '-' %></p>
                      </div>
                      <div>
                        <p class="text-gray-500 text-xs">Unidad</p>
                        <p class="text-sm font-semibold text-gray-900"><%= clave_unidad_code ? [clave_unidad_code, clave_unidad_label].compact.join(' - ') : '-' %></p>
                      </div>
                      <div>
                        <p class="text-gray-500 text-xs">Cantidad</p>
                        <p class="text-sm font-semibold text-gray-900"><%= item["cantidad"].presence || '-' %></p>
                      </div>
                      <div>
                        <p class="text-gray-500 text-xs">Importe</p>
                        <p class="text-sm font-semibold text-gray-900"><%= number_to_currency(concepto_importe) %></p>
                      </div>
                      <div>
                        <p class="text-gray-500 text-xs">IVA</p>
                        <p class="text-sm font-semibold text-gray-900"><%= number_to_currency(concepto_iva) %></p>
                      </div>
                      <div>
                        <p class="text-gray-500 text-xs">Total con IVA</p>
                        <p class="text-sm font-semibold text-gray-900"><%= number_to_currency(concepto_total) %></p>
                      </div>
                    </div>
                  </div>
                <% end %>
              </div>
            <% else %>
              <p class="text-sm text-gray-500">No hay conceptos registrados en el payload.</p>
            <% end %>
          </div>
        </div>

        <% cancel_error = @invoice.last_error_code.to_s.start_with?("FACTURADOR_CANCEL_") %>
        <% if @invoice.failed? && !cancel_error %>
          <div class="mt-4 p-3 rounded-lg bg-red-50 border border-red-200">
            <p class="text-xs text-red-600 uppercase tracking-wider">Error</p>
            <p class="text-sm font-semibold text-red-800"><%= @invoice.last_error_code.presence || '-' %></p>
            <p class="text-sm text-red-700 mt-1"><%= @invoice.last_error_message.presence || '-' %></p>
          </div>
        <% elsif @invoice.effectively_issued? && cancel_error %>
          <% last_cancel_failed_event = @invoice_events.find { |event| event.event_type == "cancel_failed" } %>
          <% diagnostics_payload = {
               invoice_id: @invoice.id,
               sat_uuid: @invoice.sat_uuid,
               status: @invoice.status,
               effective_status: @invoice.effective_status,
               last_error_code: @invoice.last_error_code,
               last_error_message: @invoice.last_error_message,
               last_cancel_failed_at: last_cancel_failed_event&.created_at,
               last_cancel_failed_error: last_cancel_failed_event&.provider_error_message,
               provider_context: last_cancel_failed_event&.response_payload&.dig("provider_context")
             }.to_json %>
          <div class="mt-4 p-3 rounded-lg bg-amber-50 border border-amber-200">
            <p class="text-xs text-amber-700 uppercase tracking-wider">Intento de cancelación fallido</p>
            <p class="text-sm font-semibold text-amber-900"><%= @invoice.last_error_code %></p>
            <p class="text-sm text-amber-800 mt-1"><%= @invoice.last_error_message.presence || "El PAC/SAT no confirmó la cancelación en el último intento." %></p>
            <textarea id="cancel-diagnostics-<%= @invoice.id %>" class="hidden"><%= diagnostics_payload %></textarea>
            <button type="button"
                  class="cursor-pointer mt-3 inline-flex items-center px-3 py-1.5 rounded-md text-xs font-semibold bg-amber-100 text-amber-900 border border-amber-300 hover:bg-amber-200"
                    onclick="const source = document.getElementById('cancel-diagnostics-<%= @invoice.id %>'); const text = source ? source.value : ''; if (navigator.clipboard && text) { navigator.clipboard.writeText(text).then(() => { const original = this.textContent; this.textContent = 'Diagnóstico copiado'; setTimeout(() => { this.textContent = original; }, 1500); }); }">
              Copiar diagnóstico
            </button>
          </div>
        <% end %>
      </section>

      <section id="payments-section" class="bg-white shadow-sm rounded-xl p-5 border border-gray-100">
        <h2 class="text-lg font-bold text-gray-900 mb-4">Pagos registrados</h2>

        <% if can_manage_payments && @invoice.effectively_issued? %>
          <% if @invoice.payment_registration_eligible? %>
            <div class="mb-5 rounded-2xl border border-indigo-100 bg-indigo-50/40 shadow-sm overflow-hidden">
              <div class="px-4 py-3 border-b border-indigo-100 bg-white/70 flex flex-col md:flex-row md:items-center md:justify-between gap-2">
                <div>
                  <p class="text-sm font-semibold text-gray-900">Registrar nuevo pago</p>
                  <p class="text-xs text-gray-500">Captura la información para registrar el pago y conciliar saldo.</p>
                  <% if @invoice.payment_method_code != FiscalProfile::METODO_PAGO_PPD %>
                    <p class="text-xs text-amber-700 mt-1">Esta factura es <%= @invoice.payment_method_code %>. Se registrará el pago sin emitir REP.</p>
                  <% end %>
                </div>
                <p class="text-xs text-indigo-700">Saldo actual: <span class="font-semibold"><%= number_to_currency(@invoice.outstanding_amount || 0) %></span></p>
              </div>

              <%= form_with url: register_payment_invoice_path(@invoice), method: :post, local: true, multipart: true, class: "p-4 grid grid-cols-1 md:grid-cols-2 xl:grid-cols-6 gap-3 items-end" do |f| %>
                <div>
                  <label class="block text-xs font-medium text-gray-700 mb-1">Monto</label>
                  <%= f.number_field :amount, name: "payment[amount]", step: "0.01", min: "0.01", required: true, placeholder: "0.00", class: "w-full h-11 text-sm rounded-xl border border-gray-300 bg-white px-3 shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500" %>
                </div>

                <div>
                  <label class="block text-xs font-medium text-gray-700 mb-1">Fecha pago</label>
                  <%= f.datetime_local_field :paid_at, name: "payment[paid_at]", required: true, class: "w-full h-11 text-sm rounded-xl border border-gray-300 bg-white px-3 shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500" %>
                </div>

                <div>
                  <label class="block text-xs font-medium text-gray-700 mb-1">Forma pago</label>
                  <%= f.select :payment_method,
                      FiscalProfile::FORMAS_PAGO.map { |code, label| ["#{code} - #{label}", code] },
                      { selected: "03" },
                      { name: "payment[payment_method]", class: "w-full h-11 text-sm rounded-xl border border-gray-300 bg-white px-3 shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500" } %>
                </div>

                <div>
                  <label class="block text-xs font-medium text-gray-700 mb-1">Referencia</label>
                  <%= f.text_field :reference, name: "payment[reference]", placeholder: "Referencia", class: "w-full h-11 text-sm rounded-xl border border-gray-300 bg-white px-3 shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500" %>
                </div>

                <div>
                  <label class="block text-xs font-medium text-gray-700 mb-1">Clave rastreo</label>
                  <%= f.text_field :tracking_key, name: "payment[tracking_key]", placeholder: "Clave rastreo", class: "w-full h-11 text-sm rounded-xl border border-gray-300 bg-white px-3 shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500" %>
                </div>

                <div>
                  <label class="block text-xs font-medium text-gray-700 mb-1">Notas</label>
                  <%= f.text_field :notes, name: "payment[notes]", placeholder: "Opcional", class: "w-full h-11 text-sm rounded-xl border border-gray-300 bg-white px-3 shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500" %>
                </div>

                <div class="md:col-span-2 xl:col-span-2">
                  <label class="block text-xs font-medium text-gray-700 mb-1">Comprobante (opcional)</label>
                  <%= f.file_field :receipt_file, name: "payment[receipt_file]", class: "w-full h-11 text-sm rounded-xl border border-gray-300 bg-white px-3 py-2 shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500" %>
                </div>

                <div class="md:col-span-2 xl:col-span-6 flex items-center justify-end pt-1">
                  <%= f.submit "Registrar pago", class: "cursor-pointer inline-flex items-center justify-center h-11 px-5 rounded-xl text-sm font-semibold bg-indigo-600 text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="mb-5 rounded-2xl border border-amber-200 bg-amber-50 shadow-sm overflow-hidden">
              <div class="px-4 py-3 border-b border-amber-200 bg-white/70 flex flex-col md:flex-row md:items-center md:justify-between gap-2">
                <div>
                  <p class="text-sm font-semibold text-amber-900">Registro de pago no disponible</p>
                  <p class="text-xs text-amber-800"><%= @invoice.payment_registration_ineligibility_reason %></p>
                </div>
                <p class="text-xs text-amber-800">Metodo de pago CFDI: <span class="font-semibold"><%= @invoice.payment_method_code %></span></p>
              </div>
            </div>
          <% end %>
        <% end %>

        <% if @invoice_payments.any? %>
          <div class="hidden lg:block overflow-x-auto lg:overflow-visible">
            <table class="min-w-full divide-y divide-gray-200 text-sm">
              <thead class="bg-gray-50">
                <tr>
                  <th class="px-3 py-2 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Fecha pago</th>
                  <th class="px-3 py-2 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Monto</th>
                  <th class="px-3 py-2 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Forma pago</th>
                  <th class="px-3 py-2 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Referencia</th>
                  <th class="px-3 py-2 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Estatus</th>
                  <th class="px-3 py-2 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Complemento</th>
                  <% if can_manage_payments %>
                    <th class="px-3 py-2 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Acciones</th>
                  <% end %>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100">
                <% @invoice_payments.each do |payment| %>
                  <tr>
                    <td class="px-3 py-2 text-gray-700"><%= l(payment.paid_at, format: :short) %></td>
                    <td class="px-3 py-2 font-semibold text-gray-900"><%= number_to_currency(payment.amount) %></td>
                    <td class="px-3 py-2 text-gray-700"><%= [payment.payment_method, FiscalProfile::FORMAS_PAGO[payment.payment_method]].compact.join(' - ') %></td>
                    <td class="px-3 py-2 text-gray-700"><%= payment.reference.presence || '-' %></td>
                    <td class="px-3 py-2 text-gray-700"><%= payment.status_label %></td>
                    <td class="px-3 py-2 text-gray-700">
                      <% if payment.complement_invoice.present? %>
                        <% rep_can_be_deleted = policy(payment.complement_invoice).destroy? %>
                        <div class="flex flex-col gap-1">
                          <%= link_to(payment.complement_invoice.sat_uuid.presence || "Factura ##{payment.complement_invoice.id}", invoice_path(payment.complement_invoice), class: "text-indigo-700 hover:text-indigo-900 text-xs font-mono") %>
                          <div class="flex items-center gap-1">
                            <% if payment.complement_invoice.xml_file.attached? %>
                              <%= link_to "XML", rails_blob_path(payment.complement_invoice.xml_file, disposition: "attachment"), class: "cursor-pointer inline-flex items-center px-2 py-0.5 rounded text-[10px] font-semibold bg-slate-50 text-slate-700 border border-slate-200 hover:bg-slate-100" %>
                            <% end %>
                            <% if payment.complement_invoice.pdf_file.attached? %>
                              <%= link_to "PDF", rails_blob_path(payment.complement_invoice.pdf_file, disposition: "attachment"), class: "cursor-pointer inline-flex items-center px-2 py-0.5 rounded text-[10px] font-semibold bg-slate-50 text-slate-700 border border-slate-200 hover:bg-slate-100" %>
                            <% end %>
                            <% if rep_can_be_deleted %>
                              <%= button_to invoice_path(payment.complement_invoice, return_to: invoice_path(@invoice, anchor: "payments-section")),
                                  method: :delete,
                                  form: { data: { turbo_confirm: "Se eliminará el REP no timbrado vinculado a este pago y el pago quedará listo para volver a emitir complemento.\n\nEsta acción no se puede deshacer.\n\n¿Deseas continuar?" } },
                                  class: "cursor-pointer inline-flex items-center px-2 py-0.5 rounded text-[10px] font-semibold bg-rose-50 text-rose-700 border border-rose-200 hover:bg-rose-100" do %>
                                <span>Eliminar REP no timbrado</span>
                              <% end %>
                            <% end %>
                          </div>
                        </div>
                      <% elsif payment.status == "complement_queued" %>
                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[11px] font-semibold bg-blue-100 text-blue-800">En cola</span>
                      <% elsif payment.status == "failed" %>
                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[11px] font-semibold bg-red-100 text-red-800">Falló</span>
                      <% else %>
                        -
                      <% end %>
                    </td>
                    <% if can_manage_payments %>
                      <td class="px-3 py-2 text-gray-700">
                        <div class="relative inline-block text-left" data-controller="dropdown">
                          <button type="button" class="cursor-pointer p-2 text-gray-500 hover:text-gray-700 hover:bg-gray-100 rounded-full transition-colors focus:outline-none" data-action="click->dropdown#toggle" title="Opciones">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2z"></path>
                            </svg>
                          </button>
                          <div data-dropdown-target="menu" class="hidden absolute right-0 bottom-full mb-2 w-48 rounded-xl shadow-xl bg-white border border-gray-100 z-[70] origin-bottom-right ring-1 ring-black ring-opacity-5 focus:outline-none">
                            <div class="py-2" role="menu">
                              <%= link_to invoice_invoice_payment_path(@invoice, payment), class: "cursor-pointer flex items-center gap-3 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 hover:text-gray-900 transition-colors", role: "menuitem" do %>
                                <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                </svg>
                                Ver
                              <% end %>

                              <% if payment.complement_invoice_id.blank? && payment.status.in?(["registered", "failed"]) %>
                                <%= link_to edit_invoice_invoice_payment_path(@invoice, payment), class: "cursor-pointer flex items-center gap-3 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 hover:text-gray-900 transition-colors", role: "menuitem" do %>
                                  <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                  </svg>
                                  Editar
                                <% end %>

                                <div class="border-t border-gray-100 my-1"></div>
                                <%= button_to invoice_invoice_payment_path(@invoice, payment), method: :delete,
                                    form: { data: { turbo_confirm: "¿Eliminar este pago?" } },
                                    class: "group flex w-full items-center gap-3 px-4 py-2.5 text-sm text-red-600 hover:bg-red-50 hover:text-red-900 transition-colors", role: "menuitem" do %>
                                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                  </svg>
                                  Eliminar
                                <% end %>
                              <% else %>
                                <div class="px-4 py-2 text-xs text-gray-500">Edición bloqueada</div>
                              <% end %>
                            </div>
                          </div>
                        </div>
                      </td>
                    <% end %>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>

          <div class="lg:hidden mt-4 space-y-3">
            <% @invoice_payments.each do |payment| %>
              <%= render "invoices/payment_mobile_card", invoice: @invoice, payment: payment, can_manage_payments: can_manage_payments %>
            <% end %>
          </div>
        <% else %>
          <p class="text-sm text-gray-500">No hay pagos registrados para esta factura.</p>
        <% end %>
      </section>

      <section class="bg-white shadow-sm rounded-xl p-5 border border-gray-100">
        <details>
          <summary class="cursor-pointer text-sm font-semibold text-gray-800">Eventos recientes (<%= @invoice_events.size %>)</summary>
          <% if @invoice_events.any? %>
            <div class="space-y-3 mt-3">
              <% @invoice_events.each do |event| %>
                <% event_type = event.event_type.to_s %>
                <% is_error_event = event_type.include?("failed") %>
                <% is_success_event = !is_error_event && event_type.match?(/(succeeded|success|sent|synced|issued|cancelled|registered|completed)\z/) %>
                <% actor = event.created_by %>
                <% actor_label = if actor.present?
                  if actor.respond_to?(:email) && actor.email.present?
                    actor.email
                  elsif actor.respond_to?(:name) && actor.name.present?
                    actor.name
                  else
                    [event.created_by_type, event.created_by_id].compact.join(" #")
                  end
                else
                  "Sistema"
                end %>
                <% actor_meta = if actor.respond_to?(:role_name)
                  actor.role_name.to_s.humanize
                elsif actor.present?
                  event.created_by_type.to_s
                end %>
                <% event_title_class = if is_error_event
                  "text-red-800"
                elsif is_success_event
                  "text-emerald-800"
                else
                  "text-gray-900"
                end %>
                <% event_message_class = if is_error_event
                  "text-red-600"
                elsif is_success_event
                  "text-emerald-700"
                else
                  "text-gray-600"
                end %>

                <div class="pb-3 border-b border-gray-100 last:border-0">
                  <p class="text-sm font-semibold <%= event_title_class %>"><%= event.event_type.humanize %></p>
                  <p class="text-xs text-gray-500 mt-0.5"><%= l(event.created_at, format: :short) %></p>
                  <p class="text-xs text-gray-500 mt-1">Actor: <span class="font-medium text-gray-700"><%= actor_label %></span><% if actor_meta.present? %> · <%= actor_meta %><% end %></p>
                  <% if event.provider_error_message.present? %>
                    <p class="text-xs mt-1 <%= event_message_class %>"><%= event.provider_error_message %></p>
                  <% end %>
                  <% if event.provider_status.present? %>
                    <p class="text-xs text-gray-500 mt-1">Subestatus: <%= event.provider_status %></p>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-sm text-gray-500 mt-3">Sin eventos registrados.</p>
          <% end %>
        </details>
      </section>

      <section class="bg-white shadow-sm rounded-xl p-5 border border-gray-100">
        <details>
          <summary class="cursor-pointer text-sm font-semibold text-gray-800">Payload de emisión</summary>
          <pre class="mt-3 p-3 text-xs text-gray-700 bg-gray-50 rounded-lg overflow-auto"><%= JSON.pretty_generate(@invoice.payload_snapshot || {}) %></pre>
        </details>
      </section>

      <section class="bg-white shadow-sm rounded-xl p-5 border border-gray-100">
        <details>
          <summary class="cursor-pointer text-sm font-semibold text-gray-800">Respuesta proveedor</summary>
          <pre class="mt-3 p-3 text-xs text-gray-700 bg-gray-50 rounded-lg overflow-auto"><%= JSON.pretty_generate(@invoice.provider_response || {}) %></pre>
        </details>
      </section>
    </div>
  </div>
</div>

<% if can_cancel_invoice && @invoice.cancel_retryable? %>
  <div id="invoice-cancel-modal" data-modal-target="modal" class="hidden fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full z-50" data-action="click->modal#closeOnBackdrop">
    <div class="relative top-20 mx-auto p-5 border w-full max-w-lg shadow-lg rounded-md bg-white">
      <div class="mt-2">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-lg font-semibold text-gray-900">Confirmar cancelación de CFDI</h3>
          <button type="button" data-action="click->modal#close" class="cursor-pointer text-gray-400 hover:text-gray-600">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>
        </div>

        <div class="rounded-lg border border-red-200 bg-red-50 p-4 text-sm text-red-800 space-y-2">
          <p class="font-semibold">Esta acción solicitará la cancelación del CFDI en PAC/SAT.</p>
          <p>Si el PAC no confirma de inmediato, la factura quedará en <span class="font-semibold">pendiente de cancelación</span> hasta que conciliación confirme el estado final.</p>
          <p>Motivo aplicado en esta fase: <span class="font-semibold">02 - Sin relación</span>.</p>
        </div>

        <div class="mt-5 flex justify-end gap-3">
          <button type="button" data-action="click->modal#close" class="cursor-pointer px-4 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 transition-colors">Cancelar</button>
              <%= button_to "Confirmar cancelación",
                cancel_invoice_path(@invoice),
                method: :patch,
                form: { data: { action: "submit->modal#closeAndSubmit" } },
                class: "px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors font-semibold" %>
        </div>
      </div>
    </div>
  </div>
<% end %>
