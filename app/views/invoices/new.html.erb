<% content_for :title, "Nuevo CFDI" %>
<% content_for :head do %>
  <meta name="turbo-cache-control" content="no-cache">
<% end %>
<% manual_form_values = @manual_form_values || {} %>
<% manual_line_items_prefill = @manual_line_items_prefill || [] %>
<% service_catalog_lookup = @service_catalogs_for_manual.each_with_object({}) do |catalog, memo|
  memo[catalog.id.to_s] = {
    "label" => catalog.display_name,
    "name" => catalog.name,
    "price" => catalog.amount.to_s
  }
end %>
<%
  selected_customs_agent = @customs_agents_for_manual.find do |agent|
    agent.id.to_s == manual_form_values["customs_agent_id"].to_s
  end

  selected_receiver = (@receiver_clients + @receiver_consolidators).find do |entity|
    entity.id.to_s == manual_form_values["receiver_entity_id"].to_s
  end
%>

<div class="w-full px-4 sm:px-6 lg:px-8 py-6 sm:py-8">
  <div class="mb-6">
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">Nuevo CFDI</h1>
    <p class="text-sm text-gray-500 mt-1">Crea y emite un CFDI manual con uno o varios conceptos.</p>
  </div>

  <% if flash.now[:alert].present? || flash[:alert].present? %>
    <div class="mb-4 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800" data-testid="manual-cfdi-alert">
      <%= flash.now[:alert].presence || flash[:alert] %>
    </div>
  <% end %>

  <%= form_with url: invoices_path, method: :post, scope: :manual_invoice, class: "space-y-6", id: "manual-cfdi-form", data: { turbo: false } do |f| %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5 space-y-4">
      <h2 class="text-sm font-semibold text-gray-800 uppercase tracking-wider">Datos Generales</h2>

      <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
        <div>
          <%= f.label :receiver_kind, "Tipo de receptor", class: "block text-xs font-medium text-gray-600 mb-1" %>
          <%= f.select :receiver_kind,
            options_for_select([["Cliente", "client"], ["Consolidador", "consolidator"]], @selected_receiver_kind),
            {},
            class: "w-full px-3 py-2.5 border border-gray-300 rounded-lg",
            id: "manual_receiver_kind" %>
        </div>

        <div>
          <%= f.label :customs_agent_id, "Agencia aduanal (opcional)", class: "block text-xs font-medium text-gray-600 mb-1" %>
          <div
            id="manual_customs_agent_autocomplete"
            data-controller="catalog-autocomplete"
            data-catalog-autocomplete-url-value="<%= manual_customs_agents_search_invoices_path %>"
            data-catalog-autocomplete-min-chars-value="2"
            data-catalog-autocomplete-debounce-value="300"
            class="relative"
          >
            <%= f.hidden_field :customs_agent_id,
              id: "manual_customs_agent_id",
              value: manual_form_values["customs_agent_id"],
              data: { catalog_autocomplete_target: "hiddenInput" } %>

            <%= text_field_tag :manual_customs_agent_search,
              selected_customs_agent&.name,
              id: "manual_customs_agent_search",
              autocomplete: "off",
              placeholder: "Sin agencia (opcional)",
              class: "w-full px-3 py-2.5 border border-gray-300 rounded-lg",
              data: {
                catalog_autocomplete_target: "input",
                action: "input->catalog-autocomplete#onInput keydown->catalog-autocomplete#onKeydown focus->catalog-autocomplete#onFocus blur->catalog-autocomplete#onBlur"
              } %>

            <div id="manual_customs_agent_status" data-catalog-autocomplete-target="status" class="mt-1 text-xs text-gray-500"></div>
            <div data-catalog-autocomplete-target="results" class="absolute z-30 mt-2 hidden w-full rounded-lg border border-gray-200 bg-white shadow-lg max-h-72 overflow-auto"></div>
          </div>

          <noscript>
            <%= f.select :customs_agent_id,
              options_for_select([["Sin agencia", ""]] + @customs_agents_for_manual.map { |agent| [agent.name, agent.id] }, manual_form_values["customs_agent_id"]),
              {},
              class: "w-full px-3 py-2.5 border border-gray-300 rounded-lg",
              id: "manual_customs_agent_id_noscript" %>
          </noscript>
        </div>

        <div>
          <%= f.label :receiver_entity_id, "Receptor", class: "block text-xs font-medium text-gray-600 mb-1" %>
          <div
            id="manual_receiver_autocomplete"
            data-controller="catalog-autocomplete"
            data-base-url="<%= manual_receivers_search_invoices_path %>"
            data-catalog-autocomplete-url-value="<%= manual_receivers_search_invoices_path(receiver_kind: @selected_receiver_kind) %>"
            data-catalog-autocomplete-min-chars-value="2"
            data-catalog-autocomplete-debounce-value="300"
            data-catalog-autocomplete-depends-on-field-value="manual_customs_agent_id"
            data-catalog-autocomplete-depends-on-param-value="customs_agent_id"
            class="relative"
          >
            <%= f.hidden_field :receiver_entity_id,
              id: "manual_receiver_entity_id",
              value: manual_form_values["receiver_entity_id"],
              data: { catalog_autocomplete_target: "hiddenInput" } %>

            <%= text_field_tag :manual_receiver_entity_search,
              selected_receiver&.name,
              id: "manual_receiver_entity_search",
              autocomplete: "off",
              placeholder: "Escribe para buscar receptor",
              required: true,
              class: "w-full px-3 py-2.5 border border-gray-300 rounded-lg",
              data: {
                catalog_autocomplete_target: "input",
                action: "input->catalog-autocomplete#onInput keydown->catalog-autocomplete#onKeydown focus->catalog-autocomplete#onFocus blur->catalog-autocomplete#onBlur"
              } %>

            <div id="manual_receiver_status" data-catalog-autocomplete-target="status" class="mt-1 text-xs text-gray-500"></div>
            <div data-catalog-autocomplete-target="results" class="absolute z-30 mt-2 hidden w-full rounded-lg border border-gray-200 bg-white shadow-lg max-h-72 overflow-auto"></div>
          </div>

          <noscript>
            <% receiver_options =
              @receiver_clients.map { |entity| [entity.name, entity.id, { "data-kind": "client", "data-customs-agent-id": entity.customs_agent_id }] } +
              @receiver_consolidators.map { |entity| [entity.name, entity.id, { "data-kind": "consolidator", "data-customs-agent-id": "" }] } %>
            <%= f.select :receiver_entity_id,
              options_for_select(receiver_options, manual_form_values["receiver_entity_id"]),
              { include_blank: "Seleccionar receptor" },
              class: "w-full px-3 py-2.5 border border-gray-300 rounded-lg",
              required: true,
              id: "manual_receiver_entity_id_noscript" %>
          </noscript>
        </div>

        <div>
          <%= f.label :serie, "Serie", class: "block text-xs font-medium text-gray-600 mb-1" %>
          <%= f.select :serie,
            options_for_select(@manual_series_options || [], manual_form_values["serie"]),
            { include_blank: "Seleccionar serie" },
            class: "w-full px-3 py-2.5 border border-gray-300 rounded-lg",
            required: true,
            id: "manual_serie" %>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-sm font-semibold text-gray-800 uppercase tracking-wider">Conceptos</h2>
        <button type="button" id="add-manual-line-item" class="cursor-pointer px-3 py-2 text-sm font-semibold text-white bg-indigo-600 rounded-lg hover:bg-indigo-700">Agregar concepto</button>
      </div>

      <div id="manual-line-items" class="space-y-3"></div>

      <template id="manual-line-item-template">
        <div class="manual-line-item border border-gray-200 rounded-lg p-3">
          <div class="grid grid-cols-1 md:grid-cols-5 gap-3">
            <div class="md:col-span-2">
              <label class="block text-xs font-medium text-gray-600 mb-1">Concepto (catálogo)</label>
              <div
                data-controller="catalog-autocomplete"
                data-catalog-autocomplete-url-value="<%= manual_services_search_invoices_path %>"
                data-catalog-autocomplete-min-chars-value="2"
                data-catalog-autocomplete-debounce-value="300"
                class="relative"
              >
                <input type="hidden" name="manual_invoice[line_items][][service_catalog_id]" class="service-catalog-hidden" data-catalog-autocomplete-target="hiddenInput">

                <input
                  type="text"
                  autocomplete="off"
                  placeholder="Escribe para buscar concepto"
                  class="w-full px-3 py-2.5 border border-gray-300 rounded-lg service-catalog-search"
                  data-catalog-autocomplete-target="input"
                  data-action="input->catalog-autocomplete#onInput keydown->catalog-autocomplete#onKeydown focus->catalog-autocomplete#onFocus blur->catalog-autocomplete#onBlur"
                  required
                >

                <div data-catalog-autocomplete-target="status" class="mt-1 text-xs text-gray-500"></div>
                <div data-catalog-autocomplete-target="results" class="absolute z-30 mt-2 hidden w-full rounded-lg border border-gray-200 bg-white shadow-lg max-h-72 overflow-auto"></div>
              </div>

              <noscript>
                <select name="manual_invoice[line_items][][service_catalog_id]" class="w-full px-3 py-2.5 border border-gray-300 rounded-lg" required>
                  <option value="">Seleccionar concepto</option>
                  <% @service_catalogs_for_manual.each do |catalog| %>
                    <option value="<%= catalog.id %>" data-name="<%= catalog.name %>" data-price="<%= catalog.amount %>"><%= catalog.display_name %></option>
                  <% end %>
                </select>
              </noscript>
            </div>

            <div>
              <label class="block text-xs font-medium text-gray-600 mb-1">Cantidad</label>
              <input type="number" step="1" min="1" name="manual_invoice[line_items][][quantity]" value="1" class="w-full px-3 py-2.5 border border-gray-300 rounded-lg line-qty" required>
            </div>

            <div>
              <label class="block text-xs font-medium text-gray-600 mb-1">Precio unitario</label>
              <input type="number" step="0.01" min="0" name="manual_invoice[line_items][][unit_price]" value="0" class="w-full px-3 py-2.5 border border-gray-300 rounded-lg line-price" required>
            </div>

            <div class="flex items-end">
              <button type="button" class="remove-manual-line-item cursor-pointer w-full px-3 py-2.5 text-sm font-semibold text-red-700 bg-red-50 border border-red-200 rounded-lg hover:bg-red-100">Quitar</button>
            </div>
          </div>

          <div class="mt-3">
            <label class="block text-xs font-medium text-gray-600 mb-1">Descripción (editable)</label>
            <input type="text" name="manual_invoice[line_items][][description]" class="w-full px-3 py-2.5 border border-gray-300 rounded-lg line-description" placeholder="Descripción del concepto" required>
          </div>
        </div>
      </template>
    </div>

    <div class="flex items-center gap-3">
      <%= f.submit "Generar CFDI",
        id: "manual-cfdi-submit",
        data: { loading_text: "Generando CFDI..." },
        class: "cursor-pointer px-4 py-2.5 bg-emerald-600 hover:bg-emerald-700 text-white rounded-lg text-sm font-semibold inline-flex items-center gap-2" %>
      <%= link_to "Cancelar", invoices_path, class: "cursor-pointer px-4 py-2.5 bg-gray-100 hover:bg-gray-200 text-gray-700 rounded-lg text-sm font-medium" %>
    </div>
  <% end %>
</div>

<div id="manual-cfdi-processing-overlay" class="hidden fixed inset-0 z-[100] bg-slate-950/55 backdrop-blur-[1px]">
  <div class="h-full w-full flex items-center justify-center px-4">
    <div class="w-full max-w-md rounded-2xl border border-slate-200 bg-white p-6 shadow-2xl">
      <div class="flex items-center gap-3">
        <svg class="w-6 h-6 text-indigo-600 animate-spin" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"></path>
        </svg>
        <div>
          <p class="text-sm font-semibold text-slate-900">Estamos generando tu CFDI</p>
          <p class="text-xs text-slate-600 mt-1">No cierres esta ventana, estamos procesando tu solicitud.</p>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  (function() {
    const initManualCfdiForm = () => {
    const form = document.getElementById('manual-cfdi-form');
    if (!form || form.dataset.manualCfdiReady === 'true') return;
    form.dataset.manualCfdiReady = 'true';

    const receiverKind = document.getElementById('manual_receiver_kind');
    const customsAgent = document.getElementById('manual_customs_agent_id');
    const customsAgentNoscript = document.getElementById('manual_customs_agent_id_noscript');
    const receiverEntityHidden = document.getElementById('manual_receiver_entity_id');
    const receiverEntitySearch = document.getElementById('manual_receiver_entity_search');
    const receiverEntityNoscript = document.getElementById('manual_receiver_entity_id_noscript');
    const receiverAutocomplete = document.getElementById('manual_receiver_autocomplete');

    const lineItems = document.getElementById('manual-line-items');
    const addButton = document.getElementById('add-manual-line-item');
    const template = document.getElementById('manual-line-item-template');
    const submitButton = document.getElementById('manual-cfdi-submit');
    const overlay = document.getElementById('manual-cfdi-processing-overlay');
    const prefilledLineItems = <%= raw(manual_line_items_prefill.to_json) %>;
    const serviceCatalogLookup = <%= raw(service_catalog_lookup.to_json) %>;

    // In some browsers/navigation states, noscript fallbacks can leak into validation.
    // Disable them when JS is running so they never block submit.
    if (customsAgentNoscript) {
      customsAgentNoscript.disabled = true;
      customsAgentNoscript.required = false;
    }
    if (receiverEntityNoscript) {
      receiverEntityNoscript.disabled = true;
      receiverEntityNoscript.required = false;
    }

    const enterSubmittingState = () => {
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }
      if (overlay) overlay.classList.remove('hidden');
      form.setAttribute('aria-busy', 'true');

      if (submitButton) {
        submitButton.disabled = true;
        submitButton.classList.add('opacity-75', 'cursor-not-allowed');
        submitButton.innerHTML = `
          <svg class="w-4 h-4 animate-spin" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"></path>
          </svg>
          ${submitButton.dataset.loadingText || 'Procesando...'}
        `;
      }
    };

    const leaveSubmittingState = () => {
      if (overlay) overlay.classList.add('hidden');
      form.removeAttribute('aria-busy');
      if (submitButton) {
        submitButton.disabled = false;
        submitButton.classList.remove('opacity-75', 'cursor-not-allowed');
        submitButton.textContent = 'Generar CFDI';
      }
    };

    const prepareForTurboCache = () => {
      leaveSubmittingState();
      form.dataset.manualCfdiReady = 'false';
    };

    const preventEnterImplicitSubmit = (event) => {
      if (event.key !== 'Enter') return;

      const target = event.target;
      if (!target) return;

      const tagName = (target.tagName || '').toLowerCase();
      const isTextarea = tagName === 'textarea';
      const isSubmitButton = target === submitButton;

      if (isTextarea || isSubmitButton) return;

      event.preventDefault();
    };

    const clearReceiverSelection = () => {
      if (receiverEntityHidden) receiverEntityHidden.value = '';
      if (receiverEntitySearch) receiverEntitySearch.value = '';
      if (receiverAutocomplete) {
        const statusNode = receiverAutocomplete.querySelector('#manual_receiver_status');
        const resultsNode = receiverAutocomplete.querySelector('[data-catalog-autocomplete-target="results"]');
        if (statusNode) statusNode.textContent = '';
        if (resultsNode) {
          resultsNode.classList.add('hidden');
          resultsNode.innerHTML = '';
        }
      }
    };

    const updateReceiverAutocompleteUrl = () => {
      if (!receiverAutocomplete) return;
      const baseUrl = receiverAutocomplete.dataset.baseUrl;
      if (!baseUrl) return;

      const url = new URL(baseUrl, window.location.origin);
      url.searchParams.set('receiver_kind', receiverKind.value || 'client');
      receiverAutocomplete.dataset.catalogAutocompleteUrlValue = `${url.pathname}?${url.searchParams.toString()}`;
    };

    const attachLineItemEvents = (lineItem) => {
      const serviceCatalogHidden = lineItem.querySelector('.service-catalog-hidden');
      const serviceCatalogSearch = lineItem.querySelector('.service-catalog-search');
      const description = lineItem.querySelector('.line-description');
      const price = lineItem.querySelector('.line-price');
      const removeBtn = lineItem.querySelector('.remove-manual-line-item');

      const applyServiceSelection = () => {
        if (!serviceCatalogHidden.value) {
          description.value = '';
          price.value = '0';
          serviceCatalogSearch.setCustomValidity('Selecciona un concepto del catalogo.');
          return;
        }

        serviceCatalogSearch.setCustomValidity('');
        description.value = serviceCatalogHidden.dataset.serviceName || '';
        price.value = serviceCatalogHidden.dataset.servicePrice || '0';
      };

      serviceCatalogHidden.addEventListener('change', applyServiceSelection);
      serviceCatalogSearch.addEventListener('input', () => {
        if (serviceCatalogHidden.value) return;
        serviceCatalogSearch.setCustomValidity('Selecciona un concepto del catalogo.');
      });

      removeBtn.addEventListener('click', () => {
        lineItem.remove();
      });
    };

    const addLineItem = (prefill = {}) => {
      const fragment = template.content.cloneNode(true);
      const lineItem = fragment.querySelector('.manual-line-item');

      // Prevent noscript fallback controls from participating in validation
      // when JS is active; otherwise hidden required selects can block submit.
      const noscriptServiceSelects = lineItem.querySelectorAll('select[name="manual_invoice[line_items][][service_catalog_id]"]');
      noscriptServiceSelects.forEach((select) => {
        select.disabled = true;
        select.required = false;
        select.removeAttribute('name');
      });

      attachLineItemEvents(lineItem);

      const serviceCatalogHidden = lineItem.querySelector('.service-catalog-hidden');
      const serviceCatalogSearch = lineItem.querySelector('.service-catalog-search');
      const qty = lineItem.querySelector('.line-qty');
      const price = lineItem.querySelector('.line-price');
      const description = lineItem.querySelector('.line-description');

      if (prefill.service_catalog_id) {
        const selectedServiceId = String(prefill.service_catalog_id);
        const selectedService = serviceCatalogLookup[selectedServiceId];
        serviceCatalogHidden.value = selectedServiceId;

        if (selectedService) {
          serviceCatalogSearch.value = selectedService.label || '';
          serviceCatalogHidden.dataset.serviceName = selectedService.name || '';
          serviceCatalogHidden.dataset.servicePrice = selectedService.price || '0';

          if (!prefill.description) description.value = selectedService.name || '';
          if (!prefill.unit_price) price.value = selectedService.price || '0';
        }
      }
      if (prefill.quantity) qty.value = String(prefill.quantity);
      if (prefill.unit_price) price.value = String(prefill.unit_price);
      if (prefill.description) description.value = String(prefill.description);

      lineItems.appendChild(fragment);
    };

    receiverKind?.addEventListener('change', () => {
      updateReceiverAutocompleteUrl();
      clearReceiverSelection();
    });
    customsAgent?.addEventListener('change', () => {
      if ((receiverKind?.value || 'client') === 'client') {
        clearReceiverSelection();
      }
    });
    addButton?.addEventListener('click', addLineItem);
    form.addEventListener('keydown', preventEnterImplicitSubmit);

    form.addEventListener('submit', enterSubmittingState);
    form.addEventListener('turbo:submit-start', enterSubmittingState);
    form.addEventListener('turbo:submit-end', (event) => {
      if (event.detail && event.detail.success) return;
      leaveSubmittingState();
    });
    document.addEventListener('turbo:before-cache', prepareForTurboCache, { once: true });

    if (lineItems) {
      if (Array.isArray(prefilledLineItems) && prefilledLineItems.length > 0) {
        prefilledLineItems.forEach((item) => addLineItem(item));
      } else {
        addLineItem();
      }
    }
    updateReceiverAutocompleteUrl();

    };

    document.addEventListener('turbo:load', initManualCfdiForm);
    initManualCfdiForm();
  })();
</script>
