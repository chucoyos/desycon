<% payment_status_chip = case payment.status
  when "registered" then "bg-emerald-100 text-emerald-800"
  when "complement_queued" then "bg-blue-100 text-blue-800"
  when "failed" then "bg-rose-100 text-rose-800"
  else "bg-slate-100 text-slate-700"
end %>

<div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-[0_2px_8px_rgba(15,23,42,0.08)]">
  <div class="flex items-start justify-between gap-3">
    <div class="min-w-0">
      <p class="text-[11px] font-medium uppercase tracking-wide text-slate-500">Pago registrado</p>
      <p class="mt-1 text-sm font-semibold text-slate-900"><%= l(payment.paid_at, format: :short) %></p>
    </div>
    <div class="text-right">
      <p class="text-lg font-semibold text-slate-900"><%= number_to_currency(payment.amount) %></p>
      <span class="mt-1 inline-flex items-center rounded-full px-2.5 py-0.5 text-[11px] font-semibold <%= payment_status_chip %>"><%= payment.status_label %></span>
    </div>
  </div>

  <div class="mt-4 grid grid-cols-1 gap-2 rounded-xl bg-slate-50 p-3 text-xs text-slate-700">
    <p><span class="font-medium text-slate-500">Forma:</span> <%= [payment.payment_method, FiscalProfile::FORMAS_PAGO[payment.payment_method]].compact.join(' - ') %></p>
    <p><span class="font-medium text-slate-500">Referencia:</span> <%= payment.reference.presence || '-' %></p>
  </div>

  <div class="mt-3 rounded-xl border border-slate-200 p-3">
    <p class="text-[11px] font-medium uppercase tracking-wide text-slate-500">Complemento</p>
    <% if payment.complement_invoice.present? %>
      <div class="mt-2 flex flex-col gap-1.5">
        <%= link_to(payment.complement_invoice.sat_uuid.presence || "Factura ##{payment.complement_invoice.id}", invoice_path(payment.complement_invoice), class: "text-xs font-mono font-semibold text-indigo-700 hover:text-indigo-900") %>
        <div class="flex items-center gap-1.5">
          <% if payment.complement_invoice.xml_file.attached? %>
            <%= link_to "XML", rails_blob_path(payment.complement_invoice.xml_file, disposition: "attachment"), class: "inline-flex items-center rounded-full border border-slate-300 bg-white px-2.5 py-1 text-[10px] font-semibold text-slate-700 hover:bg-slate-100" %>
          <% end %>
          <% if payment.complement_invoice.pdf_file.attached? %>
            <%= link_to "PDF", rails_blob_path(payment.complement_invoice.pdf_file, disposition: "attachment"), class: "inline-flex items-center rounded-full border border-slate-300 bg-white px-2.5 py-1 text-[10px] font-semibold text-slate-700 hover:bg-slate-100" %>
          <% end %>
        </div>
      </div>
    <% elsif payment.status == "complement_queued" %>
      <span class="mt-2 inline-flex items-center rounded-full bg-blue-100 px-2.5 py-0.5 text-[11px] font-semibold text-blue-800">En cola</span>
    <% elsif payment.status == "failed" %>
      <span class="mt-2 inline-flex items-center rounded-full bg-rose-100 px-2.5 py-0.5 text-[11px] font-semibold text-rose-800">Falló</span>
    <% else %>
      <p class="mt-2 text-xs text-slate-500">Sin complemento</p>
    <% end %>
  </div>

  <% if can_manage_payments %>
    <div class="mt-3 flex justify-end border-t border-slate-200 pt-3">
      <div class="relative inline-block text-left" data-controller="dropdown">
        <button type="button" class="cursor-pointer inline-flex h-10 w-10 items-center justify-center rounded-full bg-slate-100 text-slate-600 transition-colors hover:bg-slate-200 hover:text-slate-800 focus:outline-none" data-action="click->dropdown#toggle" title="Opciones">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2z"></path>
          </svg>
        </button>
        <div data-dropdown-target="menu" class="hidden absolute right-0 mt-2 w-48 rounded-xl border border-slate-200 bg-white shadow-xl z-[70] origin-top-right ring-1 ring-black ring-opacity-5 focus:outline-none">
          <div class="py-2" role="menu">
            <%= link_to invoice_invoice_payment_path(invoice, payment), class: "cursor-pointer flex items-center gap-3 px-4 py-2.5 text-sm text-slate-700 hover:bg-slate-50 hover:text-slate-900 transition-colors", role: "menuitem" do %>
              <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
              </svg>
              Ver
            <% end %>

            <% if payment.complement_invoice_id.blank? && payment.status.in?(["registered", "failed"]) %>
              <%= link_to edit_invoice_invoice_payment_path(invoice, payment), class: "cursor-pointer flex items-center gap-3 px-4 py-2.5 text-sm text-slate-700 hover:bg-slate-50 hover:text-slate-900 transition-colors", role: "menuitem" do %>
                <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                </svg>
                Editar
              <% end %>

              <div class="my-1 border-t border-slate-100"></div>
              <%= button_to invoice_invoice_payment_path(invoice, payment), method: :delete,
                  form: { data: { turbo_confirm: "¿Eliminar este pago?" } },
                  class: "group flex w-full items-center gap-3 px-4 py-2.5 text-sm text-rose-600 hover:bg-rose-50 hover:text-rose-900 transition-colors", role: "menuitem" do %>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                </svg>
                Eliminar
              <% end %>
            <% else %>
              <div class="px-4 py-2 text-xs text-slate-500">Edición bloqueada</div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>
