<% content_for :title, "Facturas" %>

<div class="w-full px-4 sm:px-6 lg:px-8 py-4 sm:py-6 lg:py-8">
  <div class="mb-8">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
      <div class="flex items-start gap-4">
        <div class="flex items-center justify-center w-14 h-14 rounded-xl bg-gradient-to-br from-indigo-500 to-indigo-600 shadow-lg">
          <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6M7 4h10a2 2 0 012 2v12a2 2 0 01-2 2H7a2 2 0 01-2-2V6a2 2 0 012-2z"/>
          </svg>
        </div>
        <div>
          <h1 class="font-bold text-3xl text-gray-900">Facturas</h1>
          <p class="text-sm text-gray-500 mt-1">Consulta y seguimiento de facturas emitidas</p>
        </div>
      </div>

      <% if policy(Invoice).new? %>
        <%= link_to "Nuevo CFDI", new_invoice_path,
          class: "inline-flex items-center justify-center gap-2 px-4 py-2.5 rounded-lg bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-semibold shadow-sm transition-all" %>
      <% end %>
    </div>
  </div>

  <div class="bg-white rounded-xl shadow-md border border-gray-200 p-5 mb-6">
    <div class="flex items-center gap-2 mb-4">
      <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"/>
      </svg>
      <h2 class="text-sm font-semibold text-gray-700 uppercase tracking-wider">Filtros</h2>
    </div>

    <%= form_with url: invoices_path, method: :get, class: "w-full", data: { turbo: false } do |f| %>
      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">Emision</label>
          <%= f.select :status,
            options_for_select([["Todos", ""]] + @invoice_statuses.map { |status| [t("activerecord.attributes.invoice.statuses.#{status}", default: status.humanize), status] }, @selected_status),
              {},
              class: "w-full px-3 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 text-sm transition-all" %>
        </div>

        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">Tipo comprobante</label>
          <%= f.select :kind,
            options_for_select([["Todos", ""], ["Factura", "ingreso"], ["Pago", "pago"]], @selected_kind),
              {},
              class: "w-full px-3 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 text-sm transition-all" %>
        </div>

        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">Pago</label>
          <%= f.select :payment_status,
            options_for_select([["Todos", ""]] + @payment_statuses.map { |status| [Invoice::PAYMENT_STATUS_LABELS[status], status] }, @selected_payment_status),
              {},
              class: "w-full px-3 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 text-sm transition-all" %>
        </div>

        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">Desde</label>
          <%= f.date_field :start_date, value: @selected_start_date, class: "w-full px-3 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 text-sm transition-all" %>
        </div>

        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">Hasta</label>
          <%= f.date_field :end_date, value: @selected_end_date, class: "w-full px-3 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 text-sm transition-all" %>
        </div>

        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">Receptor</label>
          <% selected_client = @clients.find { |client| client.id.to_s == @selected_client_id.to_s } if @selected_client_id.present? %>
          <div
            data-controller="catalog-autocomplete"
            data-catalog-autocomplete-url-value="<%= receivers_search_invoices_path %>"
            data-catalog-autocomplete-min-chars-value="2"
            data-catalog-autocomplete-debounce-value="300"
            class="relative"
          >
            <%= hidden_field_tag :client_id,
              @selected_client_id,
              data: { catalog_autocomplete_target: "hiddenInput" } %>

            <%= text_field_tag :client_search,
              selected_client&.name,
              autocomplete: "off",
              placeholder: "Todos",
              class: "w-full px-3 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 text-sm transition-all",
              data: {
                catalog_autocomplete_target: "input",
                action: "input->catalog-autocomplete#onInput keydown->catalog-autocomplete#onKeydown focus->catalog-autocomplete#onFocus blur->catalog-autocomplete#onBlur"
              } %>

            <div data-catalog-autocomplete-target="status" class="mt-1 text-xs text-gray-500"></div>
            <div data-catalog-autocomplete-target="results" class="absolute z-30 mt-2 hidden w-full rounded-lg border border-gray-200 bg-white shadow-lg max-h-72 overflow-auto"></div>
          </div>

          <noscript>
            <%= f.select :client_id,
              options_for_select([["Todos", ""]] + @clients.map { |client| [client.name, client.id] }, @selected_client_id),
              {},
              class: "w-full px-3 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 text-sm transition-all" %>
          </noscript>
        </div>

        <% if @admin_or_executive %>
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">Agencia aduanal</label>
            <%= f.select :customs_agent_id,
                options_for_select([["Todos", ""]] + @customs_agents.map { |agent| [agent.name, agent.id] }, @selected_customs_agent_id),
                {},
                class: "w-full px-3 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 text-sm transition-all" %>
          </div>
        <% end %>

        <% if @admin_or_executive %>
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">Consolidador</label>
            <%= f.select :consolidator_id,
                options_for_select([["Todos", ""]] + @consolidators.map { |consolidator| [consolidator.name, consolidator.id] }, @selected_consolidator_id),
                {},
                class: "w-full px-3 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 text-sm transition-all" %>
          </div>
        <% end %>

        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">UUID</label>
          <%= f.text_field :uuid, value: @selected_uuid, placeholder: "Buscar UUID", class: "w-full px-3 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 text-sm transition-all" %>
        </div>

        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">Contenedor</label>
          <%= f.text_field :container_number, value: @selected_container_number, placeholder: "Buscar número de contenedor", maxlength: 11, class: "w-full px-3 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 text-sm transition-all" %>
        </div>

        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">BL House</label>
          <%= f.text_field :blhouse, value: @selected_blhouse, placeholder: "Buscar BL House", class: "w-full px-3 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 text-sm transition-all" %>
        </div>

        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">Serie</label>
          <%= f.select :serie,
            options_for_select(@series_filter_options || [["Todas", ""]], @selected_serie),
            {},
            class: "w-full px-3 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 text-sm transition-all" %>
        </div>

        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">Folio</label>
          <%= f.text_field :folio, value: @selected_folio, placeholder: "Buscar Folio", class: "w-full px-3 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 text-sm transition-all" %>
        </div>

        <div class="md:col-span-2 xl:col-span-3 flex gap-2 items-end">
          <%= f.submit "Filtrar", class: "px-4 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg text-sm font-semibold transition-all shadow-sm hover:shadow-md cursor-pointer" %>
          <%= link_to "Limpiar", invoices_path, class: "cursor-pointer px-4 py-2.5 bg-gray-100 hover:bg-gray-200 text-gray-700 rounded-lg text-sm font-medium transition-colors" %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="mb-6">
    <%= render 'shared/tailwind_pagination', paginated: @invoices %>
  </div>

  <% if @consolidator_portal_user %>
    <div class="mb-4 rounded-xl border border-indigo-200 bg-indigo-50 px-4 py-3 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
      <div>
        <p class="text-sm font-semibold text-indigo-900">Adjuntar comprobante a múltiples facturas</p>
        <p class="text-xs text-indigo-700 mt-0.5">Selecciona facturas con saldo pendiente y envía un solo comprobante para revisión.</p>
      </div>
      <%= form_with url: new_consolidators_payment_evidence_path, method: :get, html: { id: "consolidator-payment-evidence-batch-form" }, data: { turbo_frame: "payment_evidence_modal" }, class: "flex items-center gap-3" do %>
        <span id="consolidator-selected-invoices-count" class="text-xs font-semibold text-indigo-800">0 seleccionadas</span>
        <%= submit_tag "Adjuntar comprobante", id: "consolidator-open-payment-evidence-modal", disabled: true, class: "cursor-pointer inline-flex items-center justify-center h-10 px-4 rounded-full text-sm font-semibold bg-indigo-600 text-white hover:bg-indigo-700 disabled:opacity-50 disabled:cursor-not-allowed" %>
      <% end %>
    </div>
  <% end %>

  <div class="hidden lg:block bg-white shadow-sm rounded-xl overflow-visible border border-gray-100">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gradient-to-r from-gray-50 to-white">
        <tr>
          <% if @consolidator_portal_user %>
            <th class="px-4 py-4 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider w-12">
              <input type="checkbox" id="consolidator-select-all-invoices" class="h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" />
            </th>
          <% end %>
          <th class="px-6 py-4 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Fecha</th>
          <th class="px-6 py-4 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Serie</th>
          <th class="px-6 py-4 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Folio</th>
          <th class="px-6 py-4 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Receptor</th>
          <th class="px-6 py-4 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Emision</th>
          <th class="px-6 py-4 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Pago</th>
          <th class="px-6 py-4 text-right text-xs font-semibold text-gray-700 uppercase tracking-wider">Saldo</th>
          <th class="px-6 py-4 text-right text-xs font-semibold text-gray-700 uppercase tracking-wider">Acciones</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-100">
        <% if @invoices.any? %>
          <% @invoices.each do |invoice| %>
            <% can_view_details = policy(invoice).show? %>
            <% can_attach_payment_evidence = policy(invoice).attach_payment_evidence? %>
            <% payment_evidence_new_path = if current_user.consolidator? && current_user.entity&.role_consolidator?
              new_consolidators_payment_evidence_path(invoice_ids: [ invoice.id ])
            else
              new_customs_agents_payment_evidence_path(invoice_id: invoice.id)
            end %>
            <% serie = invoice.provider_response.to_h["serie"].presence || invoice.payload_snapshot.to_h["serie"].presence %>
            <% folio = invoice.provider_response.to_h["folio"].presence ||
                       invoice.provider_response.to_h["noComprobante"].presence ||
                       invoice.provider_response.to_h["numeroComprobante"].presence ||
                       invoice.facturador_comprobante_id&.to_s %>
            <tr class="hover:bg-gray-50 transition-colors duration-150">
              <% if @consolidator_portal_user %>
                <td class="px-4 py-4 align-top">
                  <% if can_attach_payment_evidence %>
                    <input
                      type="checkbox"
                      name="invoice_ids[]"
                      value="<%= invoice.id %>"
                      form="consolidator-payment-evidence-batch-form"
                      class="consolidator-invoice-selector h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500"
                    />
                  <% end %>
                </td>
              <% end %>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700">
                <% if can_view_details %>
                  <%= link_to l(invoice.created_at, format: :short), invoice_path(invoice), class: "text-indigo-700 hover:text-indigo-900 font-medium" %>
                <% else %>
                  <span><%= l(invoice.created_at, format: :short) %></span>
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-xs font-mono text-gray-700">
                <% if serie.present? %>
                  <% if can_view_details %>
                    <%= link_to serie, invoice_path(invoice), class: "text-indigo-700 hover:text-indigo-900" %>
                  <% else %>
                    <span><%= serie %></span>
                  <% end %>
                <% else %>
                  -
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-xs font-mono text-gray-700">
                <% if folio.present? %>
                  <% if can_view_details %>
                    <%= link_to folio, invoice_path(invoice), class: "text-indigo-700 hover:text-indigo-900" %>
                  <% else %>
                    <span><%= folio %></span>
                  <% end %>
                <% else %>
                  -
                <% end %>
                <% if invoice.sat_uuid.present? %>
                  <span class="sr-only"><%= invoice.sat_uuid %></span>
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700"><%= invoice.receiver_entity&.name || '-' %></td>
              <% status_for_display = invoice.effective_status %>
              <% issue_status_badge_class = case status_for_display
                when "issued" then "bg-emerald-100 text-emerald-800 border-emerald-200"
                when "queued" then "bg-blue-100 text-blue-800 border-blue-200"
                when "failed" then "bg-rose-100 text-rose-800 border-rose-200"
                when "cancel_pending" then "bg-amber-100 text-amber-800 border-amber-200"
                when "cancelled" then "bg-slate-100 text-slate-800 border-slate-200"
                else "bg-gray-100 text-gray-700 border-gray-200"
              end %>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700">
                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold border <%= issue_status_badge_class %>">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5-2a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  <%= t("activerecord.attributes.invoice.statuses.#{status_for_display}", default: status_for_display.humanize) %>
                </span>
              </td>
              <% payment_status_badge_class = case invoice.payment_status
                when "paid" then "bg-emerald-100 text-emerald-800 border-emerald-200"
                when "partial" then "bg-blue-100 text-blue-800 border-blue-200"
                else "bg-amber-100 text-amber-800 border-amber-200"
              end %>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700">
                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold border <%= payment_status_badge_class %>">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h5M5 6h14a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2z" />
                  </svg>
                  <%= invoice.payment_status_label %>
                </span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-right font-semibold text-gray-900"><%= number_to_currency(invoice.outstanding_amount || 0) %></td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                <div class="relative inline-block text-left" data-controller="dropdown">
                  <button type="button" class="h-10 w-10 inline-flex items-center justify-center rounded-full text-slate-500 hover:text-slate-700 hover:bg-slate-100 transition-colors focus:outline-none focus:ring-2 focus:ring-indigo-500" data-action="click->dropdown#toggle" title="Opciones">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2z"></path>
                    </svg>
                  </button>

                  <div data-dropdown-target="menu" class="hidden absolute right-0 mt-2 w-64 rounded-2xl border border-slate-200 bg-white shadow-[0_14px_40px_rgba(15,23,42,0.16)] z-50 origin-top-right">
                    <div class="py-2" role="menu">
                      <% if can_view_details %>
                        <%= link_to invoice_path(invoice), class: "flex items-center gap-3 px-4 py-2.5 text-sm text-slate-700 hover:bg-slate-50 hover:text-slate-900 transition-colors", role: "menuitem" do %>
                          <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                          </svg>
                          Ver detalle
                        <% end %>
                      <% end %>

                      <% if can_attach_payment_evidence %>
                        <%= link_to payment_evidence_new_path, class: "flex items-center gap-3 px-4 py-2.5 text-sm text-indigo-700 hover:bg-indigo-50 hover:text-indigo-900 transition-colors", role: "menuitem", data: { turbo_frame: "payment_evidence_modal" } do %>
                          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6M7 4h7l5 5v11a2 2 0 01-2 2H7a2 2 0 01-2-2V6a2 2 0 012-2z" />
                          </svg>
                          Adjuntar comprobante de pago
                        <% end %>
                      <% end %>
                    </div>
                  </div>
                </div>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="<%= @consolidator_portal_user ? 9 : 8 %>" class="px-6 py-12 text-center">
              <p class="text-gray-500 text-lg font-medium">No hay facturas para los filtros seleccionados</p>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div class="lg:hidden space-y-4">
    <% if @invoices.any? %>
      <% @invoices.each do |invoice| %>
        <% if @consolidator_portal_user && policy(invoice).attach_payment_evidence? %>
          <label class="flex items-center gap-2 px-2 text-xs font-semibold text-indigo-800">
            <input
              type="checkbox"
              name="invoice_ids[]"
              value="<%= invoice.id %>"
              form="consolidator-payment-evidence-batch-form"
              class="consolidator-invoice-selector h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500"
            />
            Seleccionar para comprobante
          </label>
        <% end %>
        <%= render "invoices/mobile_card", invoice: invoice %>
      <% end %>
    <% else %>
      <div class="bg-white shadow-sm rounded-xl p-8 text-center border border-gray-100">
        <p class="text-gray-500 text-base font-medium">No hay facturas para los filtros seleccionados</p>
      </div>
    <% end %>
  </div>

  <div class="mt-6">
    <%= render 'shared/tailwind_pagination', paginated: @invoices %>
  </div>
</div>

<turbo-frame id="payment_evidence_modal"></turbo-frame>

<script>
  document.addEventListener("turbo:load", initConsolidatorInvoiceEvidenceSelection);
  document.addEventListener("turbo:render", initConsolidatorInvoiceEvidenceSelection);

  function initConsolidatorInvoiceEvidenceSelection() {
    const form = document.getElementById("consolidator-payment-evidence-batch-form");
    if (!form) return;

    const checkboxes = Array.from(document.querySelectorAll(".consolidator-invoice-selector"));
    const selectAll = document.getElementById("consolidator-select-all-invoices");
    const submitButton = document.getElementById("consolidator-open-payment-evidence-modal");
    const countElement = document.getElementById("consolidator-selected-invoices-count");

    const updateState = () => {
      const selected = checkboxes.filter((checkbox) => checkbox.checked).length;
      if (submitButton) submitButton.disabled = selected === 0;
      if (countElement) countElement.textContent = `${selected} seleccionadas`;
      if (selectAll) {
        const selectable = checkboxes.length;
        selectAll.checked = selectable > 0 && selected === selectable;
      }
    };

    if (selectAll) {
      selectAll.addEventListener("change", () => {
        checkboxes.forEach((checkbox) => {
          checkbox.checked = selectAll.checked;
        });
        updateState();
      });
    }

    checkboxes.forEach((checkbox) => checkbox.addEventListener("change", updateState));
    updateState();
  }
</script>
