<%= turbo_frame_tag "payment_evidence_modal" do %>
  <div class="fixed inset-0 z-[80] flex items-center justify-center bg-slate-900/60 px-4">
    <div class="w-full max-w-lg rounded-2xl bg-white shadow-2xl border border-slate-200 overflow-hidden">
      <div class="px-6 py-5 border-b border-slate-100">
        <h2 class="text-lg font-semibold text-slate-900">Comprobante enviado</h2>
        <p class="mt-1 text-sm text-slate-600">Tu evidencia fue enviada para revisión del ejecutivo.</p>
      </div>
      <div class="px-6 py-5 flex justify-end">
        <button type="button" class="cursor-pointer inline-flex items-center justify-center h-10 px-5 rounded-full text-sm font-semibold bg-indigo-600 text-white hover:bg-indigo-700" onclick="document.getElementById('payment_evidence_modal').innerHTML = ''">
          Cerrar
        </button>
      </div>
    </div>
  </div>
<% end %>
