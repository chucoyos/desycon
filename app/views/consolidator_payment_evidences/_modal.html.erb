<%= turbo_frame_tag "payment_evidence_modal" do %>
  <div class="fixed inset-0 z-[80] flex items-center justify-center bg-slate-900/60 px-4" data-controller="payment-evidence-modal" data-action="click->payment-evidence-modal#backgroundClose">
    <div class="w-full max-w-3xl rounded-2xl bg-white shadow-2xl border border-slate-200 max-h-[90vh] overflow-y-auto" role="dialog" aria-modal="true" aria-labelledby="consolidator-payment-evidence-title">
      <div class="sticky top-0 z-10 bg-white border-b border-slate-200 px-5 py-4 flex items-center justify-between">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.08em] text-indigo-600">Consolidador</p>
          <h2 id="consolidator-payment-evidence-title" class="text-lg font-semibold text-slate-900">Adjuntar comprobante para múltiples facturas</h2>
        </div>
        <button type="button" class="cursor-pointer inline-flex items-center justify-center h-9 w-9 rounded-full text-slate-500 hover:bg-slate-100" onclick="document.getElementById('payment_evidence_modal').innerHTML = ''" aria-label="Cerrar">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <div class="px-5 py-5">
        <%= render "consolidator_payment_evidences/form", modal: true %>
      </div>
    </div>
  </div>
<% end %>
