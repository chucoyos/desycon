<% container = bl_house_line.container %>
<% consolidator_name = container&.consolidator_entity&.name.presence || container&.consolidator&.name.presence || "N/A" %>
<% dom_suffix ||= :mobile %>
<% customs_broker_label = if bl_house_line.customs_broker.present?
    patent = bl_house_line.customs_broker.patent_number.to_s.strip
    broker_name = bl_house_line.customs_broker.name.to_s.strip
    patent.present? ? "#{broker_name} - #{patent}" : broker_name
  else
    "N/A"
  end %>
<% imo_label = bl_house_line.imo_double_charge_applicable? ? "Si" : "No" %>
<% menu_dom_id = "dropdown-menu-#{dom_suffix}-#{bl_house_line.id}" %>
<% button_dom_id = "dropdown-menu-button-#{dom_suffix}-#{bl_house_line.id}" %>

<div class="rounded-2xl border border-slate-200/80 bg-gradient-to-b from-white to-slate-50/70 shadow-[0_1px_2px_rgba(15,23,42,0.08),0_12px_28px_rgba(15,23,42,0.08)] hover:shadow-[0_2px_6px_rgba(15,23,42,0.12),0_16px_36px_rgba(15,23,42,0.1)] transition-shadow duration-200 overflow-visible" id="<%= dom_id(bl_house_line, dom_suffix) %>">
  <div class="flex items-start justify-between gap-3 px-4 py-3 bg-gradient-to-r from-slate-50/95 via-indigo-50/35 to-slate-50/95 border-b border-slate-200/70">
    <h3 class="inline-flex items-center gap-2 text-base sm:text-lg font-semibold text-slate-900">
      <span class="inline-flex h-7 w-7 items-center justify-center rounded-lg bg-indigo-600 text-white shrink-0 shadow-sm">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
        </svg>
      </span>
      <span><%= bl_house_line.blhouse.presence || "N/A" %></span>
    </h3>
    <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium shadow-sm <%= bl_house_line_status_badge_class(bl_house_line.status) %>">
      <%= bl_house_line_status_icon(bl_house_line.status) %>
      <%= bl_house_line_status_nombre(bl_house_line.status) %>
    </span>
  </div>

  <div class="p-4">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-2 text-sm">
      <div class="rounded-lg bg-white/85 backdrop-blur-[1px] px-3 py-2 border border-slate-200/70 shadow-[inset_0_1px_0_rgba(255,255,255,0.8)]">
        <p class="text-[11px] uppercase tracking-wide text-slate-500">Contenedor</p>
        <p class="font-semibold text-slate-900 break-words"><%= container&.number.presence || "N/A" %></p>
      </div>
      <div class="rounded-lg bg-white/85 backdrop-blur-[1px] px-3 py-2 border border-slate-200/70 shadow-[inset_0_1px_0_rgba(255,255,255,0.8)]">
        <p class="text-[11px] uppercase tracking-wide text-slate-500">BL Master</p>
        <p class="font-semibold text-slate-900 break-words"><%= container&.bl_master.presence || "N/A" %></p>
      </div>
      <div class="rounded-lg bg-white/85 backdrop-blur-[1px] px-3 py-2 border border-slate-200/70 shadow-[inset_0_1px_0_rgba(255,255,255,0.8)]">
        <p class="text-[11px] uppercase tracking-wide text-slate-500">BL House</p>
        <p class="font-semibold text-slate-900 break-words"><%= bl_house_line.blhouse.presence || "N/A" %></p>
      </div>
      <div class="rounded-lg bg-white/85 backdrop-blur-[1px] px-3 py-2 border border-slate-200/70 shadow-[inset_0_1px_0_rgba(255,255,255,0.8)]">
        <p class="text-[11px] uppercase tracking-wide text-slate-500">Cantidad</p>
        <p class="font-semibold text-slate-900"><%= bl_house_line.cantidad || "N/A" %></p>
      </div>
      <div class="rounded-lg bg-white/85 backdrop-blur-[1px] px-3 py-2 border border-slate-200/70 shadow-[inset_0_1px_0_rgba(255,255,255,0.8)]">
        <p class="text-[11px] uppercase tracking-wide text-slate-500">Peso</p>
        <p class="font-semibold text-slate-900"><%= bl_house_line.peso ? number_with_precision(bl_house_line.peso, precision: 2) : "N/A" %></p>
      </div>
      <div class="rounded-lg bg-white/85 backdrop-blur-[1px] px-3 py-2 border border-slate-200/70 shadow-[inset_0_1px_0_rgba(255,255,255,0.8)]">
        <p class="text-[11px] uppercase tracking-wide text-slate-500">Volumen</p>
        <p class="font-semibold text-slate-900"><%= bl_house_line.volumen ? number_with_precision(bl_house_line.volumen, precision: 2) : "N/A" %></p>
      </div>
      <div class="rounded-lg bg-white/85 backdrop-blur-[1px] px-3 py-2 border border-slate-200/70 shadow-[inset_0_1px_0_rgba(255,255,255,0.8)]">
        <p class="text-[11px] uppercase tracking-wide text-slate-500">Consolidador</p>
        <p class="font-semibold text-slate-900 break-words"><%= consolidator_name %></p>
      </div>
      <div class="rounded-lg bg-white/85 backdrop-blur-[1px] px-3 py-2 border border-slate-200/70 shadow-[inset_0_1px_0_rgba(255,255,255,0.8)]">
        <p class="text-[11px] uppercase tracking-wide text-slate-500">Agente Aduanal</p>
        <p class="font-semibold text-slate-900 break-words"><%= customs_broker_label.presence || "N/A" %></p>
      </div>
      <div class="rounded-lg bg-white/85 backdrop-blur-[1px] px-3 py-2 border border-slate-200/70 shadow-[inset_0_1px_0_rgba(255,255,255,0.8)]">
        <p class="text-[11px] uppercase tracking-wide text-slate-500">Agencia Aduanal</p>
        <p class="font-semibold text-slate-900 break-words"><%= bl_house_line.customs_agent&.name.presence || "N/A" %></p>
      </div>
      <div class="rounded-lg bg-white/85 backdrop-blur-[1px] px-3 py-2 border border-slate-200/70 shadow-[inset_0_1px_0_rgba(255,255,255,0.8)]">
        <p class="text-[11px] uppercase tracking-wide text-slate-500">Almacén</p>
        <p class="font-semibold text-slate-900 break-words"><%= container&.almacen.presence || "N/A" %></p>
      </div>
      <div class="rounded-lg bg-white/85 backdrop-blur-[1px] px-3 py-2 border border-slate-200/70 shadow-[inset_0_1px_0_rgba(255,255,255,0.8)]">
        <p class="text-[11px] uppercase tracking-wide text-slate-500">IMO</p>
        <p class="font-semibold <%= imo_label == 'Si' ? 'text-rose-700' : 'text-emerald-700' %>"><%= imo_label %></p>
      </div>
    </div>
  </div>

  <div class="flex justify-end gap-2 px-4 py-3 border-t border-slate-200/80 bg-slate-50/60">
    <div class="relative inline-block text-left">
      <button type="button" class="cursor-pointer inline-flex items-center justify-center w-10 h-10 rounded-full bg-white text-slate-600 border border-slate-200 shadow-sm hover:bg-slate-100 focus:outline-none focus:ring-2 focus:ring-indigo-500" id="<%= button_dom_id %>" aria-expanded="false" aria-haspopup="true" onclick="document.getElementById('<%= menu_dom_id %>').classList.toggle('hidden')">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
          <circle cx="6" cy="12" r="1.5" />
          <circle cx="12" cy="12" r="1.5" />
          <circle cx="18" cy="12" r="1.5" />
        </svg>
      </button>
      <div id="<%= menu_dom_id %>" class="hidden absolute right-0 z-50 mt-2 w-44 origin-top-right rounded-xl bg-white shadow-lg ring-1 ring-slate-200 focus:outline-none">
        <div class="py-1">
          <%= link_to bl_house_line, class: "flex items-center gap-2 px-4 py-2 text-sm text-indigo-700 hover:bg-indigo-50 transition-colors duration-150", title: "Ver" do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
            </svg>
            Ver
          <% end %>

          <% if policy(bl_house_line).update? %>
            <%= link_to edit_bl_house_line_path(bl_house_line), class: "flex items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 transition-colors duration-150", title: "Editar" do %>
              <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
              </svg>
              Editar
            <% end %>

            <%= button_to bl_house_line_path(bl_house_line, bl_house_line: { hidden_from_customs_agent: !bl_house_line.hidden_from_customs_agent }), method: :patch, class: "flex items-center gap-2 w-full px-4 py-2 text-sm #{bl_house_line.hidden_from_customs_agent? ? 'text-emerald-700 hover:bg-emerald-50' : 'text-amber-700 hover:bg-amber-50'} transition-colors", form: { data: { turbo_confirm: bl_house_line.hidden_from_customs_agent? ? nil : "Ocultar esta partida a la agencia aduanal?" } }, title: (bl_house_line.hidden_from_customs_agent? ? "Mostrar a la agencia" : "Ocultar a la agencia") do %>
              <% if bl_house_line.hidden_from_customs_agent? %>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                Mostrar a la agencia
              <% else %>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.973 9.973 0 013.478-5.568m3.065-1.72A9.956 9.956 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-1.249 2.592m-4.764-1.35a3 3 0 11-4.358-4.358" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3l18 18" />
                </svg>
                Ocultar Agencia
              <% end %>
            <% end %>

            <% if bl_house_line.revalidado? %>
              <%= link_to dispatch_date_bl_house_line_path(bl_house_line), class: "flex items-center gap-2 px-4 py-2 text-sm text-blue-700 hover:bg-blue-50 transition-colors duration-150", title: "Fecha de Despacho", data: { turbo_frame: "dispatch_modal" } do %>
                <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10m-7 4h4m-9 6h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                Fecha Despacho
              <% end %>
            <% end %>
          <% end %>

          <% if policy(bl_house_line).approve_revalidation? && !bl_house_line.revalidado? && !bl_house_line.despachado? %>
            <%= link_to revalidation_approval_bl_house_line_path(bl_house_line), class: "flex items-center gap-2 px-4 py-2 text-sm text-indigo-700 hover:bg-indigo-50 transition-colors duration-150", title: "Aprobar", data: { turbo_frame: "approval_modal" } do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2a2 2 0 012-2h2a2 2 0 012 2v2m-3-4v-2a2 2 0 00-2-2H9a2 2 0 00-2 2v2" />
              </svg>
              Abrir aprobación
            <% end %>
          <% end %>

          <% if policy(bl_house_line).reassign? && bl_house_line.revalidado? %>
            <%= link_to reassign_bl_house_line_path(bl_house_line), class: "flex items-center gap-2 px-4 py-2 text-sm text-amber-700 hover:bg-amber-50 transition-colors duration-150", title: "Reasignar" do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
              </svg>
              Reasignar Agente
            <% end %>
          <% end %>

          <% if policy(bl_house_line).documents? && (bl_house_line.revalidado? || (bl_house_line.despachado? && policy(bl_house_line).approve_revalidation?)) %>
            <%= link_to documents_bl_house_line_path(bl_house_line), class: "flex items-center gap-2 px-4 py-2 text-sm text-green-700 hover:bg-green-50 transition-colors duration-150", title: "Descargar Documentos", data: { turbo_frame: "revalidation_modal" } do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V18a2 2 0 01-2 2z"/>
              </svg>
              Descarga Docs
            <% end %>
          <% end %>

          <% if policy(bl_house_line).destroy? %>
            <div class="my-1 border-t border-gray-100"></div>
            <%= button_to bl_house_line, method: :delete, class: "flex items-center gap-2 w-full px-4 py-2 text-sm text-red-700 hover:bg-red-50 transition-colors duration-150", title: "Eliminar", data: { turbo_confirm: "¿Estás seguro?" } do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
              </svg>
              Eliminar
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
